             rdfs:label "Parent"@en ,
                        "Parent"@fr ;
             skos:definition "an owl:ObjectProperty relating an ec:Asset to an ec:Asset"@en ,
                             "une propriété objet owl reliant un ec:Asset à un ec:Asset"@fr .



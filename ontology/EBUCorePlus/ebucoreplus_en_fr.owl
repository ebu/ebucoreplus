ec:requiresLicence rdf:type owl:ObjectProperty ;
                   dcterms:description "La ec:ConsumptionLicence requise par une ec:ConsumptionEvent."@fr ,
                                       "The ConsumptionLicence required by a ConsumptionEvent."@en ;

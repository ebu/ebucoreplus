ec:hasReview a owl:ObjectProperty ;
    rdfs:label "Review"@en ;
    dcterms:description "To provide a review."@en .

ec:hasRightsClearance a owl:ObjectProperty ;
    rdfs:label "Rights clearance"@en ;
    dcterms:description "To express Rights Clearance."@en ;
    rdfs:subPropertyOf ec:hasRights .

ec:hasRightsHolder a owl:ObjectProperty ;
    rdfs:label "Rights holder"@en ;
    dcterms:description "To identify an Agent (Contact/person or Organisation) having/managing Rights."@en .

ec:hasRightsTargetService a owl:ObjectProperty ;
    rdfs:label "Target service"@en ;
    dcterms:description "To identify a Service associated with Rights."@en .

ec:hasRightsTerritoryExcludes a owl:ObjectProperty ;
    rdfs:label "Excluded territories"@en ;
    dcterms:description "A list of country or region codes to which Rights do not apply."@en .

ec:hasRightsTerritoryIncludes a owl:ObjectProperty ;
    rdfs:label "Included territories"@en ;
    dcterms:description "A list of country or region codes to which Rights apply."@en .

ec:hasScheduleDate a owl:ObjectProperty ;
    rdfs:label "Schedule date"@en ;
    dcterms:description "To express specifically the schedule date to which a PublicationEvent is related in particular if the broadcast time is after midnight. For example, the schedule date would be May 29th and the programme is published at 1 am on May 30th, while still associated in the schedule with the night of May 29th."@en .

ec:hasSerial a owl:ObjectProperty ;
    rdfs:label "has serial"@en .

ec:hasServiceGenre a owl:ObjectProperty ;
    rdfs:label "Service genre"@en ;
    dcterms:description "The genre of content associated with the Service."@en .

ec:hasShot a owl:ObjectProperty ;
    rdfs:label "has shot"@en ;
    rdfs:subPropertyOf ec:hasPart .

ec:hasSigning a owl:ObjectProperty ;
    rdfs:label "Accessibility - signing"@en ;
    dcterms:description "To identify the presence of Signing associated with the EditorialObject."@en .

ec:hasSigningFormat a owl:ObjectProperty ;
    rdfs:label "Signing format"@en ;
    dcterms:description "To specify the format used for signing."@en .

ec:hasSigningSource a owl:ObjectProperty ;
    rdfs:label "Signing source"@en ;
    dcterms:description "To specify the source of signing."@en .

ec:hasSource a owl:ObjectProperty ;
    rdfs:label "Source"@en ;
    dcterms:description "To identify the source of a MediaResource."@en .

ec:hasStaffMember a owl:ObjectProperty ;
    rdfs:label "member of Staff"@en ;
    dcterms:description "To identify members of staff in an organisation."@en .

ec:hasStageLocation a owl:ObjectProperty ;
    rdfs:label "Stage location"@en ;
    dcterms:description "To associate a Location with a Stage."@en .

ec:hasStakeholder a owl:ObjectProperty ;
    rdfs:label "Publication plan stakeholder"@en,
        "Stakeholder"@en ;
    dcterms:description "An Agent related to the PublicationPlan."@en,
        "To identify Agents associated with a PublicationPlan."@en .

ec:hasStandard a owl:ObjectProperty ;
    rdfs:label "Standard"@en ;
    dcterms:description "Identifies the technical video standard of a MediaResource, i.e. NTSC or PAL."@en ;
    rdfs:subPropertyOf ec:hasFormat .

ec:hasSticker a owl:ObjectProperty ;
    rdfs:label "Link to Sticker"@en ;
    dcterms:description "To provide a link to a Sticker"@en .

ec:hasStorageId a owl:ObjectProperty ;

@prefix cc: <http://creativecommons.org/ns#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ec: <http://www.ebu.ch/metadata/ontologies/ebucoreplus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix spin: <http://spinrdf.org/spin#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix xkos: <https://rdf-vocabulary.ddialliance.org/xkos/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cc:licence a owl:AnnotationProperty .

dc:contributor a owl:AnnotationProperty ;
    rdfs:label "Beitragender"@de ;
    dcterms:description "Ein Agent, der in irgendeiner Phase der Verwaltung eines Assets mitgewirkt hat."@de .

dc:creator a owl:AnnotationProperty ;
    rdfs:label "Schöpfer"@de ;
    dcterms:description "So identifizieren Sie den Ersteller eines Assets."@de .

dc:description a owl:AnnotationProperty ;
    rdfs:label "Beschreibung"@de ;
    dcterms:description "Eine Beschreibung eines Assets."@de .

dc:format a owl:AnnotationProperty ;
    rdfs:label "Format"@de ;
    dcterms:description "Informationen über das Format einer Resource."@de .

dc:identifier a owl:AnnotationProperty ;
    rdfs:label "Kennung"@de ;
    dcterms:description "Um einen einfachen, nicht stark strukturierten Identifikator bereitzustellen."@de .

dc:language a owl:AnnotationProperty ;
    rdfs:label "Sprache"@de ;
    dcterms:description "Zur Definition von Sprachen, die mit einem Asset verbunden sind."@de .

dc:publisher a owl:AnnotationProperty ;
    rdfs:label "Herausgeber"@de ;
    dcterms:description "Ein Agent, der an der Verbreitung von Inhalten beteiligt ist."@de .

dc:rights a owl:AnnotationProperty .

dc:title a owl:AnnotationProperty ;
    rdfs:label "Titel"@de ;
    dcterms:description "Der Titel, unter dem ein EditorialObject bekannt ist."@de .

dc:type a owl:AnnotationProperty ;
    rdfs:label "Typ"@de ;
    dcterms:description "Ein Konzept, das mit einer Resource verbunden ist."@de .

dcterms:contributor rdfs:label "Beitragender"@de ;
    dcterms:description "Im Kontext von EBUCore für die Annotation von RDF-Eigenschaften reserviert."@de .

dcterms:description a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

spin:imports a owl:AnnotationProperty .

<http://www.ebu.ch/metadata/ontologies/ebucoreplus> a owl:Ontology ;
    cc:licence "http://creativecommons.org/licenses/by-sa/3.0/" ;
    dc:contributor "Alexander Schulze, Innotrade"@de,
        "Jürgen Grupp, SWR"@de,
        "Mark Guelbahar, IRT"@de ;
    vann:preferredNamespaceUri "http://www.ebu.ch/metadata/ontologies/ebucoreplus#" ;
    owl:imports <http://www.w3.org/2004/02/skos/core> ;
    owl:versionIRI <http://www.ebu.ch/metadata/ontologies/ebucoreplus/2.0.0> .

ec:Action a owl:Class ;
    rdfs:label "Aktion"@de ;
    dcterms:description "Eine Klasse zum Protokollieren von Aktionen."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasRelatedScene ],
        [ a owl:Restriction ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:ActionType a owl:Class ;
    rdfs:label "Aktionstyp"@de ;
    dcterms:description "Um eine Art von Aktion zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:AnnotationType a owl:Class ;
    rdfs:label "Art der Annotation"@de ;
    dcterms:description "Um eine Art von Anmerkung zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:ArtefactType a owl:Class ;
    rdfs:label "Artefakt-Typ"@de ;
    dcterms:description "Um eine Art von Artefakt zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:AssetType a owl:Class ;
    rdfs:label "Asset-Typ"@de ;
    dcterms:description "Um eine Art von Asset zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:Atmosphere a owl:Class ;
    rdfs:label "Atmosphäre"@de ;
    dcterms:description "Um ein Gefühl zu beschreiben, das die Atmosphäre zusammenfasst."@de ;
    rdfs:subClassOf ec:Type .

ec:AudienceLevel a owl:Class ;
    rdfs:label "Zielpublikum"@de ;
    dcterms:description "Das Zielpublikum (Zielregion, Zielgruppen Kategorie der Zielgruppe, aber auch Empfehlung der Eltern), für die die MedienResource bestimmt ist."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:targetAudienceSystem ],
        ec:Rating .

ec:AudienceRating a owl:Class ;
    rdfs:label "Eignung für Publikum"@de ;
    dcterms:description "Die Zielgruppe, für die die Resource geeignet ist gemäß Einstufungen wie MPAA (http://en.wikipedia.org/wiki/Motion_picture_rating_system) oder anderen organisatorischen / nationalen / lokalen Standards."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasAudienceScoreRecordingTechnique ],
        ec:Rating .

ec:AudienceScoreRecordingTechnique a owl:Class ;
    rdfs:label "Aufnahmetechnik für Publikumspartituren"@de ;
    dcterms:description "Um die Technik zu definieren, mit der ein Publikumsscore gemessen wird."@de ;
    rdfs:subClassOf skos:Concept .

ec:AudioChannelFunction a owl:Class ;
    rdfs:label "Funktion Audiokanal"@de ;
    dcterms:description "So definieren Sie die Funktion eines AudioChannels."@de ;
    rdfs:subClassOf skos:Concept .

ec:AudioChannelPurpose a owl:Class ;
    rdfs:label "Zweck des Audiokanals"@de ;
    dcterms:description "Um den Zweck eines AudioChannels zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:AudioContentType a owl:Class ;
    rdfs:label "Typ der Audio-Inhalte"@de ;
    dcterms:description "um einen Typ von AudioContent zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:AudioFormat a owl:Class ;
    rdfs:label "Audioformat"@de ;
    dcterms:description "Spezifiziert das Audioformat der MedienResource."@de ;
    rdfs:subClassOf ec:Format .

ec:AudioProgrammeType a owl:Class ;
    rdfs:label "Typ des Audioprogramms"@de ;
    dcterms:description "um einen Typ von AudioProgrammen zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:AudioStream a owl:Class ;
    rdfs:label "Audio-Stream"@de ;
    dcterms:description "Ein audioStreamFormat beschreibt ein dekodierbares Signal - zum Beispiel ein PCM-Signal oder einen Dolby E-Stream. Es besteht aus einem oder mehreren AudioTracks."@de ;
    rdfs:subClassOf ec:Stream .

ec:AudioTrackPurpose a owl:Class ;
    rdfs:label "Zweck der Audiospur"@de ;
    dcterms:description "Um den Zweck eines AudioTracks zu beschreiben, z.B. die Nachvertonung."@de ;
    rdfs:subClassOf skos:Concept .

ec:AwardType a owl:Class ;
    rdfs:label "Art der Auszeichnung"@de ;
    dcterms:description "Um eine Art von Award zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:Campaign a owl:Class ;
    rdfs:label "Kampagne"@de ;
    dcterms:description "Eine Kampagne legt die Strategie zur Publikation eines Produktes (Medieninhalt und damit verbundene Resourcen/Medienobjekte/Essenzen) für ein Zielpublikum gemäß eines Publikationsplans fest. Kampagnenstrategien können angepasst werden, indem die Resonanz auf Nutzungsereignisse (z.B. likes, downloads, etc.) analysiert wird. Kampagnen können für unterschiedlichste Produkte angewendet werden, z.B. Werbekampagnen, Promotionskampagnen, o.ä."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ResonanceCount ;
            owl:onProperty ec:hasInputResonance ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlan ;
            owl:onProperty ec:hasPublicationPlan ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:title ] ;
    skos:definition "eine Strategie zur koordinierten Veröffentlichung von Medieninhalten für ein Zielpublikum"@de ;
    skos:example """- eine Werbemaßnahme für ein Produkt, bei der eine Reihe von Videos zu einem Zeitpunkt und auf einem Kanal veröffentlicht wird, zu dem und an dem das Zielpublikum effektiv erreicht werden kann
- eine Ankündigung der journalistischen Berichterstattung über eine bevorstehende Regierungswahl aus vielen verschiedenen Perspektiven und für eine Vielzahl von Zielgruppen, die auf mehreren Kanälen des linearen Fernsehens, des linearen Radios, der sozialen Medien, der Podcast-Portale usw. veröffentlicht wird"""@de .

ec:CityCode a owl:Class ;
    rdfs:label "Stadtcode"@de ;
    dcterms:description "So weisen Sie einen Stadtcode zu."@de ;
    rdfs:subClassOf skos:Concept .

ec:ClosedCaptions a owl:Class ;
    rdfs:label "Geschlossene Unterschrift"@de ;
    dcterms:description "Untertitel werden als separater Inhalt bereitgestellt. Inhalt."@de ;
    rdfs:subClassOf ec:Captioning .

ec:ClosedSigning a owl:Class ;
    rdfs:label "Geschlossene Gebärdensprache"@de ;
    dcterms:description "Geschlossene Gebärdensprache wird als separater Inhalt bereitgestellt."@de ;
    rdfs:subClassOf ec:Signing .

ec:ClosedSubtitling a owl:Class ;
    rdfs:label "Geschlossene Untertitelung"@de ;
    dcterms:description "Geschlossene Untertitel werden als separater Inhalt bereitgestellt. Inhalt."@de ;
    rdfs:subClassOf ec:Subtitling .

ec:Collection a owl:Class ;
    rdfs:label "Kollektion"@de ;
    dcterms:description "Eine Gruppe von EditorialObjects. Es kann viele Arten von Sammlungen geben, für die spezifische Unterklassen definiert werden sollten. In der Welt der Archiven entspricht eine Sammlung allen Objekten, die zu einem einzelnen / Sammler."@de ;
    rdfs:subClassOf ec:EditorialGroup .

ec:CommercialCode a owl:Class ;
    rdfs:label "Handelsgesetzbuch"@de ;
    dcterms:description "Um eine Art von kommerziellen Inhalten zu identifizieren."@de ;
    rdfs:subClassOf ec:Type .

ec:ContainerFormat a owl:Class ;
    rdfs:label "Containerformat"@de ;
    dcterms:description "Definiert das Format des Containers, z.B. imf oder MXF. Es hält Informationen über das Container- oder Verpackungsformat im Gegensatz zum Stream-Encoding Format des Kanals, z.B. mp3, Wave, Quicktime, ogg."@de ;
    rdfs:subClassOf ec:Format .

ec:ContainerMimeType a owl:Class ;
    rdfs:label "Container Mime-Typ"@de ;
    dcterms:description "Die Definition des Containers, falls er als ein MIME-Typ. Dies wird als freier Text in einer Beschriftung oder als Bezeichner angegeben der auf einen Begriff in einem Klassifizierungsschema verweist. Für weitere Informationen: http://www.iana.org/assignments/media-types/application/index.html."@de ;
    rdfs:subClassOf ec:Format .

ec:ContentAlert a owl:Class ;
    rdfs:label "Inhalt Alarm"@de ;
    dcterms:description "Zur Bereitstellung von Informationen über eine bestimmte Art von potenziell sensiblen Inhalten."@de ;
    rdfs:subClassOf ec:Type .

ec:ContentEditorialCode a owl:Class ;
    rdfs:label "Redaktioneller Code"@de ;
    dcterms:description "Um einen Code von EditorialFormat zu definieren"@de ;
    rdfs:subClassOf ec:Type .

ec:ContractType a owl:Class ;
    rdfs:label "Vertragstyp"@de ;
    dcterms:description "Um eine Art von Vertrag zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:Costume a owl:Class ;
    rdfs:label "Kostüm"@de ;
    dcterms:description "Die in den Produktionen verwendeten Kostüme zu identifizieren und zu beschreiben."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Sticker ;
            owl:onProperty ec:hasSticker ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:costumeSizeInformation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:costumeTexture ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:gender ],
        ec:Artefact ;
    skos:definition "die Kleidung einer Schauspielerin/eines Schauspielers in einer Produktion"@de ;
    skos:example "- die Uniformen der Star Trek-Besatzung"@de .

ec:CostumeType a owl:Class ;
    rdfs:label "Typ Kostüm"@de ;
    dcterms:description "So definieren Sie einen Kostümtyp."@de ;
    rdfs:subClassOf skos:Concept .

ec:DepictedEvent a owl:Class ;
    rdfs:label "Dargestelltes Ereignis"@de ;
    dcterms:description "Ein DepictedEVent ist ein fiktives oder historisches oder eine andere Art von Ereignis, auf das sich der Inhalt des EditorialObjects oder der Resource bezieht bezieht."@de ;
    rdfs:subClassOf ec:Event .

ec:EditUnitCount a owl:Class ;
    rdfs:label "Anzahl der Einheiten bearbeiten"@de ;
    dcterms:description "Eine Bearbeitungseinheit kann ein Frame, ein Sample oder eine Zeitspanne sein."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:long ;
            owl:onProperty ec:editUnit ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:long ;
            owl:onProperty ec:editUnitNumbering ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        ec:TimelinePoint .

ec:EditorialExtra a owl:Class ;
    rdfs:label "Editorial Extra"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Programme ;
            owl:onProperty ec:hasProgramme ],
        ec:EditorialWork ;
    skos:definition "Ein Werk, das ein optionale Ergänzung zu einem anderen Werk ist und dazu dient zu erklären, zu unterhalten, zu werben oder ähnliches."@de ;
    skos:example """Extra-Inhalte für einen Kinofilm: Trailer, Making of, Bonus-Material, Outtakes, ...

"BehindTheScenes"
- Ein Editorial Extra, das eine Geschichte über Szenen des Werkes erzählt.
- Kurzfilm mit Erklärungen zu den Stunts in einem Actionfilm

"Bonus":
- ein Editorial Extra, das als erweiternder Inhalt eines Haupt-Werkes gedacht ist.
- Zusätzliche Inhalte für einen Film, die separat als Erweiterung konsumiert werden können

"MakingOf":
- Ein Dokumentarfilm über die Dreharbeiten oder die Produktion eines Films oder eines audiovisuellen Werks (Fernsehfilm, Fernsehserie usw.) oder einer anderen künstlerischen Produktion (z. B. Comic).

"Outtakes":
-ein Editorial Extra, in dem aussortierte Aufnahmen oder Szenen einer Produktion gesammelt werden, die den Nutzer aus Spaß, Neugier o.ä. ansprechen sollen
- ein Clip mit einer Sammlung von Outtakes auf einer Bonus-DVD zu einem Film

"Trailer":
- ein Editorial Extra mit einer typischen Werbelänge von bis zu 2 Minuten, die eine Sendung, eine Serie oder eine Reihe bewirbt, die in Zukunft veröffentlicht werden soll
- AV-Sequenz, die einen Film, eine Serie oder eine Fernsehsendung bewirbt.
- eine 1-Minuten-Vorschau auf die Folge der deutschen Serie "Tatort" vom kommenden Sonntag
- ein Promo-Clip für ein Sport-Pokal-Finale heute Abend"""@de .

ec:EditorialObjectType a owl:Class ;
    rdfs:label "Redaktioneller Objekttyp"@de ;
    dcterms:description "Um einen Typ eines redaktionellen Objekts zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:Emotion a owl:Class ;
    rdfs:label "Emotion"@de ;
    dcterms:description "Eine Klasse zum Protokollieren von Emotionen."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasRelatedScene ],
        [ a owl:Restriction ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:EmotionType a owl:Class ;
    rdfs:label "Emotion Typ"@de ;
    dcterms:description "Um eine Art von Emotion zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:EventType a owl:Class ;
    rdfs:label "Ereignis-Typ"@de ;
    dcterms:description "Um eine Art von Ereignis zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:ExclusivityType a owl:Class ;
    rdfs:label "Ausschließlichkeitstyp"@de ;
    dcterms:description "Um eine Art von Ausschließlichkeitsrechten zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:FictionalEvent a owl:Class ;
    rdfs:label "Fiktives Ereignis"@de ;
    dcterms:description "Um ein fiktives Ereignis zu beschreiben."@de ;
    rdfs:subClassOf ec:Event .

ec:FictionalLocation a owl:Class ;
    rdfs:label "Fiktiver Ort"@de ;
    dcterms:description "Um einen fiktiven Ort zu beschreiben."@de ;
    rdfs:subClassOf ec:Location .

ec:FictionalOrganisation a owl:Class ;
    rdfs:label "Fiktive Organisation"@de ;
    dcterms:description "Um eine fiktive Organisation zu definieren."@de ;
    rdfs:subClassOf ec:Organisation .

ec:Food a owl:Class ;
    rdfs:label "Essen"@de ;
    dcterms:description "Zur Beschreibung von Lebensmitteln, die in Produktionen gezeigt oder konsumiert werden."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasCuisineOrigin ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CuisineStyle ;
            owl:onProperty ec:hasCuisineStyle ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:FoodStyle ;
            owl:onProperty ec:hasFoodStyle ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:foodCategory ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:foodIngredient ],
        ec:Artefact .

ec:Generation a owl:Class ;
    rdfs:label "Generation"@de ;
    dcterms:description "Identifiziert die Erzeugung einer Version einer Resource, d.h. Master, Edit Master, Verteilungskopie, etc."@de ;
    rdfs:subClassOf ec:Format .

ec:Genre a owl:Class ;
    rdfs:label "Genre"@de ;
    dcterms:description "Diese Klasse wird verwendet, um Informationen über das Genre des EditorialObjects bereitzustellen. Dies wird als freier Text in einer Beschriftung oder als Kennung, die auf einen Begriff in einem Klassifizierungsschema verweist, bereitgestellt, z.B. http://www.ebu.ch/metadata/ontologies/skos/ebu_ContentGenreCS.rdf oder http://www.ebu.ch/metadata/ontologies/skos/ebu_EditorialFormatCodeCS.rdf."@de ;
    rdfs:subClassOf ec:Type .

ec:IdentifierType a owl:Class ;
    rdfs:label "Identifikator Typ"@de ;
    dcterms:description "So definieren Sie einen Typ von Identifikator."@de ;
    rdfs:subClassOf skos:Concept .

ec:IntentionCode a owl:Class ;
    rdfs:label "Absichtscode"@de ;
    dcterms:description "Zur Angabe des Zwecks, für den der Inhalt erstellt wurde."@de ;
    rdfs:subClassOf ec:Type .

ec:Keyframe a owl:Class ;
    rdfs:label "Keyframe"@de ;
    dcterms:description "Ein Keyframe ist ein aus einem Video extrahiertes Bild, z.B. repräsentativ für einen Teil einer MedienResource."@de ;
    rdfs:subClassOf ec:Picture .

ec:LocationType a owl:Class ;
    rdfs:label "Standorttyp"@de ;
    dcterms:description "So definieren Sie eine Art von Ort."@de ;
    rdfs:subClassOf skos:Concept .

ec:MediaResourceType a owl:Class ;
    rdfs:label "Typ der MedienResource"@de ;
    dcterms:description "Um einen Typ von MediaResource zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:MediaType a owl:Class ;
    rdfs:label "Medientyp"@de ;
    dcterms:description "Um zusätzliche Informationen über die Art des Mediums zu erhalten."@de ;
    rdfs:subClassOf ec:Format .

ec:NormalPlayTime a owl:Class ;
    rdfs:label "Normale Spielzeit"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:isoDuration ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:time ;
            owl:onProperty ec:timeOfDay ],
        ec:TimelinePoint .

ec:OpenCaptions a owl:Class ;
    rdfs:label "Bildunterschriften öffnen"@de ;
    dcterms:description "Offene Untertitel werden in das Bild eingebrannt Bild eingebrannt."@de ;
    rdfs:subClassOf ec:Captioning .

ec:OpenSigning a owl:Class ;
    rdfs:label "Offene Gebärdensprache"@de ;
    dcterms:description "Offene Gebärdensprache ist in das Bild eingebrannt."@de ;
    rdfs:subClassOf ec:Signing .

ec:OpenSubtitling a owl:Class ;
    rdfs:label "Untertitelung öffnen"@de ;
    dcterms:description "Offene Untertitel werden in das Bild gebrannt Bild eingebrannt."@de ;
    rdfs:subClassOf ec:Subtitling .

ec:OriginalLanguage a owl:Class ;
    rdfs:label "Sprache"@de ;
    dcterms:description "Die Originalsprache, in der das Redaktionsobjekt oder Resource erstellt und freigegeben wurde. Dies wird als freier Text angegeben in einer Beschriftung oder als Bezeichner, der auf einen Begriff in einem Klassifikationsschema verweist Schema verweist."@de ;
    rdfs:subClassOf ec:Language .

ec:PartType a owl:Class ;
    rdfs:label "Teil Typ"@de ;
    dcterms:description "Um einen Typ oder ein Teil zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:Pictogram a owl:Class ;
    rdfs:label "Piktogramm"@de ;
    dcterms:description "Eine visuelle / grafische Darstellung eines Konzepts."@de ;
    rdfs:subClassOf ec:Picture .

ec:PictureDisplayFormat a owl:Class ;
    rdfs:label "Code für das Bildanzeigeformat"@de ;
    dcterms:description "So definieren Sie einen Code für das Bildanzeigeformat."@de ;
    rdfs:subClassOf ec:Format .

ec:Props a owl:Class ;
    rdfs:label "Requisiten"@de ;
    dcterms:description "Requisiten, die in Produktionen verwendet werden, zu identifizieren und zu beschreiben (z.B. Fahrzeuge, Objekte verschiedener Formen und Marken und deren Zweck usw.)."@de ;
    rdfs:subClassOf ec:Artefact ;
    skos:definition "ein Artefakt, das absichtlich ausgewählt wurde, um in einem Video zu erscheinen"@de ;
    skos:example """- ein Auto in einem Film
- Möbel in einem Film
- ein Buzzer in einer Quizshow"""@de .

ec:Provenance a owl:Class ;
    rdfs:label "Herkunft"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty ec:hasProvenanceTarget ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isAttributedTo ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:DateTimeDescription ;
            owl:onProperty ec:hasDateCreated ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:DateTimeDescription ;
            owl:onProperty ec:hasDateModified ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "une Reihe von Eigenschaften, welche die Herkunft und den Lebenszyklus eines Datenobjektes beschreiben"@de ;
    skos:example """- das Erzeugungsdatum eines Datenobjektes
- das System, aus welchem das Datenobjekt ursprünglich stammt"""@de .

ec:Pseudonym a owl:Class ;
    rdfs:label "Pseudonym"@de ;
    dcterms:description "ein fiktiver Name; insbesondere: Pseudonym oder Künstlername"@de ;
    rdfs:subClassOf ec:Person .

ec:PublicationChannelType a owl:Class ;
    rdfs:label "Publikationskanal-Typ"@de ;
    dcterms:description "Um eine Art von Publikationskanal zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:PublicationEventType a owl:Class ;
    rdfs:label "Art der Veröffentlichung"@de ;
    dcterms:description "Um eine Art von Publikationsereignis zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:PublicationLog a owl:Class ;
    rdfs:label "Playout-Protokoll"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasResourceOffset ;
            owl:someValuesFrom ec:TimelinePoint ],
        [ a owl:Restriction ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass ec:PublicationEvent ;
            owl:onProperty ec:logs ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ] ;
    skos:definition "eine Sammlung aufeinanderfolgender PublicationEvents eines (in der Regel linearen) Ausspielsystems"@de ;
    skos:example """- das "as run log" eines linearen TV-Wiedergabesystems für einen ganzen Tag
- das "As-Run-Log" eines linearen Radio-Playout-Systems für den Vormittag"""@de .

ec:PublicationPlanType a owl:Class ;
    rdfs:label "Publikationsplan Typ"@de ;
    dcterms:description "Um eine Art von Veröffentlichungsplan zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:Relation a owl:Class ;
    rdfs:label "Beziehung"@de ;
    dcterms:description "Zur Definition von Verbindungen und Beziehungen."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:hasRelationLink ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasRelationSource ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:relationOrderedGroupFlag ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:relationRunningOrderNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:relationTotalNumberOfGroupMembers ] .

ec:RelationType a owl:Class ;
    rdfs:label "Beziehungstyp"@de ;
    dcterms:description "Zur Angabe einer Art von Beziehung."@de ;
    rdfs:subClassOf skos:Concept .

ec:Reminder a owl:Class ;
    rdfs:label "Erinnerung"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Promotion ;
            owl:onProperty ec:hasPromotion ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CampaignPackage ;
            owl:onProperty ec:isMemberOf ],
        ec:EditorialWork ;
    skos:definition "ein Werk, das auf eine zuvor veröffentlichte Anzeige, Werbung oder ähnliches verweist, um daran zu erinnern"@de ;
    skos:example "- eine 4-sekündige Wiederholung des Logos und des Jingles einer Versicherungsgesellschaft, Minuten nach einer 15-sekündigen Werbung"@de .

ec:ResourceType a owl:Class ;
    rdfs:label "Resourcentyp"@de ;
    dcterms:description "Um eine Art von Resource zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:RightsType a owl:Class ;
    rdfs:label "Art der Rechte"@de ;
    dcterms:description "Um eine Art von Rechten zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:SOMEPROGRAMME a ec:EditorialObject,
        owl:NamedIndividual ;
    ec:aspectRatio "16:9" .

ec:ServiceType a owl:Class ;
    rdfs:label "Art der Dienstleistung"@de ;
    dcterms:description "Um eine Art von Dienst zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:SignLanguageCode a owl:Class ;
    rdfs:label "Code für Zeichensprache"@de ;
    dcterms:description "Eine Zeichensprache anhand ihres Codes zu identifizieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:Team a owl:Class ;
    rdfs:label "Team"@de ;
    dcterms:description "So definieren Sie ein Team."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Person ;
            owl:onProperty ec:hasTeamMember ],
        ec:Organisation .

ec:Template a owl:Class ;
    rdfs:label "Vorlage"@de ;
    dcterms:description "Eine Essenz, die als Vorlage mit allen zugehörigen technischen Parametern definiert ist."@de ;
    rdfs:subClassOf ec:Essence .

ec:TerritoryCode a owl:Class ;
    rdfs:label "Territorialer Code"@de ;
    dcterms:description "Um ein Gebiet z.B. durch seinen UN-Code zu identifizieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:TextAnnotation a owl:Class ;
    rdfs:label "Text-Anmerkung"@de ;
    dcterms:description "Eine Klasse, die speziell für die Beschriftung eines Textes oder von Teilen eines Textes gedacht ist."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:characterEndIndex ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:characterStartIndex ],
        ec:Annotation .

ec:TextLineType a owl:Class ;
    rdfs:label "Typ der Textzeile"@de ;
    dcterms:description "Um einen TextLine-Typ zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:TextUsageType a owl:Class ;
    rdfs:label "Art der Textverwendung"@de ;
    dcterms:description "Um die Verwendung eines Textes anzugeben."@de ;
    rdfs:subClassOf skos:Concept .

ec:Thumbnail a owl:Class ;
    rdfs:label "Vorschaubild"@de ;
    dcterms:description "Eine Miniaturansicht ist ein Bild mit geringer Auflösung, das mit EditorialObjects oder z.B. MediaResources oder Contacts verknüpft werden kann. Kontakte."@de ;
    rdfs:subClassOf ec:Picture .

ec:TimeCode a owl:Class ;
    rdfs:label "Zeitcode"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:timecodeExpression ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        ec:TimelinePoint .

ec:TimeCodeDropFrame a owl:Class ;
    rdfs:label "Zeitcode mit Dropframe"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:timecodeExpression ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        ec:TimelinePoint .

ec:TimedTextAuthoringTechnique a owl:Class ;
    rdfs:label "Technik zum Verfassen von Texten mit Zeitvorgaben"@de ;
    dcterms:description "So definieren Sie eine Technik zum Verfassen von Texten mit Zeitvorgaben."@de ;
    rdfs:subClassOf ec:Format .

ec:TimedTextContentType a owl:Class ;
    rdfs:label "Inhaltstyp Zeitgesteuerter Text"@de ;
    dcterms:description "Um eine Art von zeitlich begrenztem Text zu definieren."@de ;
    rdfs:subClassOf ec:Format .

ec:TimedTextSubtitleTargetFormat a owl:Class ;
    rdfs:label "Zeitgesteuertes Text-Zielformat für Untertitel"@de ;
    dcterms:description "So definieren Sie ein zeitgesteuertes Textuntertitelformat."@de ;
    rdfs:subClassOf ec:Format .

ec:TimelineTrackType a owl:Class ;
    rdfs:label "Typ der Timeline-Spur"@de ;
    dcterms:description "Um einen Typ oder eine TimelineSpur anzugeben."@de ;
    rdfs:subClassOf skos:Concept .

ec:UncertainDate a owl:Class ;
    rdfs:label "Ungewisses Datum"@de ;
    dcterms:description "Das Datum, ausgedrückt als Intervall zwischen Start und Ende, für unsichere Daten. Zusätzliche Informationen können in der Eigenschaft Beschreibung angegeben werden"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:period ],
        time:Instant ;
    owl:disjointWith time:DateTimeDescription .

ec:VideoFormat a owl:Class ;
    rdfs:label "Videoformat"@de ;
    dcterms:description "Spezifiziert das Videoformat der MedienResource."@de ;
    rdfs:subClassOf ec:Format .

ec:VideoStream a owl:Class ;
    rdfs:label "Video-Stream"@de ;
    dcterms:description "Ein dekodierbarer Videostrom aus Bits."@de ;
    rdfs:subClassOf ec:Stream .

ec:abridgedTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:animates a owl:ObjectProperty ;
    rdfs:label "animiert"@de ;
    dcterms:description "Gibt an, dass eine Person eine Figur mithilfe eines Artefakts animiert, etwa einer Puppe oder einem Animationsgerät."@de ;
    owl:inverseOf ec:isAnimatedBy .

ec:commissions a owl:ObjectProperty ;
    owl:inverseOf ec:hasCommissioningContract .

ec:day a owl:DatatypeProperty ;
    rdfs:label "Tag"@de ;
    rdfs:range xsd:integer .

ec:defines a owl:ObjectProperty ;
    owl:inverseOf ec:isDefinedBy .

ec:formatId a owl:DatatypeProperty ;
    rdfs:label "Format Id"@de ;
    dcterms:description "Eine Id, die einem Format zugeordnet ist."@de ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( xsd:anyURI xsd:string ) ] .

ec:grantsApproval a owl:ObjectProperty ;
    owl:inverseOf ec:hasApprover .

ec:hasAssociatedRelation a owl:ObjectProperty ;
    rdfs:label "Beziehung"@de ;
    dcterms:description "Um eine Relation zu definieren."@de .

ec:hasClip a owl:ObjectProperty ;
    rdfs:label "hat Clip"@de .

ec:hasJob a owl:ObjectProperty ;
    owl:inverseOf ec:isOrderedBy .

ec:hasMemberAudience a owl:ObjectProperty ;
    rdfs:label "Mitglied Publikum"@de ;
    dcterms:description "So identifizieren Sie ein Mitglied der (in der) aktuellen an Zuschauergruppe."@de .

ec:hasParentEditorialSegment a owl:ObjectProperty ;
    rdfs:label "hat ein übergeordnetes redaktionelles Segment"@de .

ec:hasProvenance a owl:ObjectProperty ;
    rdfs:label "Provenienz"@de ;
    dcterms:description "Bereich: String, anyURI oder Konzept."@de,
        "Die Person oder Firma, die die Metadaten zur Verfügung stellt."@de ;
    owl:inverseOf ec:hasProvenanceTarget .

ec:hasRelatedResonanceEvent a owl:ObjectProperty ;
    rdfs:label "Ähnliches Resonanzereignis"@de ;
    dcterms:description "So verknüpfen Sie ein ResonanceEvent mit einem EditorialObject."@de .

ec:isReferencedBy a owl:ObjectProperty ;
    rdfs:label "Referenzquelle"@de ;
    dcterms:description "Eine verwandte Ressource, die auf die beschriebene Ressource verweist, sie zitiert oder anderweitig darauf verweist."@de ;
    owl:inverseOf ec:references .

ec:month a owl:DatatypeProperty ;
    rdfs:label "Monat"@de ;
    rdfs:range xsd:integer .

ec:originalTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:serialTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:seriesTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:subtitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:translationTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:version a owl:DatatypeProperty ;
    rdfs:label "Version"@de ;
    dcterms:description "Um Informationen über die aktuelle Version eines EditorialObjects bereitzustellen."@de ;
    rdfs:range rdfs:Literal .

ec:versionTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:workingTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

rdfs:example a owl:AnnotationProperty .

rdfs:related a owl:ObjectProperty .

owl:maxQualifiedCardinality a owl:AnnotationProperty .

vs:term_status a owl:AnnotationProperty .

time:TRS a owl:Class ;
    rdfs:label "Zeitliches Bezugssystem"@de ;
    dcterms:description "Ein zeitliches Referenzsystem, wie z.B. ein zeitliches Koordinatenreferenzsystem (mit Ursprung, Richtung und Maßstab), eine Kalender-Uhr-Kombination oder ein (möglicherweise hierarchisches) Ordinalsystem."@de .

<http://www.w3.org/ns/ma-ont#hasPermissions> a owl:ObjectProperty ;
    rdfs:label "Berechtigungen"@de ;
    dcterms:description "Zur Definition von Berechtigungen, wie sie in der W3C-Medien-Ontologie (ma-ont) definiert sind"@de ;
    skos:prefLabel "Permissions"^^xsd:string .

xkos:after a owl:ObjectProperty ;
    rdfs:label "nach"@de ;
    rdfs:subPropertyOf xkos:temporal .

xkos:before a owl:ObjectProperty ;
    rdfs:label "vor"@de ;
    rdfs:subPropertyOf xkos:temporal .

xkos:next a owl:ObjectProperty ;
    rdfs:label "nächste"@de ;
    rdfs:subPropertyOf xkos:succeeds .

xkos:previous a owl:ObjectProperty ;
    rdfs:label "vorherige"@de ;
    rdfs:subPropertyOf xkos:precedes .

dc:Agent a owl:Class ;
    rdfs:label "Agent"@de ;
    dcterms:description "Eine Resource, die handelt oder die die Macht hat zu handeln."@de .

dc:date a owl:AnnotationProperty ;
    rdfs:label "Datum"@de ;
    dcterms:description "Ein Datum, das mit einer Resource verbunden ist."@de ;
    rdfs:range xsd:date .

dc:source a owl:DatatypeProperty ;
    rdfs:label "Quelle"@de ;
    dcterms:description "Um eine Resource als Quelle einer anderen Resource zu identifizieren."@de ;
    rdfs:range rdfs:Literal .

ec:ActiveFormatDescriptorCode a owl:Class ;
    rdfs:label "Aktiver Format-Deskriptor-Code"@de ;
    dcterms:description "So definieren Sie einen aktiven Formatcode."@de ;
    rdfs:subClassOf ec:Format .

ec:Affiliation a owl:Class ;
    rdfs:label "Zugehörigkeit"@de ;
    dcterms:description "Eine Organisation, der ein Kontakt angehört (mit Gültigkeitsdauer)."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:onClass ec:Organisation ;
            owl:onProperty ec:isAffiliatedTo ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "eine Verbindung einer Person mit einer Organisation für einen bestimmten Zeitraum"@de ;
    skos:example """- die Beschäftigung einer Person bei der BBC von der Einstellung bis zum Eintritt in den Ruhestand
- die Moderation einer wöchentlichen BBC-Radiosendung auf einem Radiokanal über 8 Jahre"""@de .

ec:AncillaryData a owl:Class ;
    rdfs:label "Ergänzende Daten"@de ;
    dcterms:description "Alle mit dem Inhalt gelieferten Zusatzdaten mit Ausnahme von Untertiteln und Untertitelung."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:WrappingType ;
            owl:onProperty ec:hasWrappingType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:DID ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:SDID ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:lineNumber ],
        ec:DataTrack .

ec:AncillaryDataFormat a owl:Class ;
    rdfs:label "Format der Zusatzdaten"@de ;
    dcterms:description "Zur Definition des Formats von Zusatzdaten wie z.B. Legacy-Daten, die in vertikalen Austastlücken übertragen werden. Diese werden als freier Text in einer Beschriftung oder als Bezeichner, der auf einen Begriff in einem Klassifikationsschema verweist Schema."@de ;
    rdfs:subClassOf ec:DataFormat .

ec:AnimalBreedCode a owl:Class ;
    rdfs:label "Code der Tierrasse"@de ;
    dcterms:description "Zur Bereitstellung eines Rassencodes für ein Tier."@de ;
    rdfs:subClassOf skos:Concept .

ec:AnimalColourCode a owl:Class ;
    rdfs:label "Farbcode für Tiere"@de ;
    dcterms:description "Zur Bereitstellung eines Farbcodes für ein Tier."@de ;
    rdfs:subClassOf skos:Concept .

ec:Annotation a owl:Class ;
    rdfs:label "Anmerkung"@de ;
    dcterms:description "Eine Klasse, mit der Sie Assets mit Anmerkungen versehen können."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasRelatedEvent ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasAnnotationCurationDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasAuthor ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasLocation ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:MediaResource ;
            owl:onProperty ec:isAnnotatedMediaResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:annotationConfidence ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:annotationPurpose ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:annotationSaliency ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasAnnotationAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty ec:hasAnnotationTarget ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ] .

ec:Article a owl:Class ;
    rdfs:label "Artikel"@de ;
    rdfs:subClassOf ec:EditorialWork ;
    skos:definition "ein redaktionelles Werk, das aus Text, Grafik, manchmal auch Video oder Audio besteht und für die Veröffentlichung auf Websites, Blogs und anderen Kanälen erstellt wird, die den traditionelleren papierbasierten Publikationen ähneln"@de ;
    skos:example "- ein Nachrichtenartikel auf der Website der BBC"@de .

ec:AssetValue a owl:Class ;
    rdfs:label "Assetwert"@de ;
    dcterms:description "Beschreibt den Wert eines Assets."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasAssetValueCurrency ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty ec:assetValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:AudioCodec a owl:Class ;
    rdfs:label "Audio-Codec"@de ;
    dcterms:description "Zur Bereitstellung von Informationen über einen Audiocodec."@de ;
    rdfs:subClassOf ec:Codec .

ec:AudioContent a owl:Class ;
    rdfs:label "Audio-inhalt"@de ;
    dcterms:description "Ein audioContent definiert eine Komponente eines Programms (z.B. Hintergrundmusik Musik), seine Zuordnung zu einer audioGroup (z.B. ein 2.0 audioPackFormat von audioChannelFormats für die Stereowiedergabe), seine Zuordnung zu einem audioStreamFormat und seine Lautheitsparameter."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessIntegratedLoudness ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxMomentary ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxShortTerm ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxTruepeak ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessRange ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:loudnessMethod ],
        ec:EditorialSegment .

ec:AudioDescription a owl:Class ;
    rdfs:label "Audio-Beschreibung"@de ;
    dcterms:description "Ein Track mit Audiobeschreibung."@de ;
    rdfs:subClassOf ec:AudioTrack .

ec:AudioEncodingFormat a owl:Class ;
    rdfs:label "Format der Audiokodierung"@de ;
    dcterms:description "Das Kodierungsformat für das Audio."@de ;
    rdfs:subClassOf ec:EncodingFormat .

ec:AudioObject a owl:Class ;
    rdfs:label "Audio-Objekt"@de ;
    dcterms:description "So definieren Sie ein Audioobjekt mit Bezug auf das Audio Definition Model (ADM)"@de ;
    rdfs:subClassOf ec:MediaResource ;
    skos:definition "eine MedienResource in Form eines Objektes wie es im Audio Definition Model (ADM) beschrieben ist"@de .

ec:AudioProgramme a owl:Class ;
    rdfs:label "Audio Programm"@de ;
    rdfs:isDefinedBy <https://tech.ebu.ch/docs/r/r128.pdf> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessIntegratedLoudness ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxMomentary ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxShortTerm ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxTruepeak ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessRange ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:loudnessMethod ],
        ec:EditorialWork ;
    skos:definition "Ein einzelner, in sich geschlossener audiovisueller oder reiner Audiobeitrag, der im Radio, Fernsehen oder anderen elektronischen Medien präsentiert wird. Auch Werbung (Werbespot), Trailer, Werbebeiträge („Promo“), Interstitials oder ähnliche Beiträge („Kurzformat-Inhalte“) gelten in diesem Zusammenhang als \"AudioProgramme\"."@de .

ec:AuditJob a owl:Class ;
    rdfs:label "Prüfaufgabe"@de ;
    dcterms:description "Eine Prüfaufgabe untersucht die Einhaltung einer Regel durch eine Messung."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:AuditReport ;
            owl:onProperty ec:hasAuditJobRelatedAuditReport ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Measure ;
            owl:onProperty ec:usesMeasure ],
        ec:ProductionJob ;
    skos:definition "Bewertung der Einhaltung einer Maßnahme"@de ;
    skos:example """- Messung des maximalen Lautstärkepegels in der Tonspur einer Videodatei
- Messung des Anteils der Redezeit in einer Debatte der Kandidaten vor einer Wahl
- Messung des Anteils der männlichen/weiblichen Experten in allen Programmen eines Publikationsdienstes"""@de .

ec:Biography a owl:Class ;
    rdfs:label "Biographie"@de ;
    dcterms:description "Um eine Biographie aufzunehmen."@de ;
    rdfs:subClassOf ec:BibliographicalObject .

ec:CaptioningFormat a owl:Class ;
    rdfs:label "Format der Untertitel"@de ;
    dcterms:description "Zur Definition des Formats der Untertitelung. Untertitel werden hauptsächlich für die Übertragung für Hörgeschädigte verwendet. Diese wird als freier Text in einer Beschriftung oder als Kennung, die auf einen Begriff in einem Klassifikationsschema."@de ;
    rdfs:subClassOf ec:DataFormat .

ec:CastMember a owl:Class ;
    rdfs:label "Mitglied der Besetzung"@de ;
    dcterms:description "Ein Mitglied der Besetzungsliste (eine Liste von Darstellern/Schauspielern und zugehörigen fiktiven Charaktere)."@de ;
    rdfs:subClassOf ec:Person .

ec:ColourSpace a owl:Class ;
    rdfs:label "Farbraum"@de ;
    dcterms:description "Der Farbraum einer VideoResource. A ColourSpace wird als freier Text in einer Beschriftung oder als Bezeichner definiert, der auf einen Begriff in einem auf einen Begriff in einem Klassifizierungsschema wie http://www.ebu.ch/metadata/ontologies/skos/ebu_ColourCodeCS.rdf."@de ;
    rdfs:subClassOf ec:Format .

ec:Component a owl:Class ;
    rdfs:label "Komponente"@de ;
    dcterms:description "Eine Komponente, z.B. Audio, Video, Daten oder sonstiges oder eine MediaResource oder Essence."@de ;
    rdfs:subClassOf ec:MediaResource .

ec:ConsumptionCount a owl:Class ;
    rdfs:label "Nutzungszahl/-anteil"@de ;
    dcterms:description "Eine Ansammlung von Gruppen von gezählten Verbrauchern"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionEvent ;
            owl:onProperty ec:hasConsumptionEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:audienceCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "die tatsächliche Anzahl und die Umstände von ConsumptionEvents für ein einzelnes PublicationEvent"@de ;
    skos:example """- einen Marktanteil von 46 % bei den französischen Zuschauern für das Endspiel der Fußballweltmeisterschaft 2022
- 72 % Marktanteil bei den französischen Zuschauern zwischen 14 und 29 Jahren für das Endspiel der Fußballweltmeisterschaft 2022
- 18,7 Millionen Live-Stream-Zugriffe auf die Beerdigung des ehemaligen Papstes Benedikt in Europa
- 36973 Aufrufe des youtube-Videos "Tom Hanks had an ICONIC chat with the Queen" von BBC's "The One Show" 6 Monate aber Veröffentlichung
- 2080 Besucher in der Stuttgarter Liederhalle bei einem Live-Konzert des SWR-Sinfonieorchesters am 8. April 2022"""@de .

ec:ContainerCodec a owl:Class ;
    rdfs:label "Container-Codec"@de ;
    dcterms:description "Zur Identifizierung eines Container-Codecs, z.B. MXF"@de ;
    rdfs:subClassOf ec:Codec .

ec:ContainerEncodingFormat a owl:Class ;
    rdfs:label "Container-Kodierungsformat"@de ;
    dcterms:description "Zur Definition des Container-Kodierungsformats."@de ;
    rdfs:subClassOf ec:EncodingFormat .

ec:ContentEditorialFormat a owl:Class ;
    rdfs:label "Redaktionelles Format"@de ;
    dcterms:description "Um ein EditorialFormat zu definieren"@de ;
    rdfs:subClassOf ec:Type .

ec:ContractCost a owl:Class ;
    rdfs:label "Vertragskosten"@de ;
    dcterms:description "Beschreibt die Kosten eines Vertrages."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasContractCostAmountCurrency ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty ec:contractCostAmount ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Copyright a owl:Class ;
    rdfs:label "Copyright"@de ;
    dcterms:description "Um eine Urheberrechtserklärung abzugeben Erklärung."@de ;
    rdfs:subClassOf ec:Rights .

ec:CreativeCommons a owl:Class ;
    rdfs:label "Kreative Gemeingüter"@de ;
    dcterms:description "Eine Reihe von Creative-Commons-Rechten."@de ;
    rdfs:subClassOf ec:Rights .

ec:CrewMember a owl:Class ;
    rdfs:label "Stab"@de ;
    dcterms:description "Zur Identifikation eines Stabsmitglieds"@de ;
    rdfs:subClassOf ec:Person .

ec:CuisineStyle a owl:Class ;
    rdfs:label "Stil der Küche"@de ;
    dcterms:description "Um einen Küchenstil zu identifizieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:CurrencyCode a owl:Class ;
    rdfs:label "Währungscode"@de ;
    dcterms:description "So identifizieren Sie eine Währung anhand ihres ISO-Codes."@de ;
    rdfs:subClassOf skos:Concept .

ec:DID a owl:DatatypeProperty ;
    rdfs:label "DID"@de ;
    dcterms:description "Das Data Identifier Wort (zusammen mit der SDID, falls verwendet), gibt die Art der Zusatzdaten an, denen das Paket entspricht entspricht."@de ;
    rdfs:range xsd:integer .

ec:Department a owl:Class ;
    rdfs:label "Abteilung"@de ;
    dcterms:description "Eine Abteilung innerhalb einer Organisation."@de ;
    rdfs:subClassOf ec:Organisation .

ec:Disclaimer a owl:Class ;
    rdfs:label "Haftungsausschluss"@de ;
    dcterms:description "Einen Haftungsausschluss jeglicher Art bereitzustellen Form."@de ;
    rdfs:subClassOf ec:Rights .

ec:Document a owl:Class ;
    rdfs:label "Dokument"@de ;
    dcterms:description "Zur Beschreibung einer Veröffentlichung in Form eines Dokumentes, z.B. einer html-Webseite (Nachricht) oder eines pdf-Dokuments, z.B. eines Skripts."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:DocumentFormat ;
            owl:onProperty ec:hasDocumentFormat ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EncodingFormat ;
            owl:onProperty ec:hasEncodingFormat ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:wordCount ],
        ec:Resource ;
    skos:definition "eine Resource in Form von kodiertem Text und/oder Grafiken"@de ;
    skos:example """- eine Textdatei
- ein Papierbuch
- eine Webseite oder ein wiederverwendbarer Block davon"""@de .

ec:DocumentFormat a owl:Class ;
    rdfs:label "Format des Dokuments"@de ;
    dcterms:description "Zur Bereitstellung technischer Informationen über das Format eines Dokuments, z. B. die Ausrichtung. Diese Informationen werden als freier Text in einer Beschriftung oder als Bezeichner, der auf einen Begriff in einem Klassifizierungsschema verweist Schema."@de ;
    rdfs:subClassOf ec:Format .

ec:Dopesheet a owl:Class ;
    rdfs:label "Dopesheet"@de ;
    dcterms:description "Bietet zusätzliche Informationen zu einem NewsItem, z.B. Datum und Ort, Thema."@de ;
    rdfs:subClassOf ec:Document .

ec:EditorialFormat a owl:Class ;
    rdfs:label "Format"@de ;
    rdfs:subClassOf ec:EditorialGroup ;
    skos:definition "Eine EditorialGroup, die mit einem spezifischen redaktionellen Stil, Inhaltslayout, Moderator usw. entwickelt wurde, um eine Zielgruppe anzusprechen. Wird meist bei der Klassifizierung bestehender Angebote oder der Entwicklung neuer Angebote verwendet."@de ;
    skos:example """- eine Spiel-Show mit einem bestimmten Gastgeber: "Rudis Raterunde"
- eine Journalsendung zu Themen aus Asien: "Asienreport"
- eine abendliche Hauptnachrichtensendung: "Tagesschau Hauptausgabe um 20:00"
- eine im Internet gestreamte Diskussionsendung für Jugendliche mit live zugeschalteten Gästen aus dem Publikum und Kommentarfunktion: "MixTalk\""""@de .

ec:ExploitationIssues a owl:Class ;
    rdfs:label "Fragen der Ausbeutung"@de ;
    dcterms:description "Potenzielle Ausbeutung hervorheben Probleme."@de ;
    rdfs:subClassOf ec:Rights .

ec:FileFormat a owl:Class ;
    rdfs:label "Dateiformat"@de ;
    dcterms:description "Ein Dateiformat für andere Resourcen als audiovisuelle Resourcen. Das Format ist als freier Text oder als Verweis auf einen Begriff in einem Klassifikationsschema, z.B. http://www.ebu.ch/metadata/ontologies/skos/ebu_FileFormatCS.rdf."@de ;
    rdfs:subClassOf ec:Format .

ec:FoodStyle a owl:Class ;
    rdfs:label "Essen Stil"@de ;
    dcterms:description "Um einen Essensstil zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:IPRRestrictions a owl:Class ;
    rdfs:label "IPR-Beschränkungen"@de ;
    dcterms:description "Bereitstellung von Informationen über geistiges Eigentum."@de ;
    rdfs:subClassOf ec:Rights .

ec:Item a owl:Class ;
    rdfs:label "Beitrag"@de ;
    dcterms:description "Ein Element, z.B. newsItem oder sportItem"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Article ;
            owl:onProperty ec:hasArticle ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Dopesheet ;
            owl:onProperty ec:hasDopesheet ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Post ;
            owl:onProperty ec:hasPost ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Programme ;
            owl:onProperty ec:hasProgramme ],
        ec:EditorialWork ;
    skos:definition "ein Werk, das in ein Programm, einen Artikel oder einen Beitrag integriert werden soll"@de ;
    skos:example """- eine Nachricht, die in eine Nachrichtensendung integriert werden soll
- ein Umfrage-Clip, der in eine Debatte integriert werden soll"""@de .

ec:KeyCareerEvent a owl:Class ;
    rdfs:label "Wichtiges Karriere-Ereignis"@de ;
    dcterms:description "Ein wichtiges Karriereereignis einer Kontaktperson beschreiben."@de ;
    rdfs:subClassOf ec:KeyEvent .

ec:KeyPersonalEvent a owl:Class ;
    rdfs:label "Persönliches Schlüsselereignis"@de ;
    dcterms:description "Ein wichtiges persönliches Ereignis eines Kontakts."@de ;
    rdfs:subClassOf ec:KeyEvent .

ec:Keyword a owl:Class ;
    rdfs:label "Schlüsselwort"@de ;
    dcterms:description "Um Schlüsselwörter und Schlüsselkonzepte zu definieren die den Inhalt der Resource oder des redaktionellen Objekts illustrieren. Dies wird als freier Text in einer Beschriftung oder als Bezeichner, der auf einen Begriff in einem Klassifikationsschema verweist Schema verweist."@de ;
    rdfs:subClassOf skos:Concept .

ec:Licensing a owl:Class ;
    rdfs:label "Lizenzierung"@de ;
    dcterms:description "Zur Definition der mit einem Asset verbundenen Lizenzbedingungen."@de ;
    rdfs:subClassOf ec:Rights .

ec:LocationCode a owl:Class ;
    rdfs:label "Standort-Code."@de ;
    dcterms:description "Ein Code, der einem Ort zugeordnet ist."@de ;
    rdfs:subClassOf skos:Concept .

ec:Measure a owl:Class ;
    rdfs:label "Messung"@de ;
    dcterms:description "Eine Messung zu einer Regel untersucht deren Einhaltung durch Prüfaufgaben."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasUnit ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rule ;
            owl:onProperty ec:measures ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:measureValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:measureValueMax ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:measureValueMin ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "Bestimmung einer Zahl und einer Einheit zur Beantwortung einer bestimmten Frage durch Zählen, Vergleichen, Aggregieren oder Berechnen"@de ;
    skos:example """- Bestimmung des Lautstärkepegels einer Tonspur
- Zählen der Minuten, die ein Redner während einer Debatte hat
- Zählen der Anzahl der weiblichen Experten in allen Sendungen von BBC One"""@de .

ec:Medium a owl:Class ;
    rdfs:label "Medium"@de ;
    dcterms:description "Informationen zu den Medienformaten bereitstellen, in denen die in denen die Resource verfügbar ist. Dies wird als freier Text in einer Beschriftung angegeben oder als Kennung, die auf einen Begriff in einem Klassifikationsschema verweist."@de ;
    rdfs:subClassOf ec:Format .

ec:MetadataTrack a owl:Class ;
    rdfs:label "Metadaten Spur"@de ;
    dcterms:description "Eine Spur, in die Metadaten eingebettet sind (z. B. MXF)."@de ;
    rdfs:subClassOf ec:Track .

ec:PhysicalResource a owl:Class ;
    rdfs:label "Physische Resource"@de ;
    dcterms:description "Beschreibt eine physische Resource, z.B. ein Tonband."@de ;
    rdfs:subClassOf ec:Resource .

ec:Post a owl:Class ;
    rdfs:label "Post"@de ;
    rdfs:subClassOf ec:EditorialWork ;
    skos:definition "ein redaktionelles Werk, das aus Text, Grafik, manchmal auch Video oder Audio besteht und für die Veröffentlichung auf Plattformen sozialer Medien und ähnlichem erstellt wird"@de ;
    skos:example """- ein Tweet auf Twitter
- ein Beitrag auf Facebook
- ein Beitrag auf Instagram
- ein Video-Beitrag auf Youtube"""@de .

ec:ProductionOrder a owl:Class ;
    rdfs:label "Produktionsauftrag"@de ;
    dcterms:description "Die Beauftragung zur Erstellung, zum Kauf oder zur Wiederverwendung einer MedienResource. Die Bedingungen eines Produktionsauftrages sind in einem Vertrag definiert."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasProductionContract ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Promotion a owl:Class ;
    rdfs:label "Werbung"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:CampaignPackage ;
            owl:onProperty ec:isMemberOf ],
        ec:EditorialWork ;
    skos:definition "ein Werk für Werbezwecke"@de ;
    skos:example """- ein Werbespot für eine Versicherungsgesellschaft
- ein Werbeclip für ein PSM, einen seiner Kanäle, seine Marken"""@de .

ec:PublicationHistory a owl:Class ;
    rdfs:label "Veröffentlichungshistorie"@de ;
    dcterms:description "Eine Sammlung von Publikationsereignissen, durch die eine Resource veröffentlicht wurde."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasPublicationEvent ;
            owl:someValuesFrom ec:PublicationEvent ] .

ec:PublicationMedium a owl:Class ;
    rdfs:label "Medium der Veröffentlichung"@de ;
    rdfs:subClassOf skos:Concept .

ec:Record a owl:Class ;
    rdfs:label "Rekord"@de ;
    dcterms:description "Die Aufzeichnung der Beschreibung eines Assets."@de ;
    rdfs:subClassOf ec:BibliographicalObject .

ec:RegionCode a owl:Class ;
    rdfs:label "Regionalcode"@de ;
    dcterms:description "Region Code bezieht sich auf den von der Internationalen Organisation für Normung (ISO) entwickelten Code. Die ISO schuf und pflegt die Norm ISO 3166 - Codes für die Darstellung der Namen von Ländern und ihren Unterteilungen."@de ;
    rdfs:subClassOf skos:Concept .

ec:ResonanceCount a owl:Class ;
    rdfs:label "Resonanz"@de ;
    dcterms:description "Die Aggregation von Daten über die Nutzung von Produkten durch eine Gruppe von Nutzern. Repräsentiert alle zählbaren oder erfassbaren Nutzungsaktivitäten durch Nutzer während des Nutzungsereignisses, aber zu nicht-individualisierbaren Ausdrücken zusammengefasst, z.B. click-Zahlen, Anzahl von Likes, Prozentsatz von Stimmen, Anzahl der Downloads, ... Die Analyse der Resonanzdaten erlaubt eine genauere Verfeinerung einer Kampagnenstrategie und des verknüpften Publikationsplans."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:ResonanceEvent ;
            owl:onProperty ec:compilesResonanceEvents ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Locator ;
            owl:onProperty ec:hasLocator ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasMeasurementAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "die Aggregation von Resonanzereignissen zur Anzeige der Leistung eines Inhalts oder eines Dienstes"@de ;
    skos:example """- Marktanteil bei den Zuschauern einer Sport-Live-Übertragung
- Wöchentliche Seitenaufrufe einer Nachrichten-Website
- Anzahl der täglichen Unique User auf einer Nachrichten-Website
- Anzahl der Likes für einen Instagram-Post
- Anzahl der Aufrufe eines Films auf einem VOD-Portal"""@de .

ec:Review a owl:Class ;
    rdfs:label "Rezension"@de ;
    dcterms:description "Um eine Rezension zu erstellen."@de ;
    rdfs:subClassOf ec:Item .

ec:RightsClearance a owl:Class ;
    rdfs:label "Freigabe der Rechte"@de ;
    dcterms:description "Um zu signalisieren, dass die Rechte gelöscht wurden (oder nicht) nicht)"@de ;
    rdfs:subClassOf ec:Rights .

ec:SDID a owl:DatatypeProperty ;
    rdfs:label "SDID"@de ;
    dcterms:description "Sekundärdaten-Kennwort für Zusatzdaten. Kennung für den Sendemodus. Eine Kennung, die den Übertragungszeitpunkt für Untertiteldaten angibt."@de ;
    rdfs:range xsd:integer .

ec:SigningFormat a owl:Class ;
    rdfs:label "Gebärdensprachformat"@de ;
    dcterms:description "Beschreibt das Format der Gebärdensprachdolmetschung in audiovisuellen Inhalten (z. B. In-Vision/Einblendung, Vollbild, Overlay, Avatar)."@de ;
    rdfs:subClassOf skos:Concept .

ec:Stage a owl:Class ;
    rdfs:label "Bühne"@de ;
    dcterms:description "Eine Bühne."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Locator ;
            owl:onProperty ec:hasLocator ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasStageLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Standard a owl:Class ;
    rdfs:label "Standard"@de ;
    dcterms:description "identifiziert den technischen Videostandard einer Resource, d.h. NTSC oder PAL."@de ;
    rdfs:subClassOf ec:Format .

ec:Sticker a owl:Class ;
    rdfs:label "Aufkleber"@de ;
    dcterms:description "Ein Aufkleber, der mit einem Kostüm verbunden ist."@de ;
    rdfs:subClassOf ec:Picture .

ec:StorageType a owl:Class ;
    rdfs:label "Art der Lagerung"@de ;
    dcterms:description "Die Art der Speicherung, die für das Repository verwendet wird. Dies wird als freier Text in einer Beschriftung oder als Bezeichner angegeben, der auf einen Begriff in einem Klassifizierungsschema verweist."@de ;
    rdfs:subClassOf skos:Concept .

ec:Subject a owl:Class ;
    rdfs:label "Thema"@de ;
    dcterms:description "Ein Begriff, der das Thema beschreibt, das von dem EditorialObject oder der Resource. Er wird als freier Text in einer Beschriftung angegeben oder als ein Bezeichner, der auf einen Begriff in einem Klassifizierungsschema verweist."@de ;
    rdfs:subClassOf skos:Concept .

ec:SubtitlingFormat a owl:Class ;
    rdfs:label "Format der Untertitelung"@de ;
    dcterms:description "Um das Format der Untertitelung zu definieren. Die Untertitelung wird hauptsächlich für die Übersetzung verwendet. Diese wird als freier Text in einer Beschriftung oder als Kennung, die auf einen Begriff in einem Klassifizierungsschema verweist Schema verweist."@de ;
    rdfs:subClassOf ec:DataFormat .

ec:TextLine a owl:Class ;
    rdfs:label "Textzeile"@de ;
    dcterms:description "Zur Bereitstellung von Textzeilen, die aus der Resource extrahiert wurden oder diese ergänzen."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Character ;
            owl:onProperty ec:hasRelatedCharacter ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasRelatedScene ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasTextLineSource ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:artefactBoxHeight ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:artefactBoxTopLeftCornerLineNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:artefactBoxTopLeftCornerPixelNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:artefactBoxWidth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineBoxHeight ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineBoxTopLeftCornerLineNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineBoxTopLeftCornerPixelNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineBoxWidth ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineContent ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineOrder ] .

ec:Theme a owl:Class ;
    rdfs:label "Thema"@de ;
    dcterms:description "So definieren Sie ein Thema, das mit einem Asset verknüpft ist."@de ;
    rdfs:subClassOf skos:Concept .

ec:TimecodeTrack a owl:Class ;
    rdfs:label "Timecode-Spur"@de ;
    dcterms:description "Eine Spur mit Timecode-Informationen z.B. in MXF."@de ;
    rdfs:subClassOf ec:Track .

ec:Topic a owl:Class ;
    rdfs:label "Thema"@de ;
    dcterms:description "Ein Typ, der in einigen Kontexten verwendet werden kann. Diese wird als freier Text in einer Beschriftung oder als Identifikator angegeben, der auf einen Begriff in einem Klassifikationsschema verweist."@de ;
    rdfs:subClassOf skos:Concept .

ec:TrackPurpose a owl:Class ;
    rdfs:label "Zweck der Spur"@de ;
    dcterms:description "Um den Zweck eines Titels zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:TrackType a owl:Class ;
    rdfs:label "Spur Typ"@de ;
    dcterms:description "Um eine Art von Track zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:UsageRights a owl:Class ;
    rdfs:label "Nutzungsrechte"@de ;
    dcterms:description "Mit den Inhalten verbundene Nutzungsrechte."@de ;
    rdfs:subClassOf ec:Rights .

ec:VideoCodec a owl:Class ;
    rdfs:label "Video-Codec"@de ;
    dcterms:description "Zur Bereitstellung von Informationen über einen Videocodec."@de ;
    rdfs:subClassOf ec:Codec .

ec:VideoEncodingFormat a owl:Class ;
    rdfs:label "Format der Videokodierung"@de ;
    dcterms:description "Das Kodierungsformat des Videos."@de ;
    rdfs:subClassOf ec:EncodingFormat .

ec:VideoTrack a owl:Class ;
    rdfs:label "Videospur"@de ;
    dcterms:description "Eine Spezialisierung von Track für Video zur Bereitstellung einer Verknüpfung zu bestimmten Dateneigenschaften wie FrameRate usw. Gebärdensprache ist ein weiteres mögliches Beispiel für eine Videospur. Spezifische VideoTracks wie Signing können als Unterklassen definiert werden. In fortgeschrittenen Systemen können verschiedene VideoTracks verwendet werden, um z.B. unterschiedliche Blickwinkel zu bieten."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:videoTrackNumber ],
        ec:Track .

ec:WrappingType a owl:Class ;
    rdfs:label "Art der Umhüllung"@de ;
    dcterms:description "Um eine Art der Umhüllung zu definieren."@de ;
    rdfs:subClassOf skos:Concept .

ec:age a owl:DatatypeProperty ;
    rdfs:label "Alter"@de ;
    dcterms:description "Das Alter eines Kontakts/einer Person in Jahren."@de ;
    rdfs:range xsd:integer .

ec:agentDbpedia a owl:DatatypeProperty ;
    rdfs:label "DBPedia"@de ;
    dcterms:description "Ein Link zu einer DBPedia-Seite."@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentLinkedData .

ec:agentFacebook a owl:DatatypeProperty ;
    rdfs:label "Facebook"@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentFee a owl:DatatypeProperty ;
    rdfs:label "Agenturgebühr"@de ;
    dcterms:description "Das Honorar eines Agenten."@de ;
    rdfs:range rdfs:Literal .

ec:agentFlickr a owl:DatatypeProperty ;
    rdfs:label "Flickr"@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentImdb a owl:DatatypeProperty ;
    rdfs:label "IMDB"@de ;
    dcterms:description "Ein Link zu einer imdb-Seite."@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentLinkedData .

ec:agentInstagram a owl:DatatypeProperty ;
    rdfs:label "Instagram"@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentLinkedIn a owl:DatatypeProperty ;
    rdfs:label "LinkedIn"@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentMobileTelephoneNumber a owl:DatatypeProperty ;
    rdfs:label "Mobil"@de ;
    dcterms:description "Zur Angabe der Mobiltelefonnummer eines Agenten (Kontaktperson/Person oder Organisation)"@de ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ec:agentTelephoneNumber .

ec:agentPreviousName a owl:DatatypeProperty ;
    rdfs:label "Vorheriger Name"@de ;
    dcterms:description "Um den früheren Namen eines Kontakts/einer Person anzugeben."@de ;
    rdfs:range rdfs:Literal .

ec:agentRelatedInformationLink a owl:DatatypeProperty ;
    rdfs:label "Verwandte Informationen Link"@de ;
    dcterms:description "Bereitstellung eines Links zu einer WebResource mit Informationen zu einem Agenten (Kontakt/Person oder Organisation) enthält."@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentRelatedLink .

ec:agentRelatedPressLink a owl:DatatypeProperty ;
    rdfs:label "Link zur Presse"@de ;
    dcterms:description "Bereitstellung eines Links zu einer WebResource mit Informationen zu einem Agenten (Kontakt/Person oder Organisation) enthält."@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentRelatedLink .

ec:agentTwitter a owl:DatatypeProperty ;
    rdfs:label "Twitter"@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentWikidata a owl:DatatypeProperty ;
    rdfs:label "Wikidata"@de ;
    dcterms:description "Ein Link zu einer wikidata-Seite."@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentLinkedData .

ec:agentWikipedia a owl:DatatypeProperty ;
    rdfs:label "Wikipedia"@de ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:animalCharacterName a owl:DatatypeProperty ;
    rdfs:label "Name der Tierfigur"@de ;
    dcterms:description "Um einen fiktiven Charakternamen mit einem Tier zu verbinden."@de ;
    rdfs:range rdfs:Literal .

ec:animalCode a owl:DatatypeProperty ;
    rdfs:label "Tiercode"@de ;
    dcterms:description "Um einen Code mit einem Tier zu verbinden."@de ;
    rdfs:range rdfs:Literal .

ec:animalPassport a owl:DatatypeProperty ;
    rdfs:label "Tierpass"@de ;
    dcterms:description "Um den Pass eines Tieres zu replizieren."@de ;
    rdfs:range rdfs:Literal .

ec:annotationConfidence a owl:DatatypeProperty ;
    rdfs:label "Vertrauen in die Kommentierung"@de ;
    dcterms:description "So schätzen Sie das Vertrauen in eine Anmerkung ein."@de ;
    rdfs:range rdfs:Literal .

ec:annotationPurpose a owl:DatatypeProperty ;
    rdfs:label "Vertrauen in die Kommentierung"@de ;
    dcterms:description "Um den Zweck einer Anmerkung zu definieren."@de ;
    rdfs:range rdfs:Literal .

ec:annotationSaliency a owl:DatatypeProperty ;
    rdfs:label "Bedeutung von Kommentaren"@de ;
    dcterms:description "So schätzen Sie die Bedeutung einer Anmerkung ein."@de ;
    rdfs:range rdfs:Literal .

ec:applyTo a owl:ObjectProperty ;
    rdfs:label "Vermögenswert"@de ;
    dcterms:description "Das Asset, auf das sich die Rechte beziehen."@de .

ec:approvedBy a owl:ObjectProperty ;
    rdfs:label "Agent"@de ;
    dcterms:description "Zur Identifizierung des Agenten, der das EditorialObject zur Veröffentlichung freigegeben hat. Wenn diese Eigenschaft vorhanden ist, dient sie als Auslöser für die Veröffentlichung des Redaktionsobjekts."@de .

ec:artefactAvailability a owl:DatatypeProperty ;
    rdfs:label "Flagge für die Verfügbarkeit von Artefakten"@de ;
    dcterms:description "Zur Kennzeichnung der Verfügbarkeit eines Artefakts."@de ;
    rdfs:range xsd:boolean .

ec:artefactBoxHeight a owl:DatatypeProperty ;
    rdfs:label "Höhe der Artefaktbox."@de ;
    dcterms:description "Die Höhe der Box, die das Artefakt enthält."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:artefactBoxTopLeftCornerLineNumber a owl:DatatypeProperty ;
    rdfs:label "Artefaktbox obere linke Ecke Y-Position."@de ;
    dcterms:description "Die Koordinaten auf einer vertikalen Achse für die Position der linken oberen Ecke der Box, die das Artefakt enthält."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:artefactBoxTopLeftCornerPixelNumber a owl:DatatypeProperty ;
    rdfs:label "Artefaktbox obere linke Ecke X-Position."@de ;
    dcterms:description "Die Koordinaten auf einer horizontalen Achse für die Position der linken oberen Ecke der Box, die das Artefakt enthält."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:artefactBoxWidth a owl:DatatypeProperty ;
    rdfs:label "Breite des Artefaktkastens."@de ;
    dcterms:description "Die Breite des Feldes, das das Artefakt enthält."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:artefactBrand a owl:DatatypeProperty ;
    rdfs:label "Marke Artefact"@de ;
    dcterms:description "Zur Angabe der Marke eines Artefakts."@de ;
    rdfs:range rdfs:Literal .

ec:artefactColour a owl:DatatypeProperty ;
    rdfs:label "Farbe(n) des Artefakts"@de ;
    dcterms:description "Um den/die Geruch(e) eines Artefakts bereitzustellen."@de ;
    rdfs:range rdfs:Literal .

ec:artefactComment a owl:DatatypeProperty ;
    rdfs:label "Artefakt-Kommentar"@de ;
    dcterms:description "Um einen kontextbezogenen Kommentar zu einem Artefakt abzugeben."@de ;
    rdfs:range rdfs:Literal .

ec:artefactModel a owl:DatatypeProperty ;
    rdfs:label "Artefakt-Modell"@de ;
    dcterms:description "Um ein Modell eines Artefakts anzugeben."@de ;
    rdfs:range rdfs:Literal .

ec:artefactPeriod a owl:DatatypeProperty ;
    rdfs:label "Artefakt Zeitraum"@de ;
    dcterms:description "Zur Angabe des Zeitraums, der mit einem Artefakt verbunden ist."@de ;
    rdfs:range rdfs:Literal .

ec:artefactPriceAmount a owl:DatatypeProperty ;
    rdfs:label "Artefakt Preis"@de ;
    dcterms:description "Um den Preis eines Artefakts anzugeben."@de ;
    rdfs:range rdfs:Literal .

ec:artefactReference a owl:DatatypeProperty ;
    rdfs:label "Artefakt-Referenz"@de ;
    dcterms:description "Um eine Referenz eines Artefakts anzugeben."@de ;
    rdfs:range xsd:anyURI .

ec:artefactStyle a owl:DatatypeProperty ;
    rdfs:label "Artefakt-Stil"@de ;
    dcterms:description "Um den mit einem Artefakt verbundenen Stil festzulegen."@de ;
    rdfs:range rdfs:Literal .

ec:artefactUsageHistory a owl:DatatypeProperty ;
    rdfs:label "Geschichte der Artefaktnutzung"@de ;
    dcterms:description "Um Informationen über die Nutzungshistorie eines Artefakts bereitzustellen."@de ;
    rdfs:range rdfs:Literal .

ec:artefactWebsite a owl:DatatypeProperty ;
    rdfs:label "Artefact Website"@de ;
    dcterms:description "Zur Angabe einer Website, auf der Sie weitere Informationen über das Artefakt finden können."@de ;
    rdfs:range xsd:anyURI .

ec:assetValue a owl:DatatypeProperty ;
    rdfs:label "Vermögenswert"@de ;
    dcterms:description "Um einen geschätzten oder tatsächlichen Wert eines Assets anzugeben."@de .

ec:audienceAgeHigh a owl:DatatypeProperty ;
    rdfs:label "Alter des Publikums hoch"@de ;
    dcterms:description "Das maximale Alter eines Publikums."@de .

ec:audienceAgeLow a owl:DatatypeProperty ;
    rdfs:label "Alter des Publikums niedrig"@de ;
    dcterms:description "Das Mindestalter eines Zuschauers."@de .

ec:audienceInterest a owl:DatatypeProperty ;
    rdfs:label "Interesse des Publikums"@de ;
    dcterms:description "Die Punkte, die für ein Publikum von Interesse sind."@de .

ec:audioBitRate a owl:DatatypeProperty ;
    rdfs:label "Audio-Bitrate"@de ;
    dcterms:description "Die Audio-Bitrate."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:audioBitRateMax a owl:DatatypeProperty ;
    rdfs:label "Audio-Bitrate max."@de ;
    dcterms:description "Die maximale Audio-Bitrate."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:audioBitRateMode a owl:DatatypeProperty ;
    rdfs:label "Audio-Bitrate-Modus"@de ;
    dcterms:description "Der Modus für die Audio-Bitrate."@de ;
    rdfs:range rdfs:Literal .

ec:audioEncodingLevel a owl:DatatypeProperty ;
    rdfs:label "Pegel der Audiokodierung"@de ;
    dcterms:description "Die Kodierungsebene, wie sie in den Spezifikationen definiert ist."@de ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:encodingLevel .

ec:audioEncodingProfile a owl:DatatypeProperty ;
    rdfs:label "Audio-Kodierungsprofil"@de ;
    dcterms:description "Das Kodierungsprofil, wie in den Spezifikationen definiert."@de ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:encodingProfile .

ec:audioTrackConfiguration a owl:DatatypeProperty ;
    rdfs:label "Konfiguration der Audiospur"@de ;
    dcterms:description "Die Konfiguration der Audiospuren, die in der der MediaResource."@de ;
    rdfs:range rdfs:Literal .

ec:audioTrackNumber a owl:DatatypeProperty ;
    rdfs:label "Audiospurnummer"@de ;
    dcterms:description "Zur Identifizierung einer Audiospur innerhalb einer MediaResource."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:auditReportResults a owl:DatatypeProperty ;
    rdfs:label "Ergebnisse des Auditberichts"@de ;
    dcterms:description "Um die kombinierten Ergebnisse von einem oder mehreren AuditJobs."@de .

ec:awardCeremony a owl:DatatypeProperty ;
    rdfs:label "Preisverleihung"@de ;
    dcterms:description "Um einen Namen für die Preisverleihung anzugeben."@de ;
    rdfs:range rdfs:Literal .

ec:basedOn a owl:ObjectProperty ;
    rdfs:label "Verwandtes redaktionelles Objekt"@de ;
    dcterms:description "So identifizieren Sie das EditorialObject, auf das sich ein ProductionJob bezieht zu."@de .

ec:belongsToAudience a owl:ObjectProperty ;
    rdfs:label "Publikum der Eltern"@de ;
    dcterms:description "Die übergeordnete Hörergruppe, der ein Verbraucher angehört von."@de .

ec:bitDepth a owl:DatatypeProperty ;
    rdfs:label "Bit-Tiefe"@de ;
    dcterms:description "Zur Angabe der Bit-Tiefe, mit der die MediaResource kodiert wurde."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:bitRate a owl:DatatypeProperty ;
    rdfs:label "Bitrate"@de ;
    dcterms:description "Zur Angabe der Bitrate, mit der die MediaResource abgespielt werden kann, in Bits/Sekunde. Aktuelle Bitrate, wenn konstant, und durchschnittliche Bitrate, wenn variabel."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:bitRateMax a owl:DatatypeProperty ;
    rdfs:label "Maximale Bitrate"@de ;
    dcterms:description "Die maximale Bitrate, wenn variabel, in Bits pro Sekunde."@de ;
    rdfs:range xsd:nonNegativeInteger .

ec:bitRateMode a owl:DatatypeProperty ;
    rdfs:label "Modus Bitrate"@de ;

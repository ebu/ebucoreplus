                                    owl:allValuesFrom xsd:integer
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty ec:totalNumberOfGroupMembers ;
                                    owl:allValuesFrom xsd:integer
                                  ] ;
                  dcterms:description "Zur Definition einer Sammlung/Gruppe von Medien Resourcen zu definieren, zum Beispiel eine Serie, die aus Episoden besteht."@de ;
                  rdfs:label "Gruppe von Medieninhalten"@de .



       rdfs:label "DID"@de .


###  http://www.ebu.ch/metadata/ontologies/ebucoreplus#SDID
ec:SDID rdf:type owl:DatatypeProperty ;
        rdfs:range xsd:integer ;
        dcterms:description "Sekundärdaten-Kennwort für Zusatzdaten. Kennung für den Sendemodus. Eine Kennung, die den Übertragungszeitpunkt für Untertiteldaten angibt."@de ;
        rdfs:label "SDID"@de .



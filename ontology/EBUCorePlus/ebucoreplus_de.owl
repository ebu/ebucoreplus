- ein Unternehmen, das ein Vertriebsnetz bereitstellt
- ein Unternehmen, das Endgeräte herstellt"""@de .

ec:hasIdentifier a owl:ObjectProperty ;
    rdfs:label "Kennung"@de ;
    dcterms:description "So verknüpfen Sie einen Identifier mit einem Asset."@de .

ec:name a owl:DatatypeProperty ;
    rdfs:label "Name"@de ;
    dcterms:description "Die Bezeichnung der Resource."@de ;
    rdfs:range rdfs:Literal .

ec:hasObjectType a owl:ObjectProperty ;
    rdfs:label "Typ"@de ;
    dcterms:description "Die Art oder das Genre der Resource."@de .

ec:Identifier a owl:Class ;
    rdfs:label "Identifikator"@de ;
    dcterms:description "Zur Unterstützung der Verwendung von strukturierten Identifikatoren."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasIssuer ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateCreated ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:identifierValue ] ;
    skos:definition "eine eindeutige Zeichenkette, die einer Entität zugeordnet ist"@de ;
    skos:example """- "ISAN 0000-0001-8947-0000-8-0000-0000-D" ist ein ISAN Identifikator
- "10.5240/EA73-79D7-1B2B-B378-3A73-M" ist ein EIDR Identifikator des Films "Blade Runner\""""@de .

ec:description a owl:DatatypeProperty ;
    rdfs:label "Beschreibung"@de ;
    dcterms:description "Eine Zusammenfassung der Resource."@de ;
    rdfs:range rdfs:Literal .

time:Instant a owl:Class ;
    rdfs:label "Zeit sofort"@de ;
    dcterms:description "Eine zeitliche Einheit ohne Ausmaß oder Dauer"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue <http://www.opengis.net/def/uom/ISO-8601/0/Gregorian> ;
            owl:onProperty time:hasTRS ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:dateTimeStamp ;
            owl:onProperty time:inXSDDateTimeStamp ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

skos:Concept a owl:Class ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> .

[] owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger .


    dcterms:description "So identifizieren Sie einen Publikationskanal"@de .

ec:hasRelatedRecord a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "Verwandter Datensatz"@de ;
    dcterms:description "So verknüpfen Sie einen Datensatz mit einem Asset."@de .

ec:hasRelatedRule a owl:ObjectProperty ;
    rdfs:label "Regel-Referenz"@de ;
    dcterms:description "Um Hinweise auf eine Regel zu geben."@de .

ec:hasRelatedStage a owl:ObjectProperty ;
    rdfs:label "Verwandte Etappe"@de ;
    dcterms:description "Um eine Bühne mit einer Position auf der Bühne zu verbinden."@de .

ec:hasRelatedTextLine a owl:ObjectProperty ;
    rdfs:label "Zugehörige Textzeile"@de ;
    dcterms:description "Eine Textzeile oder ein freier Text, der sich auf ein EditorialObject bezieht."@de .

ec:hasRelationLink a owl:ObjectProperty ;
    rdfs:label "Link"@de ;
    dcterms:description "So definieren Sie eine Verknüpfung in einer Relation."@de .

ec:hasRelationSource a owl:ObjectProperty ;
    rdfs:label "Relation Quelle"@de ;
    dcterms:description "Um die Quelle einer Relation zu definieren."@de .

ec:hasRestrictedAudience a owl:ObjectProperty ;
    rdfs:label "Eingeschränktes Publikum"@de ;
    dcterms:description "Um eine Zielgruppe zu identifizieren, für die der Zugriff eingeschränkt ist."@de .

ec:hasReview a owl:ObjectProperty ;
    rdfs:label "Überprüfung"@de ;
    dcterms:description "Um einen Überblick zu geben."@de .

ec:hasRightsClearance a owl:ObjectProperty ;
    rdfs:label "Rechteklärung"@de ;
    dcterms:description "Zum Ausdruck bringen Rechte Clearance."@de ;
    rdfs:subPropertyOf ec:hasRights .

ec:hasRightsHolder a owl:ObjectProperty ;
    rdfs:label "Rechteinhaber"@de ;
    dcterms:description "Zur Identifizierung eines Agenten (Kontaktperson/Person oder Organisation), der Rechte besitzt/verwaltet."@de .

ec:hasRightsTargetService a owl:ObjectProperty ;
    rdfs:label "Zielservice"@de ;
    dcterms:description "Um einen mit Rechten verbundenen Service zu identifizieren."@de .

ec:hasRightsTerritoryExcludes a owl:ObjectProperty ;
    rdfs:label "Ausgeschlossene Territorien"@de ;
    dcterms:description "Eine Liste von Länder- oder Regionencodes, für die die Rechte nicht gelten."@de .

ec:hasRightsTerritoryIncludes a owl:ObjectProperty ;
    rdfs:label "Enthaltene Territorien"@de ;
    dcterms:description "Eine Liste der Länder- oder Regionencodes, für die Rechte gelten."@de .

ec:hasScheduleDate a owl:ObjectProperty ;
    rdfs:label "Zeitplan Datum"@de ;
    dcterms:description "Zur Angabe des spezifischen Termindatums, auf das sich ein PublicationEvent bezieht, insbesondere wenn die Broacdast-Zeit nach Mitternacht liegt. Zum Beispiel wäre das Programmdatum der 29. Mai und die Sendung wird um 1 Uhr morgens am 30. Mai veröffentlicht, während sie im Programm noch mit der Nacht des 29. Mai verbunden ist."@de .

ec:hasSerial a owl:ObjectProperty ;
    rdfs:label "hat serielle"@de .

ec:hasServiceGenre a owl:ObjectProperty ;
    rdfs:label "Genre Dienstleistung"@de ;
    dcterms:description "Das Genre des mit dem Dienst verbundenen Inhalts."@de .

ec:hasShot a owl:ObjectProperty ;
    rdfs:label "hat geschossen"@de ;
    rdfs:subPropertyOf ec:hasPart .

ec:hasSigning a owl:ObjectProperty ;
    rdfs:label "Zugänglichkeit - Beschilderung"@de ;
    dcterms:description "Um das Vorhandensein von Signaturen im Zusammenhang mit dem EditorialObject festzustellen."@de .

ec:hasSigningFormat a owl:ObjectProperty ;
    rdfs:label "Format der Unterschrift"@de ;
    dcterms:description "Zur Angabe des für die Unterzeichnung verwendeten Formats."@de .

ec:hasSigningSource a owl:ObjectProperty ;
    rdfs:label "Quelle der Signierung"@de ;
    dcterms:description "So geben Sie die Quelle der Signierung an."@de .

ec:hasSource a owl:ObjectProperty ;
    rdfs:label "Quelle"@de ;
    dcterms:description "Um die Quelle einer MediaResource zu identifizieren."@de .

ec:hasStaffMember a owl:ObjectProperty ;
    rdfs:label "Mitglied des Personals"@de ;
    dcterms:description "Zur Identifizierung von Mitarbeitern in einer Organisation."@de .

ec:hasStageLocation a owl:ObjectProperty ;
    rdfs:label "Standort der Bühne"@de ;
    dcterms:description "So verknüpfen Sie einen Ort mit einer Bühne."@de .

ec:hasStakeholder a owl:ObjectProperty ;
    rdfs:label "Publikationsplan Stakeholder"@de,
        "Stakeholder"@de ;
    dcterms:description "Ein Agent, der sich auf den PublicationPlan bezieht."@de,
        "Um Agenten zu identifizieren, die mit einem PublicationPlan verbunden sind."@de .

ec:hasStandard a owl:ObjectProperty ;
    rdfs:label "Standard"@de ;
    dcterms:description "Identifiziert den technischen Videostandard einer MediaResource, d.h. NTSC oder PAL."@de ;
    rdfs:subPropertyOf ec:hasFormat .

ec:hasSticker a owl:ObjectProperty ;
    rdfs:label "Link zum Aufkleber"@de ;
    dcterms:description "So erstellen Sie einen Link zu einem Sticker"@de .

ec:hasStorageId a owl:ObjectProperty ;
    rdfs:label "Kennung des Speichers"@de ;
    dcterms:description "Zur Identifizierung des mit einem Locator verbundenen Speichers, von dem aus auf eine Resource zugegriffen werden kann oder die abgerufen werden kann."@de .

ec:hasSubJob a owl:ObjectProperty ;
    rdfs:label "Job in der Produktion"@de ;
    dcterms:description "So identifizieren Sie einen ProductionJob / Prozess als Teil eines komplexen ProduktionsJob."@de .

ec:hasSubject a owl:ObjectProperty ;
    rdfs:label "Thema"@de ;
    dcterms:description "Diese Eigenschaft ermöglicht es, ein Asset mit einem Betreff zu verknüpfen, der eine Zeichenkette oder ein URI sein kann, der auf einen Begriff aus einem kontrollierten Vokabular verweist."@de .

ec:hasSubtitling a owl:ObjectProperty ;
    rdfs:label "Untertitelung"@de ;
    dcterms:description "Um vorhandene Untertitel zu identifizieren."@de .

ec:hasSubtitlingFormat a owl:ObjectProperty ;
    rdfs:label "Format der Untertitelung"@de ;
    dcterms:description "Das Format der Untertitelung."@de ;
    rdfs:subPropertyOf ec:hasFormat .

ec:hasSubtitlingSource a owl:ObjectProperty ;
    rdfs:label "Quelle für die Untertitelung"@de ;
    dcterms:description "Um die Quelle der Untertitelung zu identifizieren Resource."@de .

ec:hasTargetChannel a owl:ObjectProperty ;
    rdfs:label "Ziel-Kanal für Publikation"@de ;
    dcterms:description "Um einen Zielkanal für die Publikation anzugeben."@de .

ec:hasTargetPlatform a owl:ObjectProperty ;
    rdfs:label "Ziel-Plattform"@de ;
    dcterms:description "Um eine Zielplattform anzugeben."@de .

ec:hasTargetService a owl:ObjectProperty ;
    rdfs:label "Ziel-Medienservice"@de ;
    dcterms:description "Um einen Ziel-Medienservice für die Publikation anzugeben."@de .

ec:hasTeamMember a owl:ObjectProperty ;
    rdfs:label "Teammitglied"@de ;
    dcterms:description "So identifizieren Sie die Mitglieder eines Teams"@de .

ec:hasTerritoryExcludes a owl:ObjectProperty ;
    rdfs:label "Ausschlussgebiet"@de ;
    dcterms:description "Zur Definition des Standorts (z.B. Land, Region), für den Rating und TargetAudience NICHT gelten."@de .

ec:hasTerritoryIncludes a owl:ObjectProperty ;
    rdfs:label "gilt für"@de ;
    dcterms:description "Um den Vermögenswert zu identifizieren, für den das Rating gilt."@de .

ec:hasTextLineSource a owl:ObjectProperty ;
    rdfs:label "Quelle der Textzeile"@de ;
    dcterms:description "So identifizieren Sie die Quelle einer Textzeile."@de .

ec:hasTheme a owl:ObjectProperty ;
    rdfs:label "Thema"@de ;
    dcterms:description "Diese Eigenschaft ermöglicht es, ein Asset mit einem Thema zu verknüpfen, das eine Zeichenkette oder ein URI sein kann, der auf einen Begriff aus einem kontrollierten Vokabular verweist. Ein typisches Beispiel ist die NACE-Klassifizierung von Eurostats."@de .

ec:hasTimecodeTrack a owl:ObjectProperty ;
    rdfs:label "Timecode-Spur"@de ;
    dcterms:description "So identifizieren Sie eine Timecode-Spur mit einer MediaResource."@de .

ec:hasTimelineTrack a owl:ObjectProperty ;
    rdfs:label "Zeitleiste Spur"@de ;
    dcterms:description "So verknüpfen Sie einen TimelineTrack mit einem EditorialObject"@de .

ec:hasTimelineTrackPart a owl:ObjectProperty ;
    rdfs:label "Teil der Zeitleiste"@de ;
    dcterms:description "So verknüpfen Sie ein EditorialObject mit einem TimelineTrack als TimelineTrackpart"@de ;
    owl:inverseOf ec:isTimelineTrackPartOf .

ec:hasTopic a owl:ObjectProperty ;
    rdfs:label "Thema"@de ;
    dcterms:description "Mit dieser Eigenschaft können Sie ein Asset mit einem Thema verknüpfen, das eine Zeichenkette oder ein URI sein kann, der auf einen Begriff aus einem kontrollierten Vokabular verweist. Ein typisches Beispiel ist die Verwendung der IPTC-Medienthemen, die unter http://cv.iptc.org/newscodes/mediatopic/ definiert sind."@de .

ec:hasTrack a owl:ObjectProperty ;
    rdfs:label "Spur"@de ;
    dcterms:description "So verknüpfen Sie Audio-/Daten-/Videotracks mit einer MediaResource."@de .

ec:hasTrackPart a owl:ObjectProperty ;
    rdfs:label "Quelle des Trackings"@de ;
    dcterms:description "Ein Element zur Identifizierung eines Teils eines Titels durch einen Titel, eine Startzeit und eine Endzeit sowohl in der Medienquelle als auch im Medienziel."@de ;
    owl:inverseOf ec:isTrackPartOf .

ec:hasTrackPurpose a owl:ObjectProperty ;
    rdfs:label "Zweck der Spur"@de ;
    dcterms:description "Der Zweck, für den der Track bereitgestellt wird."@de .

ec:hasTrackType a owl:ObjectProperty ;
    rdfs:label "Name der Spur"@de ;
    dcterms:description "Der Typ, der einem Track zugeordnet ist."@de .

ec:hasUnit a owl:ObjectProperty ;
    rdfs:label "Einheit messen"@de ;
    dcterms:description "Zur Festlegung der Einheit, in der der Wert einer Kennzahl ausgedrückt wird, falls zutreffend."@de .

ec:hasUsageContract a owl:ObjectProperty ;
    rdfs:label "Nutzungsvertrag"@de ;
    dcterms:description "Die Vertragsbedingungen, unter denen ein ProductionDevice verwendet werden soll verwendet wird."@de .

ec:hasUsageRights a owl:ObjectProperty ;
    rdfs:label "Nutzungsrechte"@de ;
    dcterms:description "Um Nutzungsrechte auszudrücken."@de ;
    rdfs:subPropertyOf ec:hasRights .

ec:hasVersion a owl:ObjectProperty ;
    rdfs:label "Version"@de ;
    dcterms:description "Um eine andere Version eines Assets, Redaktionsobjekts oder einer Resource zu identifizieren."@de ;
    owl:inverseOf ec:isVersionOf .

ec:hasVersionType a owl:ObjectProperty ;
    rdfs:label "Version Typ"@de ;
    dcterms:description "Um eine Art von Version für ein EditorialObject anzugeben."@de .

ec:hasVideoCodec a owl:ObjectProperty ;
    rdfs:label "Video Codec"@de ;
    dcterms:description "So identifizieren Sie einen Videocodec"@de ;
    rdfs:subPropertyOf ec:hasCodec .

ec:hasVideoEncodingFormat a owl:ObjectProperty ;
    rdfs:label "Format der Audiokodierung"@de ;
    dcterms:description "Zur Angabe des Videocodierungsformats."@de ;
    rdfs:subPropertyOf ec:hasFormat .

ec:hasVideoTrack a owl:ObjectProperty ;
    rdfs:label "Video-Spur"@de ;
    dcterms:description "So identifizieren Sie Videospuren in der Resource."@de .

ec:hasWrappingType a owl:ObjectProperty ;
    rdfs:label "Art der Umhüllung"@de ;
    dcterms:description "Um die Art der Umhüllung festzulegen."@de .

ec:hashValue a owl:DatatypeProperty ;
    rdfs:label "Hash-Code"@de ;
    dcterms:description "Der Hash-Wert, der einer Resource zugeordnet ist. Es gibt es verschiedene Methoden / Algorithmen zur Berechnung von Hash-Werten, die als Untereigenschaften definiert werden können. Unter-Eigenschaften."@de ;
    rdfs:range xsd:string .

ec:height a owl:DatatypeProperty ;
    rdfs:label "Höhe"@de ;
    dcterms:description "Die Höhe z.B. eines Videobildes wird normalerweise ausgedrückt als Anzahl von Zeilen oder die Höhe eines Bildes/Bildes, ausgedrückt in Millimetern oder anders."@de ;
    rdfs:range xsd:integer .

ec:heightUnit a owl:DatatypeProperty ;
    rdfs:label "Höheneinheit"@de ;
    dcterms:description "Um eine Einheit für die Höhe anzugeben."@de ;
    rdfs:range rdfs:Literal .

ec:highlights a owl:DatatypeProperty ;
    rdfs:label "Höhepunkte"@de ;
    dcterms:description "Um Highlights zu bieten."@de ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:contentDescription .

ec:hobbies a owl:DatatypeProperty ;
    rdfs:label "Hobbys"@de ;
    dcterms:description "Die Hobbys einer Person."@de ;
    rdfs:range rdfs:Literal .

ec:holdsAward a owl:ObjectProperty ;
    rdfs:label "erhält"@de ;
    owl:inverseOf ec:isAwardedTo .

ec:holdsLicence a owl:ObjectProperty ;
    rdfs:label "Verbrauchslizenz"@de ;
    dcterms:description "Die Bedingungen einer ConsumptionLicence, die mit einem Vertrag."@de .

ec:iFrameSize a owl:DatatypeProperty ;
    rdfs:label "I-Frame/Gop-Größe"@de ;
    dcterms:description "Der Abstand zwischen 2 I-Frames wird auch als Gop-Größe bezeichnet."@de ;
    rdfs:range xsd:int .

ec:identifierValue a owl:DatatypeProperty ;
    rdfs:label "Wert der Kennung"@de ;
    dcterms:description "Bereich: String oder anyURI."@de ;
    rdfs:range rdfs:Literal .

ec:inchesPerSecond a owl:DatatypeProperty ;
    rdfs:label "Zentimeter pro Sekunde"@de ;
    dcterms:description "Gibt die Zoll pro Sekunde an, mit der ein analoges Audioband für den menschlichen Verzehr wiedergegeben werden sollte."@de ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf ec:playbackSpeed .

ec:includesAudience a owl:ObjectProperty ;
    rdfs:label "Inklusive Publikum"@de ;
    dcterms:description "Eine definierte Zielgruppe, die in der Zielgruppe enthalten ist"@de .

ec:instantiates a owl:ObjectProperty ;
    rdfs:label "Redaktionelles Objekt"@de ;
    dcterms:description "Um eine bestimmte Manifestation eines EditorialObjects mit der entsprechenden Resource zu verknüpfen."@de ;
    owl:inverseOf ec:isInstantiatedBy .

ec:internetConnectivity a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Internet-Verbindung"@de ;
    dcterms:description "Zur Angabe, ob der Dienst eine Internetverbindung erfordert Konnektivität erfordert."@de .

ec:isAbout a owl:ObjectProperty ;
    rdfs:label "handelt von"@de ;
    dcterms:description "Wird verwendet, wenn ein anderer Medieninhalt, z.b. ein Buch, ein Film oder eine Sendung das Thema des Medieninhaltes ist."@de ;
    rdfs:range ec:Asset .

ec:isAffiliatedTo a owl:ObjectProperty ;
    rdfs:label "ist angegliedert an"@de ;
    dcterms:description "Beziehung zu der Organisation, die der Verband vertritt"@de .

ec:isAffiliationFor a owl:ObjectProperty .

ec:isAnimalGroomFor a owl:ObjectProperty .

ec:isAnnotatedMediaResource a owl:ObjectProperty ;
    rdfs:label "MedienResource"@de ;
    dcterms:description "So verknüpfen Sie eine Anmerkung mit einer MediaResource."@de .

ec:isAttributedTo a owl:ObjectProperty ;
    rdfs:label "Ziel Provenienz"@de ;
    dcterms:description "So verknüpfen Sie einen Agenten mit einer Provenance-Instanz."@de .

ec:isAuthorOf a owl:ObjectProperty .

ec:isCommissionedBy a owl:ObjectProperty ;
    rdfs:label "Vertrag"@de ;
    dcterms:description "Der Vertrag, durch den eine Resource in Auftrag gegeben wird."@de .

ec:isComposedOf a owl:ObjectProperty ;
    rdfs:label "Medien Resource"@de ;
    dcterms:description "Zur Identifizierung von MedienResourcen, die zur Erstellung einer Essenz verwendet werden."@de .

ec:isDistributedOn a owl:ObjectProperty ;
    rdfs:label "Plattform/Dienstleistung/Veröffentlichungskanal"@de ;
    dcterms:description "Um die Plattform zu identifizieren, auf der die Inhalte verbreitet werden."@de .

ec:isEmbodiedBy a owl:ObjectProperty .

ec:isEpisodeOfSeason a owl:ObjectProperty ;
    rdfs:label "Saison der Eltern"@de ;
    dcterms:description "Die Episode einer Saison."@de .

ec:isEpisodeOfSerial a owl:ObjectProperty ;
    rdfs:label "ist eine Folge der Serie"@de .

ec:isEpisodeOfSeries a owl:ObjectProperty ;
    rdfs:label "Eltern-Serie"@de ;
    dcterms:description "Die Episode einer Serie."@de .

ec:isExtractOf a owl:ObjectProperty ;
    rdfs:label "ist ein Auszug aus"@de ;
    dcterms:description "Dient zur Darstellung eines Auszugs, d. h. der Wiedergabe eines Teils oder des gesamten archivierten Materials auf dem Abspielgerät. Für Attribute wie Dauer und Start werden die Daten in der Instanz platziert, die den Auszug darstellt. Andere Metadaten werden aus der Originalinstanz gelesen, die extrahiert wird."@de .

ec:isNextInSequence a owl:ObjectProperty ;
    rdfs:label "Nächste"@de ;
    dcterms:description "Ein Link zu einem redaktionellen Objekt, das dem aktuellen redaktionellen Objekt in einer geordneten Reihenfolge folgt."@de ;
    owl:inverseOf ec:isPreviousInSequence .

ec:isOfferedBy a owl:ObjectProperty ;
    rdfs:label "Service"@de ;
    dcterms:description "Um einen Dienst zu identifizieren, der einem PublicationEvent zugeordnet ist."@de ;
    owl:inverseOf ec:offers .

ec:isOperatedBy a owl:ObjectProperty ;
    rdfs:label "Betreiber, Eigentümer"@de ;
    dcterms:description "Um den Dienst zu identifizieren, der den PublicationChannel."@de .

ec:isPlayedBy a owl:ObjectProperty ;
    rdfs:label "wird gespielt von"@de ;
    dcterms:description "Beziehung zwischen einer fiktiven Figur und dem Schauspieler, der die Rolle spielt."@de ;
    owl:inverseOf ec:playsCharacter ;
    owl:propertyDisjointWith ec:isPortrayedBy .

ec:isRelatedAgent a owl:ObjectProperty .

ec:isReplacedBy a owl:ObjectProperty ;
    rdfs:label "Ersatz"@de ;
    dcterms:description "Um Substitutionen zu identifizieren."@de ;
    owl:inverseOf ec:replaces .

ec:isSeasonOf a owl:ObjectProperty ;
    rdfs:label "Serie"@de ;
    dcterms:description "So ordnen Sie eine Saison einer Serie zu."@de .

ec:isoDuration a owl:DatatypeProperty ;
    rdfs:label "ISO-Dauer"@de ;
    dcterms:description "eine Dauer, ausgedrückt als Zeichenkette im Format ISO8601, also PT3M23S"@de ;
    rdfs:range xsd:string .

ec:lineNumber a owl:DatatypeProperty ;
    rdfs:label "Zeilennummer"@de ;
    dcterms:description "Zur Angabe der Nummer der Leitung, auf der Zusatzdaten übertragen werden, und die Entsprechung im digitalen Bereich."@de ;
    rdfs:range xsd:integer .

ec:live a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Live"@de ;
    dcterms:description "Ein Flag, das signalisiert, dass der Inhalt live ist"@de ;
    rdfs:range xsd:boolean .

ec:locationAddressApartmentNumber a owl:DatatypeProperty ;
    rdfs:label "Appartmentnummer"@de ;
    dcterms:description "Die Nummer, die eine Wohnung in einem Haus identifiziert."@de ;
    rdfs:range xsd:string .

ec:locationAddressArea a owl:DatatypeProperty ;
    rdfs:label "Bereich"@de ;
    dcterms:description "Um den Bereich Teil einer Adresse."@de ;
    rdfs:range rdfs:Literal .

ec:locationAddressCountry a owl:DatatypeProperty ;
    rdfs:label "Land"@de ;
    dcterms:description "Zur Angabe des Ländernamens und/oder des Ländercodes Code."@de ;
    rdfs:range rdfs:Literal .

ec:locationAddressHouseNumber a owl:DatatypeProperty ;
    rdfs:label "Hausnummer"@de ;
    dcterms:description "Die Nummer, die einem Haus oder einem Eingang in einer Straße gegeben wird"@de ;
    rdfs:range xsd:string .

ec:locationAddressMunicipality a owl:DatatypeProperty ;
    rdfs:label "Gemeinde"@de ;
    dcterms:description "Zur Angabe des Namens einer Stadt, eines Dorfes, usw."@de ;
    rdfs:range rdfs:Literal .

ec:locationAddressPostalCode a owl:DatatypeProperty ;
    rdfs:label "Postleitzahl"@de ;
    dcterms:description "Zur Angabe einer Postleitzahl für die Adresse code."@de ;
    rdfs:range rdfs:Literal .

ec:locationAddressStreetName a owl:DatatypeProperty ;
    rdfs:label "Straßenname"@de ;
    dcterms:description "Der Name der Straße, des Platzes oder des Blocks in einer Adresse"@de ;
    rdfs:range rdfs:Literal .

ec:locationAltitude a owl:DatatypeProperty ;
    rdfs:label "Höhenlage"@de ;
    dcterms:description "So definieren Sie die Höhe eines Ortes in Metern."@de ;
    rdfs:range xsd:float .

ec:locationCoordinateSystemName a owl:DatatypeProperty ;
    rdfs:label "Koordinatensystem"@de ;
    dcterms:description "Zur Angabe des Namens des GPS-Koordinatensystems Systems, das für den Standort verwendet wird."@de ;
    rdfs:range rdfs:Literal .

ec:locationLatitude a owl:DatatypeProperty ;
    rdfs:label "Breitengrad"@de ;
    dcterms:description "Der Breitengrad des Ortes."@de ;
    rdfs:range xsd:float .

ec:locationLongitude a owl:DatatypeProperty ;
    rdfs:label "Längengrad"@de ;
    dcterms:description "So definieren Sie den Längengrad des Standortes."@de ;
    rdfs:range xsd:float .

ec:locatorTargetInformation a owl:DatatypeProperty ;
    rdfs:label "Informationen zum Ziel des Locators"@de ;
    dcterms:description "Informationen über das Ortungsziel."@de ;
    rdfs:range rdfs:Literal .

ec:log a owl:DatatypeProperty ;
    rdfs:label "Protokoll"@de ;
    dcterms:description "Um alles im Inhalt nach vordefinierten Regeln und Kriterien als neutrale Abfolge von (möglicherweise zeitlich begrenzten) Textbeschreibungen zu protokollieren."@de ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:contentDescription .

ec:logs a owl:ObjectProperty .

ec:maritalStatus a owl:DatatypeProperty ;
    rdfs:label "Familienstand"@de ;
    dcterms:description "Zur Identifizierung des Familienstandes einer Person."@de ;
    rdfs:range rdfs:Literal .

ec:measureValue a owl:DatatypeProperty ;
    rdfs:label "Wert messen"@de ;
    dcterms:description "Um den Wert einer Maßnahme anzugeben."@de .

ec:measureValueMax a owl:DatatypeProperty ;
    rdfs:label "Maximalwert messen"@de ;
    dcterms:description "Um den maximalen Wert einer Kennzahl zu definieren, wenn gilt."@de .

ec:measureValueMin a owl:DatatypeProperty ;
    rdfs:label "Minimalwert messen"@de ;
    dcterms:description "Um den Mindestwert einer Maßnahme zu definieren, wenn gilt."@de .

ec:measures a owl:ObjectProperty ;
    rdfs:label "Verwandte Regel"@de ;
    dcterms:description "So verknüpfen Sie eine Regel mit einer Kennzahl."@de .

ec:microphone a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Mikrofon"@de ;
    dcterms:description "Um anzugeben, ob der Service ein Mikrofon benötigt."@de .

ec:midRollAdAllowed a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Midroll-Anzeige erlaubt"@de ;
    dcterms:description "Ein Flag, das anzeigt, ob es erlaubt ist, Werbeunterbrechungen in der Mitte der Rolle einzufügen."@de ;
    rdfs:range xsd:boolean .

ec:middleName a owl:DatatypeProperty ;

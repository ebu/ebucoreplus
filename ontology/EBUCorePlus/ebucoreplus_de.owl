    dcterms:description "Die Anzahl der in einem Dokument enthaltenen Wörter."@de ;
    rdfs:range xsd:integer .

<http://www.opengis.net/def/uom/ISO-8601/0/Gregorian> a owl:NamedIndividual .

xsd:date a rdfs:Datatype .

time:day a owl:DatatypeProperty ;
    rdfs:label "Tag"@de ;
    rdfs:range xsd:gDay .

time:hasTRS a owl:ObjectProperty ;
    rdfs:label "Hat TRS"@de ;
    dcterms:description "Das zeitliche Referenzsystem, das von einer zeitlichen Positions- oder Ausdehnungsbeschreibung verwendet wird."@de .

time:inXSDDateTimeStamp a owl:DatatypeProperty ;
    rdfs:range xsd:dateTimeStamp .

time:month a owl:DatatypeProperty ;
    rdfs:label "Monat"@de ;
    rdfs:range xsd:gMonth .

time:year a owl:DatatypeProperty ;
    rdfs:label "Jahr"@de ;
    rdfs:range xsd:gYear .

xkos:precedes a owl:ObjectProperty ;
    rdfs:label "steht vor"@de ;
    rdfs:subPropertyOf xkos:sequential .

xkos:succeeds a owl:ObjectProperty ;
    rdfs:label "folgt auf"@de ;
    rdfs:subPropertyOf xkos:sequential .

ec:AccessConditions a owl:Class ;
    rdfs:label "Zugangsbedingungen"@de ;
    dcterms:description "Die Bedingungen, unter denen auf Inhalte zugegriffen werden kann."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasGeoBlockingBlacklist ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasGeoBlockingWhitelist ],
        ec:Rights .

ec:AlternativeTitle a owl:Class ;
    rdfs:label "Alternativer Titel"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:onProperty ec:title ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Animal a owl:Class ;
    rdfs:label "Tier"@de ;
    dcterms:description "Um ein Tier zu identifizieren."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:AnimalBreedCode ;
            owl:onProperty ec:hasAnimalBreedCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AnimalColourCode ;
            owl:onProperty ec:hasAnimalColourCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasAnimalGroom ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Involvement ;
            owl:onProperty ec:hasAnimalRole ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasOwner ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Character ;
            owl:onProperty ec:portrays ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfBirth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfDeath ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:animalCharacterName ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:animalCode ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:animalPassport ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:gender ] .

ec:AuditReport a owl:Class ;
    rdfs:label "Prüfbericht"@de ;
    dcterms:description "Ein Prüfbericht führt die Ergebnisse von Prüfaufgaben zusammen."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasApprover ],
        [ a owl:Restriction ;
            owl:allValuesFrom time:Instant ;
            owl:onProperty ec:hasAuditReportDate ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AuditJob ;
            owl:onProperty ec:hasRelatedAuditJob ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rule ;
            owl:onProperty ec:referencesRule ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:auditReportResults ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Award a owl:Class ;
    rdfs:label "Auszeichnung"@de ;
    dcterms:description "Zur Beschreibung eines Awards und der damit verbundenen Informationen."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasRelatedEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isAwardedTo ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasAwardDate ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:awardCeremony ] .

ec:CampaignPackage a owl:Class ;
    rdfs:label "Kampagnen-Paket"@de ;
    rdfs:subClassOf ec:EditorialGroup ;
    skos:definition "eine Gruppe von EditorialObjects, um ein Produkt, eine Dienstleistung, ein Ereignis zu bewerben ..."@de ;
    skos:example """- eine Reihe von verschiedenen Anzeigen für ein Produkt
- eine Reihe von verschiedenen Trailern für einen Film"""@de .

ec:Consumer a owl:Class ;
    rdfs:label "Nutzer"@de ;
    dcterms:description "Eine Person, die einen Service konsumiert mit Hilfe eines Endgerätes. Der Nutzer kann zu einem Publikum gehören. Seine Aktivitäten führen zu Nutzungsereignissen und zu Resonanzereignissen. Ein Nutzer kann für einen Service registriert sein über ein Nutzerkonto, das den Nutzer in unterschiedlichem Detaillierungsgrad repräsentiert (z.B. Alter, Geschlecht, Adresse). Eine Nutzungslizenz definiert die genaueren Nutzungsbedingungen und -möglichkeiten."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:belongsToAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionEvent ;
            owl:onProperty ec:hasAssociatedConsumptionEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:hasRegistration ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDevice ;
            owl:onProperty ec:usesConsumptionDevice ],
        ec:Person ;
    skos:definition "eine Person, die einen Mediendienst konsumiert"@de ;
    skos:example """- ein Radiohörer
- ein Videostream-Zuschauer"""@de .

ec:ConsumptionDeviceProfile a owl:Class ;
    rdfs:label "Endgeräteprofil"@de ;
    dcterms:description "Das Profil eines Endgerätes.(z.B. Hersteller, Modell, Hardwareausstattung, Softwareausstattung, etc.)"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:canAccessPublicationChannel ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlatform ;
            owl:onProperty ec:canAccessPublicationPlatform ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasGeoLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:internetConnectivity ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:microphone ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:radioTuner ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:soundOutput ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:textInput ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:timeshift ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:videoDisplay ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:webcam ] ;
    skos:definition "eine Reihe von Eigenschaften eines einzelnen Endgerätes, die eine Klassifizierung des Geräts ermöglichen"@de ;
    skos:example """- ein Apple-Smartphone mit iOS-Version > 16
- einen Smart TV mit einem Bildschirm von 50' bis 60' und HDR-Unterstützung
- ein VR-Headset"""@de .

ec:ConsumptionLicence a owl:Class ;
    rdfs:label "Nutzungslizenz"@de ;
    dcterms:description "Eine Nutzungslizenz gehört zu einem Nutzer und legt die Nutzungsbedingungen für ein Produkt fest."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDevice ;
            owl:onProperty ec:coversConsumptionDevice ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Contract ;
            owl:onProperty ec:hasConsumptionLicenceLink ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:consumptionLicenceText ] ;
    skos:definition "eine Genehmigung zur Nutzung eines Mediendienstes"@de ;
    skos:example """- ein Abonnement für unbegrenztes Streaming von Spotify, das 3 Geräte umfasst
- ein 3-monatiges Testabonnement für einen VoD-Dienst
- die Berechtigung, als Einwohner eines Landes frei empfangbare Rundfunkdienste zu konsumieren"""@de .

ec:CoverageRestrictions a owl:Class ;
    rdfs:label "Einschränkungen der Deckung"@de ;
    dcterms:description "Bereitstellung von Informationen über mögliche Einschränkungen hinsichtlich der zeitlichen und räumlichen Abdeckung für die Veröffentlichung."@de ;
    rdfs:subClassOf ec:Rights .

ec:DataTrack a owl:Class ;
    rdfs:label "Daten verfolgen"@de ;
    dcterms:description "Zusatzdatenspur z.B. \"Captioning\" oder \"Untertitelung\" zusätzlich zu den Video- und Audiospuren."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:DataFormat ;
            owl:onProperty ec:hasDataFormat ],
        ec:Track .

ec:ImageCodec a owl:Class ;
    rdfs:label "Bild-Codec"@de ;
    dcterms:description "um einen Codec für Bilder zu identifizieren"@de ;
    rdfs:subClassOf ec:Codec .

ec:ImageFormat a owl:Class ;
    rdfs:label "Bildformat"@de ;
    dcterms:description "Zur Bereitstellung technischer Informationen über das Format eines Bildes, wie z.B. die Ausrichtung. Diese Informationen werden als freier Text in einer Beschriftung oder als Kennung, die auf einen Begriff in einem Klassifizierungsschema verweist Schema."@de ;
    rdfs:subClassOf ec:Format .

ec:KeyEvent a owl:Class ;
    rdfs:label "Wichtigstes Ereignis"@de ;
    dcterms:description "Um ein bedeutendes Ereignis zu beschreiben."@de ;
    rdfs:subClassOf ec:Event .

ec:MarketingBrand a owl:Class ;
    rdfs:label "Marke"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isOwnedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "ein Name, oft zusammen mit einem Logo, der einem Vermögenswert oder einer Dienstleistung oder einer Gruppe davon gegeben wird, um sie von Vermögenswerten oder Dienstleistungen anderer Hersteller oder Händler zu unterscheiden."@de ;
    skos:example """- der Name einer PSM-Organisation: "BBC"
- der Name eines Medienkanals: "BBC4"
- der Name einer Serie: "Downton Abbey"
- der Name einer Serie: "BBC Nachrichten\""""@de .

ec:MediaFragment a owl:Class ;
    rdfs:label "Medienfragment"@de ;
    dcterms:description "Ein MediaFragment ist ein zeitliches oder räumliches Segment einer Resource, das durch einen MediaGragment-URI identifiziert wird (http://www.w3.org/2008/WebVideo/Fragments/WD-media-fragments-spec/)."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:isMediaFragmentOf ],
        ec:MediaResource ;
    skos:definition "eine MedienResource, die ein zeitliches oder räumliches Segment einer Resource ist, das wie in MediaFragment-URI  (http://www.w3.org/2008/WebVideo/Fragments/WD-media-fragments-spec/) beschrieben ist"@de .

ec:MimeType a owl:Class ;
    rdfs:label "Mime-Typ"@de ;
    dcterms:description "Die Definition des Containers, falls er als ein MIME-Typ. Dies wird als freier Text in einer Beschriftung oder als Bezeichner angegeben der auf einen Begriff in einem Klassifizierungsschema verweist. Für weitere Informationen: http://www.iana.org/assignments/media-types/index.html."@de ;
    rdfs:subClassOf ec:Format .

ec:OnStagePosition a owl:Class ;
    rdfs:label "Bühnenposition"@de ;
    dcterms:description "Gibt die Position eines Akteurs oder eines Produktionswerkzeuges auf einer Bühne an."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Stage ;
            owl:onProperty ec:hasRelatedStage ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty ec:onStagePositionCoordinateX ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty ec:onStagePositionCoordinateY ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty ec:onStagePositionCoordinateZ ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:onStagePositionCoordinatesReferencePoint ] .

ec:ResonanceEvent a owl:Class ;
    rdfs:label "Resonanzereignis"@de ;
    dcterms:description """Daten zur Nutzung eines Medienproduktes durch einen Nutzer mit Hilfe eines speziellen Endgerätes.
Repräsentiert alle individuell zählbaren oder erfassbaren Aktivitäten des Nutzers währen eines Nutzungsereignisses mit Hilfe eines Endgerätes, z.B. Klicks, Likes, Kommntare, Abstimmungen, Tweets, Downloads, etc.
Alle Resonanzereignisse sind mit einem Nutzungsereignis verknüpft und dessen Essenz oder Medieninhalt.
Resonanzereignisse  repräsentieren Rohdaten, die aggregiert werden müssen (z.B. durch Zusammenzählen). Solche Daten können als "Big Data" betrachtet werden und erfordern den Einsatz geeigneter Technologien and Verarbeitungsalgorithmen. Die Aggregation dieser Daten führt zu einem Resonanz-Objekt."""@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:ConsumptionEvent ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:EditorialObject ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:PublicationChannel ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:PublicationEvent ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:PublicationPlatform ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:PublicationService ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Consumer ;
            owl:onProperty ec:hasAssociatedConsumer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Locator ;
            owl:onProperty ec:hasLocator ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "eine zählbare oder spürbare nuztungsbezogene Handlung eines Nutzers während oder nach einem Nutzungsereignis"@de ;
    skos:example """- Ausschalten des Fernsehgeräts
- Umschalten auf einen anderen Radiosender
- Pausieren der Wiedergabe eines Videos von einem VOD-Portal
- Suche nach Inhalten in einem VOD-Portal
- einen Twitter-Beitrag liken, teilen oder kommentieren
- ein Video auf youtube kommentieren
- sich telefonisch bei der Programm-Hotline der PSM beschweren
- Bewertung einer Radiosendung in der App des Radiosenders"""@de .

ec:Serial a owl:Class ;
    rdfs:label "Serie"@de ;
    dcterms:description "Werke, die (z. B. in einer Zeitschrift oder im Fernsehen) in Teilen erscheinen"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasEpisode ;
            owl:someValuesFrom ec:Programme ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Season ;
            owl:onProperty ec:hasSeason ],
        ec:EditorialGroup ;
    skos:definition "eine Gruppe von Medieninhalten, die eine ganze Geschichte in Teilen erzählt, wobei jeder Teil an den vorangegangenen anknüpft"@de ;
    skos:example "- Deutsche Serie \"Babylon Berlin\" mit mehreren Staffeln"@de .

ec:Series a owl:Class ;
    rdfs:label "Reihe"@de ;
    dcterms:description "Serien sind eine besondere Art von Sammlungen. TV oder Radio-Serien bestehen aus Episoden. Episoden folgen häufig einem Publikationsschema oder behandeln ähnliche Themen oder beinhalten dieselben Figuren."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasEpisode ;
            owl:someValuesFrom ec:Programme ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Season ;
            owl:onProperty ec:hasSeason ],
        ec:EditorialGroup ;
    skos:definition "eine Gruppe Medieninhalten, in der Regel gruppiert nach Personen oder Themen oder Veröffentlichungsschemata, nicht unbedingt nach einer fortlaufenden Geschichte"@de ;
    skos:example """- ABC-Sendereihe "Friends"
- BBCs tägliche Nachrichtensendung "BBC News"
- ARD-Sendereihe "Tatort\""""@de .

ec:Shot a owl:Class ;
    rdfs:label "Schuss"@de ;
    dcterms:description "Eine Filmsequenz, die kontinuierlich von einer Kamera aufgenommen wird"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasScene ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Take ;
            owl:onProperty ec:hasTake ],
        ec:EditorialSegment ;
    owl:disjointWith ec:Take ;
    skos:definition "ein EditorialSegment mit einer Kamera ohne Unterbrechung gefilmt"@de ;
    skos:example "- ein Ausschnitt aus der Schlussszene von \"Casablanca\", der Humphrey Bogart von hinten zeigt, während er Ingrid Bergman und Paul Henreid beim Gang zum Flugzeug beobachtet, gefilmt von einer einzigen Kamera ohne Unterbrechung"@de .

ec:StaffMember a owl:Class ;
    rdfs:label "Mitarbeiterin"@de ;
    dcterms:description "Ein Mitglied der Belegschaft"@de ;
    rdfs:subClassOf ec:Person .

ec:Stream a owl:Class ;
    rdfs:label "Stream"@de ;
    dcterms:description "Ein kontinuierlicher Strom von Bits."@de ;
    rdfs:subClassOf ec:Component ;
    skos:definition "eine Komponente in Form eines kontinuierlichen Flusses von Bits"@de ;
    skos:example """- einen Audiostream von einem Audio-on-Demand-Dienst
- einen Videostream von einem Video-on-Demand-Dienst"""@de .

ec:TimelineTrack a owl:Class ;
    rdfs:label "Zeitachse"@de ;
    dcterms:description "Definiert den zeitlichen Ablauf von Medieninhalten."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:hasTimelineTrackPart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasDuration ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:UsageRestrictions a owl:Class ;
    rdfs:label "Einschränkungen bei der Verwendung"@de ;
    dcterms:description "So definieren Sie eine Reihe von Nutzungseinschränkungen."@de ;
    rdfs:subClassOf ec:Rights .

ec:abstract a owl:DatatypeProperty ;
    rdfs:label "Abstrakt"@de ;
    dcterms:description "Um eine Zusammenfassung zu erstellen."@de ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:contentDescription .

ec:agentWebHomepage a owl:DatatypeProperty ;
    rdfs:label "Homepage"@de ;
    dcterms:description "Zur Angabe der Adresse der Webseite eines Agenten (Kontaktperson/Person oder Organisation)."@de ;
    rdfs:range xsd:anyURI .

ec:aspectRatio a owl:DatatypeProperty ;
    rdfs:label "Bildseitenverhältnis"@de ;
    dcterms:description "Um das Seitenverhältnis festzulegen."@de ;
    rdfs:range xsd:string .

ec:audienceCount a owl:DatatypeProperty ;
    rdfs:label "Anzahl der Zuhörer"@de ;
    dcterms:description "Die Reichweite des Publikums in Zahlen oder Prozent."@de .

ec:frameHeight a owl:DatatypeProperty ;
    rdfs:label "Rahmenhöhe"@de ;
    dcterms:description "Die Höhe eines Videobildes."@de ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf ec:height .

ec:frameHeightUnit a owl:DatatypeProperty ;
    rdfs:label "Einheit Rahmenhöhe"@de ;
    dcterms:description "Die Einheit, die zur Messung der Höhe eines Rahmens verwendet wird."@de ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:heightUnit .

ec:frameWidth a owl:DatatypeProperty ;
    rdfs:label "Rahmenbreite"@de ;
    dcterms:description "Die Breite eines Videobildes."@de ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf ec:width .

ec:frameWidthUnit a owl:DatatypeProperty ;
    rdfs:label "Einheit Rahmenbreite"@de ;
    dcterms:description "Die Einheit, die zur Messung der Breite eines Rahmens verwendet wird."@de ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:widthUnit .

ec:hasAccessConditions a owl:ObjectProperty ;
    rdfs:label "Zugangsbedingungen"@de ;
    dcterms:description "Um Zugangsbedingungen/Einschränkungen auszudrücken."@de ;
    rdfs:subPropertyOf ec:hasRights .

ec:hasAlternativeTitle a owl:ObjectProperty ;
    rdfs:label "hat einen alternativen Titel"@de .

ec:hasApprover a owl:ObjectProperty ;
    rdfs:label "Genehmigt von"@de ;
    dcterms:description "Um einen Agenten zu identifizieren, der einen AuditReport genehmigt hat."@de .

ec:hasAssociatedArtefact a owl:ObjectProperty ;
    rdfs:label "Verwandtes Artefakt"@de ;
    dcterms:description "Ein Artefakt, das mit einem Agent verbunden ist."@de .

ec:hasBrand a owl:ObjectProperty ;
    rdfs:label "Marke"@de ;
    dcterms:description "Um eine Marke zu identifizieren."@de .

ec:hasCharacter a owl:ObjectProperty ;
    rdfs:label "Charakter"@de,
        "Fiktiver Charakter."@de ;
    dcterms:description "Um einen Charakter zu identifizieren."@de,
        "Zum Auflisten von Figuren in einer Fiktion."@de .

ec:hasCommissioningContract a owl:ObjectProperty ;
    rdfs:label "Vertrag"@de ;
    dcterms:description "Der Vertrag, durch den ein EditorialObject in Auftrag gegeben wird."@de .

ec:hasContributor a owl:ObjectProperty ;
    rdfs:label "Beitragender"@de ;
    dcterms:description "Zur Identifizierung eines Mitwirkenden an einer Resource, einem Redaktionsobjekt, einem Ereignis..."@de .

ec:hasCoverageRestrictions a owl:ObjectProperty ;
    rdfs:label "Einschränkungen der Deckung"@de ;
    dcterms:description "Um Einschränkungen der Deckung auszudrücken."@de ;
    rdfs:subPropertyOf ec:hasRights .

ec:hasCreator a owl:ObjectProperty ;
    rdfs:label "Schöpfer"@de ;
    dcterms:description "Zur Identifizierung eines Agenten, der an der Erstellung der Resource oder des Redaktionsobjekts beteiligt war."@de .

ec:hasDateDeleted a owl:ObjectProperty ;
    rdfs:label "Datum der Löschung"@de ;
    dcterms:description "Das Datum, an dem die Resource gelöscht wurde."@de ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasDateModified a owl:ObjectProperty ;
    rdfs:label "Datum/Uhrzeit der Änderung"@de ;
    dcterms:description "Zur Angabe des Datums, an dem das Asset geändert wurde."@de ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasDateOfBirth a owl:ObjectProperty ;
    rdfs:label "Geburtsdatum"@de ;
    dcterms:description "Das Datum, an dem ein Kontakt/eine Person geboren wird."@de ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasDateOfDeath a owl:ObjectProperty ;
    rdfs:label "Datum des Todes"@de ;
    dcterms:description "Das Datum, an dem ein Kontakt/eine Person verstorben ist."@de ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasEditorialWork a owl:ObjectProperty ;
    rdfs:label "hat redaktionelle Arbeit"@de ;
    rdfs:subPropertyOf ec:isMemberOf .

ec:hasImageCodec a owl:ObjectProperty ;
    rdfs:label "Bild-Codec"@de ;
    dcterms:description "Um den Codec eines Bildes anzugeben."@de .

ec:hasImageFormat a owl:ObjectProperty ;
    rdfs:label "Bildformat"@de ;
    dcterms:description "Um das Format eines Bildes festzulegen."@de .

ec:hasProvenanceTarget a owl:ObjectProperty ;
    rdfs:label "Ziel Provenienz"@de ;
    dcterms:description "Die Instanz eines Objekts, das von der Provenance bezogen wird."@de .

ec:hasPublicationChannel a owl:ObjectProperty ;
    rdfs:label "hat Publikationskanal"@de .

ec:hasRelatedPicture a owl:ObjectProperty ;
    rdfs:label "Bild"@de ;
    dcterms:description "So verknüpfen Sie ein Bild mit einem EditorialObject"@de .

ec:hasRelatedPublicationEvent a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "Ereignis der Veröffentlichung"@de ;
    dcterms:description "Um das mit der Ressource verknüpfte Publikationsereignis zu identifizieren."@de .

ec:hasRelatedPublicationService a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "Service für verwandte Publikationen"@de ;
    dcterms:description "Um eine Beziehung zu den Publikationsdiensten herzustellen."@de .

ec:hasResourceOffset a owl:ObjectProperty ;
    rdfs:label "Resourcenausgleich"@de ;
    dcterms:description "Der Start-Offset innerhalb einer Resource."@de .

ec:hasScene a owl:ObjectProperty ;
    rdfs:label "hat Szene"@de ;
    rdfs:subPropertyOf ec:hasPart .

ec:hasSeason a owl:ObjectProperty ;
    rdfs:label "Saison"@de ;
    dcterms:description "Zur Identifizierung von Jahreszeiten in einer Serie."@de .

ec:hasStorageType a owl:ObjectProperty ;
    rdfs:label "Art der Lagerung"@de ;
    dcterms:description "Zur Definition eines Speichertyps, der mit einem Locator verknüpft ist, von dem aus auf eine Resource zugegriffen werden kann oder die abgerufen werden kann."@de .

ec:hasTake a owl:ObjectProperty ;
    rdfs:label "hat angenommen"@de ;
    rdfs:subPropertyOf ec:hasPart .

ec:hasUsageRestrictions a owl:ObjectProperty ;
    rdfs:label "Einschränkungen bei der Verwendung"@de ;
    dcterms:description "Um Nutzungseinschränkungen auszudrücken."@de ;
    rdfs:subPropertyOf ec:hasRights .

ec:isAnimatedBy a owl:ObjectProperty ;
    rdfs:label "wird animiert von"@de ;
    dcterms:description "Charakter, der von einer Person mit Hilfe eines Artefakts animiert wird"@de .

ec:isAwardedTo a owl:ObjectProperty ;
    rdfs:label "verliehen an"@de .

ec:isChildOf a owl:ObjectProperty ;
    rdfs:label "Eltern"@de ;
    dcterms:description "Um ein Konzept mit einem übergeordneten Konzept zu verknüpfen."@de .

ec:isCloneOf a owl:ObjectProperty ;
    rdfs:label "Quelle klonen"@de ;
    dcterms:description "So identifizieren Sie die Quelle einer geklonten MediaResource"@de .

ec:isDefinedBy a owl:ObjectProperty ;
    rdfs:label "Verwandter Vertrag"@de ;
    dcterms:description "Um den Vertrag zu identifizieren, durch den eine Regel definiert wurde definiert wurde."@de .

ec:isDerivedFrom a owl:ObjectProperty ;
    rdfs:label "Abgeleitet von"@de ;
    dcterms:description "Identifiziert eine inhaltsbezogene Beziehung zwischen zwei Resourcen."@de .

ec:isDubOf a owl:ObjectProperty ;
    rdfs:label "Synchronisiert von"@de ;
    dcterms:description "die Herkunft einer überspielten MediaResource."@de .

ec:isInstantiatedBy a owl:ObjectProperty ;
    rdfs:label "Medien Resource"@de ;
    dcterms:description "Um eine MediaResource zu identifizieren, die ein EditorialObject instanziiert."@de .

ec:isMasterOf a owl:ObjectProperty ;
    rdfs:label "Abgeleitete MedienResource"@de ;
    dcterms:description "Um den Master einer abgeleiteten MedienResource zu identifizieren."@de .

ec:isMediaFragmentOf a owl:ObjectProperty ;
    rdfs:label "Quelle des Medienfragments"@de ;
    dcterms:description "So identifizieren Sie die MedienResource, zu der ein Medienfragment gehört"@de .

ec:isOrderedBy a owl:ObjectProperty ;
    rdfs:label "Vertrag"@de ;
    dcterms:description "Der Vertrag, über den ein ProductionJob bestellt wird bestellt wird."@de .

ec:isPartOf a owl:ObjectProperty ;
    rdfs:label "Redaktionelles Objekt"@de ;
    dcterms:description "Um das redaktionelle Objekt zu identifizieren, zu dem ein Teil gehört."@de .

ec:isPortrayedBy a owl:ObjectProperty ;
    rdfs:label "wird porträtiert von"@de ;
    dcterms:description "Beziehung zwischen einer fiktiven Figur und dem Tier, das in der Szene abgebildet ist."@de ;
    owl:inverseOf ec:portrays .

ec:isPreviousInSequence a owl:ObjectProperty ;
    rdfs:label "Vorangehend"@de ;
    dcterms:description "Ein Link zu einem redaktionellen Objekt, das dem aktuellen redaktionellen Objekt in einer geordneten Reihenfolge vorausgeht."@de .

ec:isRequiredBy a owl:ObjectProperty ;
    rdfs:label "Erforderlich"@de ;
    dcterms:description "Um starke Beziehungen zwischen EditorialObjects auszudrücken"@de ;
    owl:inverseOf ec:requires .

ec:isTimelineTrackPartOf a owl:ObjectProperty ;
    rdfs:label "Redaktionelles Objekt"@de ;
    dcterms:description "So verknüpfen Sie ein EditorialObject mit einem Teil der TimelineTrack."@de .

ec:isTrackPartOf a owl:ObjectProperty ;
    rdfs:label "Quelle des Trackings"@de ;
    dcterms:description "Ein Element zur Identifizierung eines Teils eines Titels durch einen Titel, eine Startzeit und eine Endzeit sowohl in der Medienquelle als auch im Medienziel."@de .

ec:isVersionOf a owl:ObjectProperty ;
    rdfs:label "Version von"@de ;
    dcterms:description "Um verwandte Versionen zu identifizieren."@de .

ec:loudnessIntegratedLoudness a owl:DatatypeProperty ;
    rdfs:label "Integrierte Lautstärke"@de ;
    dcterms:description "Der Wert für die integrierte Lautheit, gemessen auf AudioProgramme- oder AudioContent-Ebene."@de ;
    rdfs:range xsd:float .

ec:loudnessMaxMomentary a owl:DatatypeProperty ;
    rdfs:label "Maximale momentane Lautstärke"@de ;
    dcterms:description "Der Wert für die maximale momentane Lautstärke, gemessen auf AudioProgramme- oder AudioContent-Ebene."@de ;
    rdfs:range xsd:float .

ec:loudnessMaxShortTerm a owl:DatatypeProperty ;
    rdfs:label "Maximale Kurzzeit-Lautstärke"@de ;
    dcterms:description "Der Wert für die maximale kurzfristige Lautstärke, gemessen auf der Ebene des AudioProgramms oder AudioContents."@de ;
    rdfs:range xsd:float .

ec:loudnessMaxTruepeak a owl:DatatypeProperty ;
    rdfs:label "Max. wahre Spitzenlautstärke"@de ;
    dcterms:description "Der Wert für die maximale wahre Spitzenlautheit, gemessen auf AudioProgramme- oder AudioContent-Ebene."@de ;
    rdfs:range xsd:float .

ec:loudnessMethod a owl:DatatypeProperty ;
    rdfs:label "Loudness-Methode"@de ;
    dcterms:description "Die Methode zur Messung der Lautheit auf der Ebene des AudioProgramms oder AudioContents."@de ;
    rdfs:range rdfs:Literal .

ec:loudnessRange a owl:DatatypeProperty ;
    rdfs:label "Loudness-Bereich"@de ;
    dcterms:description "Der Lautstärkebereich, gemessen auf der Ebene des AudioProgramms oder des AudioContents."@de ;
    rdfs:range xsd:float .

ec:occursIn a owl:ObjectProperty .

ec:offers a owl:ObjectProperty ;
    rdfs:label "Angebote Service"@de,
        "Veranstaltungen zur Veröffentlichung"@de ;
    dcterms:description "Zur Identifizierung der PublicationEvents, die über einen Dienst."@de .

ec:playbackSpeed a owl:DatatypeProperty ;
    rdfs:label "Wiedergabegeschwindigkeit"@de ;
    dcterms:description "Gibt die Rate der Zeiteinheiten an, in der die Resource für den menschlichen Verzehr wiedergegeben werden soll. Wenn die Maßeinheit bekannt ist, verwenden Sie die Untereigenschaften framesPerSecond oder inchesPerSecond."@de ;
    rdfs:range xsd:double .

ec:playsCharacter a owl:ObjectProperty ;
    rdfs:label "spielt Charakter"@de ;
    dcterms:description "Eine Figur, die von einer Person gespielt wird. Die Beziehung impliziert, dass die Person die geistigen Rechte an der Darstellung der Figur hat."@de .

ec:portrays a owl:ObjectProperty ;
    rdfs:label "porträtiert"@de ;
    dcterms:description "Ein Tier, das als eine andere Figur als sich selbst erscheint."@de .

ec:promotes a owl:ObjectProperty ;
    rdfs:label "fördert"@de ;
    dcterms:description "Der Inhalt wirbt für einen anderen Inhalt"@de .

ec:publishes a owl:ObjectProperty ;
    rdfs:label "Redaktionelles Objekt"@de ;
    dcterms:description "Das redaktionelle Objekt, das mit einem PublicationEvent verbunden ist."@de .

ec:replaces a owl:ObjectProperty ;
    rdfs:label "Ersetzt"@de ;
    dcterms:description "Um die Substitution zu identifizieren."@de .

ec:resolution a owl:DatatypeProperty ;
    rdfs:label "Auflösung"@de ;
    dcterms:description "Zum Festlegen der Auflösung eines Assets, z.B. eines Videos, Bildes..."@de ;
    rdfs:range rdfs:Literal .

ec:timecodeExpression a owl:DatatypeProperty ;
    rdfs:label "Timecode-Ausdruck"@de ;
    dcterms:description "Eine Zeit ausgedrückt als Timecode."@de ;
    rdfs:range xsd:string .

ec:usesProductionDevice a owl:ObjectProperty ;
    rdfs:label "Produktionsgerät"@de ;
    dcterms:description "Um ein ProductionDevice zu identifizieren, das mit einem ProduktionsJob."@de .

xsd:gDay a rdfs:Datatype .

xsd:gMonth a rdfs:Datatype .

xsd:gYear a rdfs:Datatype .

xsd:time a rdfs:Datatype .

xkos:temporal a owl:ObjectProperty ;
    rdfs:label "Zeitliche"@de ;
    rdfs:subPropertyOf xkos:sequential .

ec:AudioTrack a owl:Class ;
    rdfs:label "Audiospur"@de ;
    dcterms:description "Ein audioTrack ist der grundlegende Audiodaten-Container eines Mediums. Ein Attribut ist ein eindeutiger Verweis auf diesen Container in einem bestimmten Medium."@de ;
    rdfs:subClassOf ec:Track .

ec:Captioning a owl:Class ;
    rdfs:label "Untertitel"@de ;
    dcterms:description "Um das Vorhandensein von Schwerhörigkeit zu signalisieren Untertitelung."@de ;
    rdfs:subClassOf ec:Track .

ec:ConsumptionDevice a owl:Class ;
    rdfs:label "Endgerät"@de ;
    dcterms:description "Ein Gerät zur Nutzung eines Medienproduktes."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDeviceProfile ;
            owl:onProperty ec:compliesWith ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasConsumptionDeviceManufacturer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Essence ;
            owl:onProperty ec:renders ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:consumptionDeviceBrand ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:consumptionDeviceBrowser ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:consumptionDeviceModel ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:consumptionDeviceOS ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "ein Gerät zur Nutzung von Mediendiensten"@de ;
    skos:example """- ein Smartphone
- ein Smart-TV-Gerät
- ein UKW-Radio
- ein Beamer, der mit einem Mediensignal gespeist wird und auf eine Leinwand projiziert"""@de .

ec:Contact a owl:Class ;
    rdfs:label "Kontakt"@de ;
    dcterms:description "Ein Kontakt z.B. für eine Person oder Organisation."@de ;
    rdfs:subClassOf ec:Person .

ec:ProductionDevice a owl:Class ;
    rdfs:label "Produktionswerkzeug"@de ;
    dcterms:description "Ein Werkzeug zur Herstellung oder Bearbeitung einer MedienResource."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:OnStagePosition ;
            owl:onProperty ec:hasProductionDeviceOnStagePosition ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasUsageContract ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "ein Werkzeug zur Erleichterung der Aktivitäten im Rahmen einer Produktionsaufgabe"@de ;
    skos:example """- eine Kamera
- ein Mikrofon
- ein Video- oder Tonmischpult
- einen Video- oder Ton-Editor
- Scheinwerfer
- eine LED-Wand"""@de .

ec:PublicationPlan a owl:Class ;
    rdfs:label "Publikationsplan"@de ;
    dcterms:description "Ein Publikationsplan beschreibt eine Zeitplan von Publikationsereignissen und ihre Publika. Die Realisierung eines Publikationsplan erfordert möglicherweise den Einkauf oder die Herstellung von Medienprodukten (Medieninhalt mit Essenz), ausgelöst durch einen Produktionsauftrag. Ein Publikationsplan kann aus mehreren Publikationsplänen zusammengesetzt werden. Beispiele 1: Eine Werbekampagne für ein neues Produkt besteht aus einer Reihe geplanter Veröffentlichungsereignisse. Beispiel 2: Ein Film wird durch mehrere Trailer beworben, bevor er veröffentlicht wird."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasPublicationEvent ;
            owl:someValuesFrom ec:PublicationEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:hasAsset ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionOrder ;
            owl:onProperty ec:hasAssociatedProductionOrder ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasBusinessContract ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlan ;
            owl:onProperty ec:hasPublicationPlanMember ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasStakeholder ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlan ;
            owl:onProperty ec:isMemberOf ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Collection ;
            owl:onProperty ec:hasPublicationPlanStatus ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:publicationPlanTitle ] ;
    skos:definition "ein Zeitplan für eine oder mehrere Publikationsereignissen, um eine Zielgruppe anzusprechen, oder eine Hierarchie von Publikationsereignissen"@de ;
    skos:example """- das geplante Datum, die Uhrzeit und den Kanal für die Veröffentlichung eines Films
- die geplanten Daten, Uhrzeiten und Kanäle für die Veröffentlichung der Episoden einer Serie
- das geplante Programm eines Senders für einen Tag
- die geplanten Daten, Uhrzeiten und Kanäle für eine Sammlung von Inhalten zu einem gemeinsamen Thema"""@de .

ec:Rule a owl:Class ;
    rdfs:label "Regel"@de ;
    dcterms:description "Eine Regel aus gesetzlichen, technischen, inhaltlichen oder regulatorischen Anforderungen."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasPriority ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rule ;
            owl:onProperty ec:hasRelatedRule ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:isDefinedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:ruleStatement ] ;
    skos:definition "eine rechtliche, regulatorische, technische oder redaktionelle Vorgabe"@de ;
    skos:example """- Die Lautstärke der Tonspur muss unter 0 dB liegen.
- die Redezeit bei einer Debatte zwischen zwei Kandidaten muss gleich sein
- der Anteil männlicher/weiblicher Experten in allen Sendungen von BBC One sollte jeweils 50% betragen"""@de .

ec:Season a owl:Class ;
    rdfs:label "Staffel"@de ;
    dcterms:description "Eine Serie kann aus einer oder mehreren Staffeln bestehen die eine bestimmte Anzahl von Episoden zusammenfassen. Aus diesem Grund werden Staffeln mit Serien verknüpft mit Hilfe der Eigenschaft isRelatedTo."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasEpisode ;
            owl:someValuesFrom ec:Programme ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Serial ;
            owl:onProperty ec:hasSerial ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Series ;
            owl:onProperty ec:isSeasonOf ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:seasonNumber ],
        ec:EditorialGroup ;
    skos:definition "eine Gruppe von Episoden einer Serie oder einer Reihe, die in der Regel aufgrund eines gemeinsamen Zeitrahmens für die Produktion gruppiert werden"@de ;
    skos:example """- die 216 Episoden des Jahres 2018 der BBC-Serie "EastEnder"
- Staffel 1 mit 8 Episoden der deutschen Serie "Babylon Berlin\""""@de .

ec:Signing a owl:Class ;
    rdfs:label "Gebärdensprache"@de ;
    dcterms:description "Kennzeichnet die Präsenz von Gebärdensprachdolmetschen im audiovisuellen Inhalt (für gehörlose und schwerhörige Nutzer*innen). Typ (z. B. In-Vision/Einblendung) und Gebärdensprache können über entsprechende Eigenschaften angegeben werden."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:SigningFormat ;
            owl:onProperty ec:hasSigningFormat ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasSigningSource ],
        ec:Track .

ec:Subtitling a owl:Class ;
    rdfs:label "Untertitelung"@de ;
    dcterms:description "Um das Vorhandensein von Untertiteln für die Übersetzung in andere Sprachen."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasSubtitlingSource ],
        ec:Track .

ec:agentEmailAddress a owl:DatatypeProperty ;
    rdfs:label "E-Mail"@de ;
    dcterms:description "Um eine E-Mail-Adresse anzugeben."@de ;
    rdfs:range xsd:string .

ec:agentRelatedLink a owl:DatatypeProperty ;
    rdfs:label "Verwandter Link"@de ;
    dcterms:description "Um einen Link z.B. zu einer Web-Resource im Zusammenhang mit einem Agent bereitzustellen."@de ;
    rdfs:range xsd:anyURI .

ec:encodingLevel a owl:DatatypeProperty ;
    rdfs:label "Kodierungsebene"@de ;
    dcterms:description "Um eine Kodierungsebene zu definieren."@de ;
    rdfs:range rdfs:Literal .

ec:encodingProfile a owl:DatatypeProperty ;
    rdfs:label "Kodierungsprofil"@de ;
    dcterms:description "Das Kodierungsprofil, wie in den Spezifikationen definiert."@de ;
    rdfs:range rdfs:Literal .

ec:gender a owl:DatatypeProperty ;
    rdfs:label "Geschlecht"@de ;
    dcterms:description "Das Geschlecht einer Person, z.B. männlich oder weiblich."@de ;
    rdfs:range rdfs:Literal .

ec:hasContact a owl:ObjectProperty ;
    rdfs:label "Kontakt"@de ;
    dcterms:description "Zur Bereitstellung von Informationen über einen Kontakt für eine Organisation oder eine natürliche Person (z.B. den Agenten eines Schauspielers)."@de .

ec:hasCoverage a owl:ObjectProperty ;
    rdfs:label "Erfassungsbereich"@de ;
    dcterms:description "Zur Bereitstellung von Informationen zum Versicherungsschutz."@de .

ec:hasDateCreated a owl:ObjectProperty ;
    rdfs:label "Erstellungsdatum/-zeit"@de ;
    dcterms:description "Das Datum der Erstellung des Assets."@de ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasEditorialGroup a owl:ObjectProperty ;
    rdfs:label "hat eine Redaktionsgruppe"@de ;
    rdfs:subPropertyOf ec:isMemberOf .

ec:hasEncodingFormat a owl:ObjectProperty ;
    rdfs:label "Format der Kodierung"@de ;
    dcterms:description "Zur Beschreibung eines beliebigen Kodierungsformats, das zur Erstellung von Inhalten verwendet wird."@de ;
    rdfs:subPropertyOf ec:hasFormat .

ec:hasEpisode a owl:ObjectProperty ;
    rdfs:label "Episode"@de ;
    dcterms:description "So identifizieren Sie Episoden einer Serie"@de .

ec:hasLanguage a owl:ObjectProperty ;
    rdfs:label "Sprache"@de ;
    dcterms:description "So verknüpfen Sie eine Sprache mit einem Asset. Es wird ein kontrolliertes Vokabular auf der Grundlage von BCP 47 empfohlen. Diese Eigenschaft kann auch verwendet werden, um das Vorhandensein von Zeichensprache zu identifizieren (RFC 5646). Durch Vererbung gilt die Eigenschaft hasLanguage gleichgültig auf den Ebenen MediaResource / Fragment / Track-Ebene, auf der die Verwendung definiert wird. Die beste Praxis empfiehlt, dass die bestmögliche Granularität zu verwenden, um die Verwendung der Sprache innerhalb einer MediaResource zu beschreiben, auch auf Fragment- und Trackebene."@de .

ec:hasProgramme a owl:ObjectProperty ;
    rdfs:label "hat Programm"@de .

ec:hasPublicationEvent a owl:ObjectProperty ;
    rdfs:label "Ereignis der Veröffentlichung"@de ;
    dcterms:description "Um PublicationEvents zu verknüpfen mit PublicationChannels oder als Elemente einer PublicationHistory oder PublicationPlanning."@de .

ec:hasRelatedEditorialObject a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "Zugehöriges redaktionelles Objekt"@de ;
    dcterms:description "Um verwandte EditorialObjects zu identifizieren."@de .

ec:hasRelatedScene a owl:ObjectProperty ;
    rdfs:label "Verwandte Szene"@de ;
    dcterms:description "So verknüpfen Sie ein Konzept mit einer Szene"@de .

ec:requires a owl:ObjectProperty ;
    rdfs:label "Benötigt"@de ;
    dcterms:description "Um eine Abhängigkeit auszudrücken."@de .

xkos:sequential a owl:ObjectProperty ;
    rdfs:label "sequenziell"@de ;
    rdfs:subPropertyOf skos:related .

ec:BibliographicalObject a owl:Class ;
    rdfs:label "Bibliographisches Objekt"@de ;
    dcterms:description "Dokumente verschiedener Art."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:BibliographicalObject ;
            owl:onProperty ec:references ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:references ],
        ec:Asset .

ec:ConsumptionEvent a owl:Class ;
    rdfs:label "Nutzungsereignis"@de ;
    dcterms:description "Ein Nutzungsereignis repräsentiert die Nutzung eines Medienanproduktes im Rahmen eines Publikationsereignisses. Bei linearen Medienservices finden Nutzungsereignis und Publikationsereignis zur gleichen Zeit statt. Bei nicht-linearen Medienservices entscheidet der Nutzer selbst über den Zeitpunkt des Nutzungsereignisses (im Rahmen des Publikationszeitraums). Das Nutzunsereignis führt zu Resonanzereignissen, die zu Resonanzdaten aggregiert werden."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Essence ;
            owl:onProperty ec:consumesEssence ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Consumer ;
            owl:onProperty ec:hasConsumer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:TimelinePoint ;
            owl:onProperty ec:hasConsumptionEventResumePoint ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDevice ;
            owl:onProperty ec:hasDevice ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionEvent ;
            owl:onProperty ec:hasRelatedConsumptionEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationEvent ;
            owl:onProperty ec:hasRelatedPublicationEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:occursIn ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:occursIn ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlatform ;
            owl:onProperty ec:occursOn ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionLicence ;
            owl:onProperty ec:requiresLicence ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ResonanceEvent ;
            owl:onProperty ec:resultsIn ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Account ;
            owl:onProperty ec:accountingTo ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "das Ereignis, dass ein Nutzer einen Mediendienst konsumiert"@de ;
    skos:example """- eine Person, die eine Nachrichtensendung im linearen Fernsehen sieht
- eine Familie, die beim Frühstück zu Hause lineares Radio hört
- ein Paar auf der Couch im Wohnzimmer, das einen Film von einem VoD-Dienst streamt"""@de .

ec:DataFormat a owl:Class ;
    rdfs:label "Datenformat"@de ;
    dcterms:description "Spezifiziert das verwendete Datenformat der MedienResource."@de ;
    rdfs:subClassOf ec:Format .

ec:Locator a owl:Class ;
    rdfs:label "Locator"@de ;
    dcterms:description "Benutzerdefinierte Attribute müssen von den Implementierern zugewiesen werden."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:locatorTargetInformation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Organisation a owl:Class ;
    rdfs:label "Organisation"@de ;
    dcterms:description "Eine Organisation (Unternehmen, Körperschaft, Verband usw.) oder ein moralischer Akteur (Regierungsstelle)."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Department ;
            owl:onProperty ec:hasDepartment ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:StaffMember ;
            owl:onProperty ec:hasOrganisationStaff ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:StaffMember ;
            owl:onProperty ec:hasStaffMember ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        ec:Agent ;
    skos:definition "ein Agent in Form einer Verwaltungs- und Funktionsstruktur, der an medienbezogenen Aktivitäten beteiligt ist"@de ;
    skos:example """- PSM-Organisationen
- EBU
- Verwertungsgesellschaft
- Filmstudios
- Kinos
- Autorenvereinigung"""@de .

ec:ProductionJob a owl:Class ;
    rdfs:label "Produktionsaufgabe"@de ;
    dcterms:description "Eine Aufgabe oder ein Prozess, der ausgeführt wird, um eine MedienResource oder eine Essenz zu erstellen, zu modifizieren, zu speichern o.ä. MedienResource und Essenz werden gemäß einen Medieninhalt hergestellt. Die Produktionsaufgabe wird durch einen Vertrag beauftragt."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:basedOn ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:createsMetadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Involvement ;
            owl:onProperty ec:hasContributor ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:hasInputMediaResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasInputResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Essence ;
            owl:onProperty ec:hasOutputEssence ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:hasOutputMediaResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasOutputResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionJob ;
            owl:onProperty ec:hasPreviousRelated ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasProductionJobEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasProductionJobLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionJob ;
            owl:onProperty ec:hasSubJob ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:isOrderedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionDevice ;
            owl:onProperty ec:usesProductionDevice ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "eine Aufgabe oder eine Reihe von Aufgaben zum Erstellen, Ändern, Manipulieren, Speichern usw. einer MedienResource"@de ;
    skos:example """- Produktion einer Live-Show für die Ausstrahlung
- das Filmen und Bearbeiten eines Nachrichtenclips
- eine ausgelagerte Produktion eines kompletten Films"""@de .

ec:PublicationPlatform a owl:Class ;
    rdfs:label "Publikationsplattform"@de ;
    dcterms:description "Eine Plattform wie ein Netzwerk oder eine Betreiberplattform."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:accountingTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:hasPublicationChannel ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:hasRelatedPublicationService ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isOwnedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:offers ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDeviceProfile ;
            owl:onProperty ec:supportsConsumptionDeviceProfile ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "eine technische Einrichtung, die es ermöglicht, Quellen und Ziele von MedienResourcen über uni- oder bidirektionale Kanäle zu verbinden"@de ;
    skos:example """- die Eutelsat-DVB-S-Übertragungsplattform
- die youtube-Video-on-Demand-Plattform
- alle Server, die über Internetprotokolle zugänglich sind und in HTML oder ähnlich kodierte Inhalte anbieten/aufnehmen
- Fortnite, Decentraland oder Roblox als Metaversen"""@de .

ec:Take a owl:Class ;
    rdfs:label "Nehmen Sie"@de ;
    dcterms:description "Eine bestimmte Version einer Szene oder einer Bild- oder Tonsequenz, die kontinuierlich zu einem Zeitpunkt fotografiert oder aufgenommen wurde."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasScene ],
        ec:EditorialSegment ;
    skos:definition "eine bestimmte Aufnahme oder Szene aus einer Reihe ähnlicher Aufnahmen für die Auswahl bei der Nachbearbeitung"@de ;
    skos:example "- ein EditorialWork besteht aus ausgewählten Takes, während verworfene Takes manchmal als \"Outtakes\" veröffentlicht werden, wofür sich im Internet leicht Beispiele finden lassen"@de .

ec:accountingTo a owl:ObjectProperty ;
    rdfs:label "Konto"@de ;
    dcterms:description "Ein Verbraucherkonto für einen bestimmten Dienst."@de .

ec:agentLinkedData a owl:DatatypeProperty ;
    rdfs:label "Verknüpfte Daten des Agenten"@de ;
    dcterms:description "Einen Haken für verknüpfte Daten bereitstellen. Bereich: eine URL oder URI."@de ;
    rdfs:range xsd:anyURI .

ec:hasCodec a owl:ObjectProperty ;
    rdfs:label "Codec"@de ;
    dcterms:description "Um einen Codec zu identifizieren, der zur Erstellung einer Resource verwendet wird."@de .

ec:hasDuration a owl:ObjectProperty .

ec:hasLocator a owl:ObjectProperty ;
    rdfs:label "Locator"@de ;
    dcterms:description "Ein Locator, von dem aus auf die Resource zugegriffen werden kann."@de .

ec:hasPart a owl:ObjectProperty ;
    rdfs:label "Teil"@de ;
    dcterms:description "Zur Definition von Teilen (Segmente, Fragmente, Aufnahmen usw.) innerhalb eines EditorialObjects."@de ;
    owl:inverseOf ec:isPartOf .

ec:isOwnedBy a owl:ObjectProperty ;
    rdfs:label "ist Eigentum von"@de ;
    dcterms:description "Zur Identifizierung des Agenten (Kontakt, Person oder Organisation), der Eigentümer einer Marke, eines Veröffentlichungskanals, einer Veröffentlichungsplattform oder eines Veröffentlichungsdienstes ist."@de ;
    owl:inverseOf ec:owns .

ec:title a owl:DatatypeProperty ;
    rdfs:label "Titel"@de ;
    dcterms:description "Alle Werte des EBU-Titelstatus-Klassifizierungsschemas (https://github.com/ebu/ebu_cs/blob/main/metadata/cs/ebu_TitleStatusCodeCS.xml) sind Kandidaten Untereigenschaften der Eigenschaft title, wie sie zum Beispiel mit alternativeTitel."@de ;
    rdfs:range rdfs:Literal .

time:DateTimeDescription a owl:Class ;
    rdfs:label "Datum-Zeit-Beschreibung"@de ;
    dcterms:description "Beschreibung von Datum und Uhrzeit, strukturiert mit separaten Werten für die verschiedenen Elemente eines Kalender-Uhr-Systems. Das zeitliche Bezugssystem ist auf den Gregorianischen Kalender festgelegt und der Bereich der Eigenschaften Jahr, Monat und Tag ist auf die entsprechenden XML-Schema-Typen xsd:gYear, xsd:gMonth bzw. xsd:gDay beschränkt."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:gDay ;
            owl:onProperty time:day ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:gMonth ;
            owl:onProperty time:month ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:gYear ;
            owl:onProperty time:year ],
        time:Instant .

ec:Character a owl:Class ;
    rdfs:label "Rolle"@de ;
    dcterms:description "Z.B. ein fiktiver Kontakt / eine fiktive Person."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasEmbodyingArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Person ;
            owl:onProperty ec:isAnimatedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Involvement ;
            owl:onProperty ec:isPlayedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Animal ;
            owl:onProperty ec:isPortrayedBy ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Person ;
            owl:onProperty ec:hasFictitiousPerson ],
        ec:Person .

ec:Codec a owl:Class ;
    rdfs:label "Codec"@de ;
    dcterms:description "Um Informationen über einen Codec bereitzustellen."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasCodecVendor ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:codecFamily ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:codecVersion ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:EditorialSegment a owl:Class ;
    rdfs:label "Redaktioneller Abschnitt"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:isPartOf ;
            owl:someValuesFrom ec:EditorialObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialGroup ;
            owl:onProperty ec:hasEditorialGroup ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialWork ;
            owl:onProperty ec:hasEditorialWork ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:segmentNumber ],
        ec:EditorialObject ;
    skos:definition "Ein Medieninhalt, der einen Ausschnitt eines anderen Medieninhaltes darstellt"@de ;
    skos:example """- eine Filmszene
- eine Passage eines Interviews
- das Intro eines Liedes
- ein Textabschnitt"""@de .

ec:Language a owl:Class ;
    rdfs:label "Sprache"@de ;
    dcterms:description "Zur Bereitstellung von Informationen über die Sprachen in des EditorialObjects und dessen Zweck. Dies wird als freier Text in einer Beschriftung angegeben. oder als Bezeichner, der auf einen Begriff in einem Klassifikationsschema verweist. spezifische Typen können als Unterklassen von language hinzugefügt werden."@de ;
    rdfs:subClassOf skos:Concept .

ec:Scene a owl:Class ;
    rdfs:label "Szene"@de ;
    dcterms:description "Eine Sequenz mit kontinuierlicher Handlung"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Programme ;
            owl:onProperty ec:hasProgramme ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Shot ;
            owl:onProperty ec:hasShot ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Take ;
            owl:onProperty ec:hasTake ],
        ec:EditorialSegment ;
    owl:disjointWith ec:Shot,
        ec:Take ;
    skos:definition "ein Mediensegment, das in ein Inhaltsobjekt eingebunden ist und einen Teil einer Geschichte ohne Zeit- oder Ortssprünge darstellt"@de ;
    skos:example "- der letzte Abschied von Humphrey Bogart und Ingrid Bergman auf dem Flughafen von Casablanca im gleichnamigen Film."@de .

ec:hasConsumptionCount a owl:ObjectProperty ;
    rdfs:label "hat den Verbrauch gezählt"@de ;
    dcterms:description "Die Anzahl und der Bezug zum echten Publikum."@de .

ec:hasLocation a owl:ObjectProperty ;
    rdfs:label "Standort"@de ;
    dcterms:description "Ein Ort, der mit dem Objekt oder Gegenstand verbunden ist"@de .

ec:hasRelatedArtefact a owl:ObjectProperty ;
    rdfs:label "Verwandtes Artefakt"@de ;
    dcterms:description "Identifizieren eines Artefakts mit Bezug zu einem EditorialObject oder einem Konzept"@de .

ec:hasRelatedEvent a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "verwandtes Ereignis"@de ;
    dcterms:description "ein mit dem Konzept verbundenes Ereignis"@de .

ec:hasRelatedResource a owl:ObjectProperty ;
    rdfs:label "Verwandte Resource"@de ;
    dcterms:description "Um eine Resource zu identifizieren, die mit einem Asset oder einem EditorialObject oder einem PublicationEvent oder einer anderen Resource verbunden ist."@de .

ec:Account a owl:Class ;
    rdfs:label "Nutzerkonto"@de ;
    dcterms:description "Das Konto, unter dem einen Nutzer bei einem Dienst registriert ist. Die registrierten Informationen zum Konto können je nach Service unterschiedlich sein. Beispiele: (Spitz-)name, Login-Name, Alter, Geschlecht, Interessensgebiete, etc."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionLicence ;
            owl:onProperty ec:holdsLicence ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasConsumptionContract ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:hasRelatedAccount ] ;
    skos:definition "eine Registrierungsidentität für einen Mediendienst"@de ;
    skos:example """- ein registrierter Benutzer für den Zugang zu Netflix
- eine registrierte Familie mit Nicknames und Geräten für den Zugang zu einem VOD-Dienst"""@de .

ec:EncodingFormat a owl:Class ;
    rdfs:label "Kodierung"@de ;
    dcterms:description "Eine Definition des Kodierungsformats für Audio und Video. Dies wird als freier Text in einer Beschriftung oder als Bezeichner, der auf einen Begriff in einem Klassifikationsschema verweist, z.B. http://www.ebu.ch/metadata/ontologies/skos/ebu_AudioCompressionCodeCS.rdf oder http://www.ebu.ch/metadata/ontologies/skos/ebu_VideoCompressionCodeCS.rdf."@de ;
    rdfs:subClassOf ec:Format .

ec:Essence a owl:Class ;
    rdfs:label "Essenz"@de ;
    dcterms:description "Die echte physische Repräsentation einer oder mehrerer MedienResourcen, die zur Nutzung bearbeitet wurde. Die Essenz ist eine physische Repräsentation einer MedienResource in einem spezillen Format für die Ausspielung oder Publikation. Essenz ist eine Sub-Klasse von MedienResource und erbt deren Eigenschaften. Essenzen treten auf in Form einfacher Dateien oder komplexer Pakete, z.B. wie es von verschiedenen Kameras verschiedener Hersteller geliefert wird."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationEvent ;
            owl:onProperty ec:hasRelatedPublicationEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:isComposedOf ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:readyForPublication ],
        ec:MediaResource ;
    skos:definition "eine MedienResource in Form einer einfachen Datei oder eines komplexen Dateipakets zur Ausspielung oder Veröffentlichung"@de ;
    skos:example """- eine mxf-Datei
- ein Dateipaket, das von einer Kamera einer bestimmten Marke geliefert wird"""@de .

ec:Programme a owl:Class ;
    rdfs:label "Sendung"@de ;
    dcterms:description "Ein EditorialObject, das einer MediaResource, die zur Veröffentlichung bereit ist."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Season ;
            owl:onProperty ec:isEpisodeOfSeason ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Serial ;
            owl:onProperty ec:isEpisodeOfSerial ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Series ;
            owl:onProperty ec:isEpisodeOfSeries ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:episodeNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:episodeNumberInSeason ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:episodeNumberInSerial ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:episodeNumberInSeries ],
        ec:EditorialWork ;
    skos:definition "ein Werk als eigenständiges Stück oder eine Episode einer Serie oder Reihe, die als Ganzes konsumiert werden soll"@de ;
    skos:example """- den Film "Titanic"
- die Folge 2 "Der blinde Bankier" der Serie "Sherlock", einer Detektivserie
- die heutige Folge von "BBC News", der täglichen Nachrichtensendung
- die Folge 2 "Frozen Worlds" der Serie "Our Planet", einer Naturdokumentationsserie
- am kommenden Montag die Folge der BBC-Serie "Panorama", eine politische Reportage"""@de .

ec:Rating a owl:Class ;
    rdfs:label "Bewertung"@de ;
    dcterms:description "Alle Informationen über die Bewertung/Beurteilung die einer MedienResource von einem Agenten, d.h. einer Person/Kontakt oder Organisation."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Picture ;
            owl:onProperty ec:hasPictogram ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasTerritoryExcludes ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasTerritoryIncludes ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasRatingProvider ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:reason ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingValue ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:notRated ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingScaleMax ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingScaleMin ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingSystemEnvironment ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingSystemName ] .

ec:agentTelephoneNumber a owl:DatatypeProperty ;
    rdfs:label "Telefon"@de ;
    dcterms:description "Zur Angabe der Telefonnummer eines Agenten (Kontaktperson/Person oder Organisation)."@de ;
    rdfs:range xsd:string .

ec:hasEnd a owl:ObjectProperty .

ec:hasStart a owl:ObjectProperty ;
    rdfs:label "Start"@de .

ec:hasTargetAudience a owl:ObjectProperty ;
    rdfs:label "Zielpublikum"@de ;
    dcterms:description "Um das Zielpublikum zu identifizieren, das mit einem PublikationsEreignis."@de,
        "Um ein TargetAudience (z.B. für elterliche Ratschläge oder für eine bestimmte soziale Gruppe) mit einem EditorialObject zu verbinden"@de .

ec:Involvement a owl:Class ;
    rdfs:label "Beteiligung"@de ;
    dcterms:description "Definiert eine Rolle, die ein Akteur übernimmt. Eine Rolle kann durch ein Concept aus SKOS repräsentiert werden."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Rights ;
            owl:onProperty ec:bringsRights ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:OnStagePosition ;
            owl:onProperty ec:hasAgentOnStagePosition ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasAssociatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Character ;
            owl:onProperty ec:playsCharacter ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionDevice ;
            owl:onProperty ec:usesProductionDevice ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "die Beteiligung eines Akteurs an der Erstellung oder Veröffentlichung einer MedienResource"@de ;
    skos:example """- Verfassen eines Drehbuchs für eine Filmproduktion
- Regie bei einem Film
- Tontechnik für eine Talkshow
- Erstellung von Spezialeffekten für einen Film"""@de .

ec:PublicationChannel a owl:Class ;
    rdfs:label "Publikationskanal"@de ;
    dcterms:description "Ein Kanal, über den Inhalte veröffentlicht werden. Er kann eine Vielzahl von Formen annehmen, die über Rundfunk und Internet-Streaming hinausgehen, z. B. den physischen Vertrieb von CDs/DVDs usw."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:accountingTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:hasRelatedPublicationChannel ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:isOperatedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isOwnedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:transports ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "eine Verbindung zum Austausch von Inhalten zwischen Anbieter und Verbraucher, die über eine Publikationsplattform betrieben wird"@de ;
    skos:example """- der DVB-S-Kanal auf 10714 MHz H auf dem Satelliten Astra 2E für den linearen Videodienst "BBC One HD".
- der DVB-T-Kanal E23 in London/Chrystal Palace für den linearen Videodienst "BBC One London".
- den Live-Videostream "BBC One" im Rahmen des BBC iPlayers
- den Kanal @bbcradio1 auf youtube für den On-Demand-Videodienst "BBC Radio 1 visual radio".
- den Kanal @elonmusk auf Twitter für einen sozialen Textdienst "Elon Musk's Tweets"."""@de .

ec:Type a owl:Class ;
    rdfs:label "Typ"@de ;
    dcterms:description "Ein Ausdruck des Typs in Textform oder als Begriff aus einem Klassifikationsschema."@de ;
    rdfs:subClassOf skos:Concept .

ec:agentSocialMedia a owl:DatatypeProperty ;
    rdfs:label "Soziale Medien"@de ;
    dcterms:description "Links zu den sozialen Medien eines Agenten."@de ;
    rdfs:range xsd:anyURI .

ec:isMemberOf a owl:ObjectProperty ;
    rdfs:label "Mitglied von"@de ;
    dcterms:description "So identifizieren Sie einen übergeordneten Veröffentlichungsplan"@de .

ec:Logo a owl:Class ;
    rdfs:label "Logo"@de ;
    dcterms:description "Ein Logo ermöglicht die visuelle Identifizierung einer Organisation, publicationService, publicationChannel oder Bewertungen / parentalGuidance"@de ;
    rdfs:subClassOf ec:Picture .

ec:PublicationEvent a owl:Class ;
    rdfs:label "Publikationsereignis"@de ;
    dcterms:description "Beschreibt die Bereitstellung eines Medieninhaltes und seiner Essenz durch ein beliebiges Medium. Ein Publikationsereignis kann ein geplantes oder ein ungeplantes Ereignis im Rahmen eines linearen Angebot sein, oder eine Abrufmöglichkeit sowie live-streaming im nicht-linearen Angebot."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:AccessConditions ;
            owl:onProperty ec:hasAccessConditions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AlternativeTitle ;
            owl:onProperty ec:hasAlternativeTitle ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionCount ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CoverageRestrictions ;
            owl:onProperty ec:hasCoverageRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:hasPublicationChannel ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationEvent ;
            owl:onProperty ec:hasPublicationEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationMedium ;
            owl:onProperty ec:hasPublicationMedium ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasPublicationRegion ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasRestrictedAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rights ;
            owl:onProperty ec:hasRights ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:UsageRestrictions ;
            owl:onProperty ec:hasUsageRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:isOfferedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Essence ;
            owl:onProperty ec:playsOut ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:publishes ],
        [ a owl:Restriction ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasDuration ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:DateTimeDescription ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasScheduleDate ],
        [ a owl:Restriction ;
            owl:onProperty ec:title ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:abstract ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:firstShowing ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:firstShowingThisService ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:free ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:live ] ;
    owl:disjointWith ec:Rating ;
    skos:definition "das Ereignis der Veröffentlichung einer Essenz durch einen Dienst an einen Kanal unter Rechtebedingungen"@de ;
    skos:example """- die Übertragung des Endspiels der Fußballweltmeisterschaft 2022 in einem Live-Videodienst über Satellit durch die BBC in Großbritannien
- die Veröffentlichung von Elon Musks Text "Next I'm buying Coca Cola to put the cocaine back in" auf Twitter, 27. April 2022, in seinem Kanal @elonmusk"""@de .

ec:alternativeTitleTypes a owl:NamedIndividual,
        skos:ConceptScheme .

ec:hasLogo a owl:ObjectProperty ;
    rdfs:label "Link zum Logo"@de,
        "Logo"@de ;
    dcterms:description "Logos können in einer Vielzahl von Kontexten verwendet werden. Ein Logo kann mit einer Organisation, einem Dienst oder einem Publikationskanal verbunden sein."@de,
        "So erstellen Sie einen Link zu einem Logo"@de .

ec:hasRelatedAgent a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "Verwandter Agent"@de ;
    dcterms:description "Um ein Konzept mit einem Agenten (z.B. einer Person oder einem Charakter) zu verknüpfen."@de ;
    owl:inverseOf ec:isRelatedAgent .

ec:CountryCode a owl:Class ;
    rdfs:label "Ländercode"@de ;
    dcterms:description "So identifizieren Sie ein Land anhand seines ISO-Codes."@de ;
    rdfs:subClassOf skos:Concept .

ec:Event a owl:Class ;
    rdfs:label "Ereignis"@de ;
    dcterms:description "Ein Ereignis, das mit einem Medieninhalt verknüpft ist, z.B. dargestellt in einer Resource (real oder fiktional), etc."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasRelatedEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasLocation ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Person a owl:Class ;
    rdfs:label "Person"@de ;
    dcterms:description "Eine Person."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Affiliation ;
            owl:onProperty ec:hasAffiliation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Picture ;
            owl:onProperty ec:hasIdPicture ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:KeyCareerEvent ;
            owl:onProperty ec:hasKeyCareerEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:KeyPersonalEvent ;
            owl:onProperty ec:hasKeyPersonalEvent ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:CountryCode ;
            owl:onProperty ec:hasCountryOfBirth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:CountryCode ;
            owl:onProperty ec:hasCountryOfDeath ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfBirth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfDeath ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfRetirement ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasPlaceOfBirth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasPlaceOfDeath ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:education ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:familyInformation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:familyName ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:givenName ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:hobbies ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:middleName ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:occupation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:officeEmailAddress ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:officeMobileTelephoneNumber ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:officeTelephoneNumber ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:personWeight ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:privateEmailAddress ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ec:privateHomepage ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:privateMobileTelephoneNumber ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:privateTelephoneNumber ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:salutationTitle ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:suffix ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:username ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:age ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:gender ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:maritalStatus ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:personHeight ],
        ec:Agent ;
    skos:definition "ein einzelner Agent"@de ;
    skos:example """- Alfred Hitchcock (Regisseur)
- James Bond (Figur)
- Sean Connery (Schauspieler)
- John Ford (Pseudonym des Regisseurs John Martin Feeney)"""@de .

ec:Picture a owl:Class ;
    rdfs:label "Bild"@de ;
    dcterms:description "Eine Fotografie, ein Logo, ein Piktogramm, usw."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:EncodingFormat ;
            owl:onProperty ec:hasEncodingFormat ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:ImageCodec ;
            owl:onProperty ec:hasImageCodec ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:ImageFormat ;
            owl:onProperty ec:hasImageFormat ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:aspectRatio ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:frameHeight ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:frameHeightUnit ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:frameWidth ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:frameWidthUnit ],
        ec:Resource ;
    skos:definition "eine Resource in Form eines kodierten Bildes"@de ;
    skos:example """- eine JPEG-Datei eines Fotos, eines Logos, einer Grafik, ...
- eine PNG-Datei eines Fotos, eines Logos, einer Grafik, ..."""@de .

ec:Track a owl:Class ;
    rdfs:label "Spur"@de ;
    dcterms:description "z.B. Audio-, Video-, Timecode- und/oder Datenspuren bilden eine MedienResource."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:hasTrackPart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TrackPurpose ;
            owl:onProperty ec:hasTrackPurpose ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TrackType ;
            owl:onProperty ec:hasTrackType ],
        ec:MediaResource ;
    skos:definition "eine MedienResource in Form von zeitbasierten Elementen für Audio, Video oder Daten (\"Track\"), die in einer \"aggregierten\" MedienResource enthalten sind."@de ;
    skos:example "- das Audio in einer MPEG4-Videodatei"@de .

ec:Artefact a owl:Class ;
    rdfs:label "Artefakt"@de ;
    dcterms:description "Sämtliche Artefakte, die im Rahmen einer Produktion unterschieden werden können, z.B. Produkte, Kostüme, Requisiten"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasArtefactBuyer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasArtefactOwner ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasArtefactRelatedLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PhysicalResource ;
            owl:onProperty ec:hasArtefactRelatedPhysicalResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasArtefactRetailer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasArtefactSupplier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Involvement ;
            owl:onProperty ec:hasCreator ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:hasRelatedEditorialObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasArtefactDateOfPurchase ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasArtefactDateOfSale ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:CurrencyCode ;
            owl:onProperty ec:hasArtefactPriceCurrency ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactAvailability ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactBrand ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactColour ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactComment ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactModel ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactPeriod ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactPriceAmount ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ec:artefactReference ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactStyle ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactUsageHistory ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ec:artefactWebsite ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "ein Ding, das in einer Produktion verwendet wird, oft sichtbar und absichtlich wegen seines Wertes für die Bedeutung des Inhalts ausgewählt"@de ;
    skos:example """- die Kostüme und Requisiten in einem Film
- die nicht-dynamische Kulisse, Stühle, Tische in einer Talkshow"""@de .

ec:Contract a owl:Class ;
    rdfs:label "Vertrag"@de ;
    dcterms:description "Eine Sammlung rechtlicher Regelungen zwischen verschiedenen Parteien und Rechten, die genutzt wird, um die Herstellung von Medieninhalten und ihrer Resourcen/MedienResourcen/Essenzen zu beauftragen. Ein Vertrag deckt den Produktionsauftrag und den Einkaufsauftrag ab. Der Vertrag definiert die Aufteilung der Verwertungsrechte unter den Vertragspartnern."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasContractLink ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ContractCost ;
            owl:onProperty ec:hasContractRelatedCost ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasContractTemplate ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasContractualParty ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "eine Vereinbarung zwischen Parteien oder ein Gesetz über die Rechte und Pflichten bei der Erstellung oder Veröffentlichung von MedienResourcen"@de ;
    skos:example """- ein Vertrag zwischen einem PSM und einer Produktionsfirma über die Lieferung einer Serie
- ein Gesetz über das Urheberrecht von Nachrichtenartikeln"""@de .

ec:EditorialGroup a owl:Class ;
    rdfs:label "Gruppe von Medieninhalten"@de ;
    dcterms:description "Zur Definition einer Sammlung/Gruppe von Medien Resourcen zu definieren, zum Beispiel eine Serie, die aus Episoden besteht."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialGroup ;
            owl:onProperty ec:hasEditorialGroup ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:hasMember ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:totalNumberOfEpisodes ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:totalNumberOfGroupMembers ],
        ec:EditorialObject .

ec:EditorialWork a owl:Class ;
    rdfs:label "Werk"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialGroup ;
            owl:onProperty ec:hasEditorialGroup ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialWork ;
            owl:onProperty ec:hasEditorialWork ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialGroup ;
            owl:onProperty ec:promotes ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialWork ;
            owl:onProperty ec:promotes ],
        ec:EditorialObject ;
    skos:definition "ein Medieninhalt, der ein geistiges Werk, ein \"Stück\" ist"@de ;
    skos:example """- ein Film nach einem Drehbuch
- ein Hörspiel auf der Grundlage eines Spielbuchs
- eine Nachrichtensendung mit mehreren Beiträgen
- ein Beitrag in einer Nachrichtensendung
- eine Folge einer Serie"""@de .

ec:PublicationService a owl:Class ;
    rdfs:label "Medienservice"@de ;
    dcterms:description "Ein Service ist ein Kanal oder eine Publikationsplattform die einem Publikum den Zugriff auf Medienprodukte erlaubt."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:accountingTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MarketingBrand ;
            owl:onProperty ec:hasBrand ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:hasRelatedPublicationService ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasServiceGenre ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isOwnedBy ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "ein Dienst, über den eine Verlagsorganisation oder eine Person ihre MedienResourcen veröffentlicht und den Nutzern Zugang dazu bietet"@de ;
    skos:example """- der lineare Videodienst mit dem Namen "BBC One"
- der Video-on-Demand-Dienst von Netflix"""@de .

ec:references a owl:ObjectProperty ;
    rdfs:label "Referenzen"@de ;
    dcterms:description "Eine verwandte Ressource, auf die von der beschriebenen Ressource verwiesen, die sie zitiert oder auf die sie auf andere Weise verweist."@de .

ec:Resource a owl:Class ;
    rdfs:label "Resource"@de ;
    dcterms:description "Eine Resource, die in einem Arbeitsablauf genutzt oder referenziert wird, z.B. ein Dokument, ein Bild, oder ein beliebiges Objekt einer Sub-Klasse von Resource). Die Resource hat einen Locator, der angibt, wo auf die Resource zugegriffen werden kann."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:AncillaryData ;
            owl:onProperty ec:hasAncillaryData ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Format ;
            owl:onProperty ec:hasFormat ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Locator ;
            owl:onProperty ec:hasLocator ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaFragment ;
            owl:onProperty ec:hasRelatedMediaFragment ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasStorageId ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasStorageType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:isCommissionedBy ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateDeleted ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateValidated ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:fileName ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:double ;
            owl:onProperty ec:fileSize ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:resolution ] ;
    skos:definition "eine Sache, die in einem medienbezogenen Arbeitsablauf erstellt, veröffentlicht, verbreitet und konsumiert wird"@de ;
    skos:example """- ein Papierdokument
- ein digitales Dokument
- ein digitales Bild
- eine Schallplatte
- eine Audio-CD
- eine Audiokassette
- eine Videokassette
- eine Film-DVD"""@de .

ec:hasRights a owl:ObjectProperty ;
    rdfs:label "Wird abgedeckt durch"@de .

ec:Asset a owl:Class ;
    rdfs:label "Asset"@de ;
    dcterms:description "Assets sind Inhaltsobjekte oder Medienobjekte und ihre zugeordneten (Verwertungs-)Rechte. Ein Asset erhält durch die Beauftragung einen Identifikator. Es dient als zentrale Referenz, um die Rechte zu verwalten, die mit Inhaltsobjekten, Medienobjekten, Essenzen sowie Veröffentlichungsereignissen (per Deduktion) verknüpft sind. Achtung: Medienobjekte oder Essenzen werden in diesem Modell immer durch Inhaltsobjekte repräsentiert. Beispiel: CCDM gestattet die Verknüpfung von Verwertungsrechten mit einem Inhaltsobjekt, das von einem oder auch mehreren Essenzen repräsentiert wird."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:derivedTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AccessConditions ;
            owl:onProperty ec:hasAccessConditions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AssetValue ;
            owl:onProperty ec:hasAssetValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:hasChild ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contact ;
            owl:onProperty ec:hasContact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Copyright ;
            owl:onProperty ec:hasCopyright ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CoverageRestrictions ;
            owl:onProperty ec:hasCoverageRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CreativeCommons ;
            owl:onProperty ec:hasCreativeCommons ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Disclaimer ;
            owl:onProperty ec:hasDisclaimer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ExploitationIssues ;
            owl:onProperty ec:hasExploitationIssues ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:IPRRestrictions ;
            owl:onProperty ec:hasIPRRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Licensing ;
            owl:onProperty ec:hasLicensing ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasParticipatingAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:hasRelatedAsset ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AuditReport ;
            owl:onProperty ec:hasRelatedAuditReport ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:hasRelatedEditorialObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Picture ;
            owl:onProperty ec:hasRelatedPicture ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Record ;
            owl:onProperty ec:hasRelatedRecord ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rights ;
            owl:onProperty ec:hasRights ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:RightsClearance ;
            owl:onProperty ec:hasRightsClearance ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:UsageRestrictions ;
            owl:onProperty ec:hasUsageRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:UsageRights ;
            owl:onProperty ec:hasUsageRights ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:isDerivedFrom ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:isReplacedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:replaces ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateArchived ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateCreated ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateDeleted ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateDistributed ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateLicenseEnd ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateLicensedStart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateModified ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateProduced ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateReleased ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Asset ;
            owl:onProperty ec:isChildOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:orderedFlag ] ;
    owl:disjointWith ec:Rating ;
    skos:definition "ein Medienobjekt, das für die Veröffentlichung und den Konsum bestimmt ist, mit Urheberrechten und Copyrights versehen ist und einen Wert darstellt."@de ;
    skos:example """- ein Film auf Band im Archiv
- eine digitale Tonaufnahme mit Urheberrecht und Copyright
- ein Buch
- eine Sammlung von Büchern"""@de .

ec:Rights a owl:Class ;
    rdfs:label "Recht"@de ;
    dcterms:description "Urheber- oder vertragliches Verwertungsrecht an einem Asset, einem Vertrag oder einem Publikationsereignis. Rechte entstammen einem Vertrag. Rechte sind gebunden an einen Medieninhalt, eine MedienResource oder eine Essenz durch die Definition des Assets. Rechte haben zugeordnete Rechteinhaber."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:applyTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contact ;
            owl:onProperty ec:hasContact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRightsHolder ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:hasRightsTargetService ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasRightsTerritoryExcludes ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasRightsTerritoryIncludes ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:originatesFrom ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasDuration ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:publishingEventsLeft ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:rightsExpression ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ec:rightsLink ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:rightsUsageRestrictions ] .

ec:Audience a owl:Class ;
    rdfs:label "Publikum"@de ;
    dcterms:description "Eine Gruppe von Nutzern oder eine Aggregation von Nutzergruppen gebildet durch z.B. Altersklasse, soziale Kategorien o.ä."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:excludesAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:includesAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:audienceAgeHigh ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:audienceAgeLow ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:audienceCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:audienceInterest ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "ein Segment der potenziellen Konsumenten von Mediendiensten, das sich durch Kriterien wie Alter, Bildung, Geschlecht, sozialer Status, Wohnort, Einstellungen usw. auszeichnet, die ihr Konsumverhalten beeinflussen"@de ;
    skos:example """- 14 bis 29 Jahre
- Landjugend
- Männer über 70
- kulturinteressierte Menschen
- Spaßorientierte Menschen
- Eltern von Schulkindern
- Gering gebildete Männer unter 25
- junge progressive Menschen"""@de .

ec:Location a owl:Class ;
    rdfs:label "Ort"@de ;
    dcterms:description "Ein Ort, der mit einer MedienResource verknüpft ist, z.B. darin dargestellt (auch fiktional) oder dort hergestellt (Drehort), etc. Ein Ort definiert den räumliche Bezug der Geschichte oder des Aufnahmeortes in einem Medieninhalt, wie z.b. im Studio, Außenaufnahme."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:LocationCode ;
            owl:onProperty ec:hasLocationCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Picture ;
            owl:onProperty ec:hasLocationPicture ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasRelatedEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:RegionCode ;
            owl:onProperty ec:hasRegionCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:locationAddressMunicipality ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:locationAddressPostalCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:locationAddressStreetName ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:locationAddressApartmentNumber ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:locationAddressArea ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:locationAddressCountry ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:locationAddressHouseNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:locationAltitude ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:locationCoordinateSystemName ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:locationLatitude ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:locationLongitude ] ;
    skos:definition "eine räumliche Zuordnung zu einer medienbezogenen lokalisierbaren Sache"@de ;
    skos:example """- London als Ort, an dem die BBC Nachrichtensendungen produziert
- London als Schauplatz eines Drehbuchs
- London als Ort der öffentlichen Ankündigung des Premierministers in einer BBC-Nachrichtensendung"""@de .

ec:hasEndDateTime a owl:ObjectProperty ;
    rdfs:label "Enddatum Uhrzeit"@de ;
    dcterms:description "Das Ende eines Intervalls beschreiben"@de ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasFormat a owl:ObjectProperty ;
    rdfs:label "Format"@de ;
    dcterms:description "So identifizieren Sie ein Format"@de .

ec:hasStartDateTime a owl:ObjectProperty ;
    rdfs:label "Startdatum Uhrzeit"@de ;
    dcterms:description "Ein Zeitpunkt oder der Beginn eines Intervalls"@de ;
    rdfs:subPropertyOf ec:hasDate .

ec:contentDescription a owl:DatatypeProperty ;
    rdfs:label "Beschreibung des Inhalts"@de ;
    dcterms:description "Dies kann durch die Verwendung von Untereigenschaften spezialisiert werden wie in https://github.com/ebu/ebu_cs/blob/main/metadata/cs/ebu_DescriptionTypeCodeCS.xml definiert als Beispiele implementiert sind, wie z.B. 'summary' oder 'Skript'."@de ;
    rdfs:isDefinedBy <dc:description> ;
    rdfs:range rdfs:Literal .

ec:Format a owl:Class ;
    rdfs:label "Format"@de ;
    dcterms:description "Ein Format wird definiert als eine Sammlung aus Audio-, Video-, Daten- und Containerformaten. Ein Format kann global mit einer MedienResource verknüpft sein, oder auch speziell nach unterschiedlichen Audio-, Video-, Daten- und Containerformaten. Das Containerformat definiert die Datei- bzw. Paketstruktur einer MedienResource."@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Identifier ;
            owl:onProperty ec:hasFormatId ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Identifier ;
            owl:onProperty ec:hasFormatVersionId ],
        skos:Concept .

ec:TimelinePoint a owl:Class ;
    rdfs:label "Punkt auf der Zeitachse"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:equivalentTime ] .


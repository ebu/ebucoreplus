@prefix cc: <http://creativecommons.org/ns#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ec: <http://www.ebu.ch/metadata/ontologies/ebucoreplus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix spin: <http://spinrdf.org/spin#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix xkos: <https://rdf-vocabulary.ddialliance.org/xkos/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cc:licence a owl:AnnotationProperty .

dc:contributor a owl:AnnotationProperty ;
    rdfs:label "Contributeur"@fr ;
    dcterms:description "Un agent qui a participé à une phase quelconque de la gestion d'un actif."@fr .

dc:creator a owl:AnnotationProperty ;
    rdfs:label "Créateur"@fr ;
    dcterms:description "Pour identifier le créateur d'un actif."@fr .

dc:description a owl:AnnotationProperty ;
    rdfs:label "Description"@fr ;
    dcterms:description "Une description d'un actif."@fr .

dc:format a owl:AnnotationProperty ;
    rdfs:label "Format"@fr ;
    dcterms:description "Informations sur le format d'une ressource."@fr .

dc:identifier a owl:AnnotationProperty ;
    rdfs:label "Identifiant"@fr ;
    dcterms:description "Fournir un identifiant simple et non fortement structuré."@fr .

dc:language a owl:AnnotationProperty ;
    rdfs:label "Langue"@fr ;
    dcterms:description "Pour définir les langues associées à une ressource."@fr .

dc:publisher a owl:AnnotationProperty ;
    rdfs:label "Editeur"@fr ;
    dcterms:description "Un agent impliqué dans la distribution de contenu."@fr .

dc:rights a owl:AnnotationProperty .

dc:title a owl:AnnotationProperty ;
    rdfs:label "Titre"@fr ;
    dcterms:description "Le titre par lequel un EditorialObject est connu."@fr .

dc:type a owl:AnnotationProperty ;
    rdfs:label "Type"@fr ;
    dcterms:description "Un concept associé à une ressource."@fr .

dcterms:contributor rdfs:label "Contributeur"@fr ;
    dcterms:description "Dans le contexte d'EBUCore, réservé à l'annotation des propriétés RDF."@fr .

dcterms:description a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

spin:imports a owl:AnnotationProperty .

<http://www.ebu.ch/metadata/ontologies/ebucoreplus> a owl:Ontology ;
    cc:licence "http://creativecommons.org/licenses/by-sa/3.0/" ;
    dc:contributor "Cedric Klein, Perfect Memory"@fr,
        "Guillaume Rachez, Perfect Memory"@fr,
        "Hugo Cordier, SetKeeper"@fr,
        "Ismail Harrendo, Eurecom"@fr,
        "Marc-Antoine Arnaud, Media-IO"@fr,
        "Matthieu Parmentier, francetelevisions"@fr,
        "Raphael Troncy, Eurecom"@fr,
        "Vincent Dabouineau"@fr ;
    vann:preferredNamespaceUri "http://www.ebu.ch/metadata/ontologies/ebucoreplus#" ;
    owl:imports <http://www.w3.org/2004/02/skos/core> ;
    owl:versionIRI <http://www.ebu.ch/metadata/ontologies/ebucoreplus/2.0.0> .

ec:Action a owl:Class ;
    rdfs:label "Action"@fr ;
    dcterms:description "Une classe pour enregistrer les actions."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasRelatedScene ],
        [ a owl:Restriction ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:ActionType a owl:Class ;
    rdfs:label "Type d'action"@fr ;
    dcterms:description "Pour définir un type d'action."@fr ;
    rdfs:subClassOf skos:Concept .

ec:AnnotationType a owl:Class ;
    rdfs:label "Type d'annotation"@fr ;
    dcterms:description "Pour définir un type d'Annotation."@fr ;
    rdfs:subClassOf skos:Concept .

ec:ArtefactType a owl:Class ;
    rdfs:label "Type d'artefact"@fr ;
    dcterms:description "Pour définir un type d'artefact."@fr ;
    rdfs:subClassOf skos:Concept .

ec:AssetType a owl:Class ;
    rdfs:label "Type d'actif"@fr ;
    dcterms:description "Pour définir un type d'actif."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Atmosphere a owl:Class ;
    rdfs:label "Atmosphère"@fr ;
    dcterms:description "Pour décrire un sentiment résumant l'atmosphère."@fr ;
    rdfs:subClassOf ec:Type .

ec:AudienceLevel a owl:Class ;
    rdfs:label "Public cible"@fr ;
    dcterms:description "Le public cible (région cible, catégorie de catégorie de public cible mais aussi recommandation d'orientation parentale) à laquelle la ressource médiatique est destinée."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:targetAudienceSystem ],
        ec:Rating .

ec:AudienceRating a owl:Class ;
    rdfs:label "Classification du public"@fr ;
    dcterms:description "Le public par lequel la ressource peut être vu selon des classements tels que MPAA (http://en.wikipedia.org/wiki/Motion_picture_rating_system) ou d'autres normes organisationnelles / nationales / locales."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasAudienceScoreRecordingTechnique ],
        ec:Rating .

ec:AudienceScoreRecordingTechnique a owl:Class ;
    rdfs:label "Technique d'enregistrement des partitions d'audience"@fr ;
    dcterms:description "Définir la technique utilisée pour mesurer un score d'audience."@fr ;
    rdfs:subClassOf skos:Concept .

ec:AudioChannelFunction a owl:Class ;
    rdfs:label "Fonction de canal audio"@fr ;
    dcterms:description "Pour définir la fonction d'un AudioChannel."@fr ;
    rdfs:subClassOf skos:Concept .

ec:AudioChannelPurpose a owl:Class ;
    rdfs:label "Objectif du canal audio"@fr ;
    dcterms:description "Pour définir l'objectif d'un AudioChannel."@fr ;
    rdfs:subClassOf skos:Concept .

ec:AudioContentType a owl:Class ;
    rdfs:label "Type de contenu audio"@fr ;
    dcterms:description "pour définir un type de AudioContent."@fr ;
    rdfs:subClassOf skos:Concept .

ec:AudioFormat a owl:Class ;
    rdfs:label "Format audio"@fr ;
    dcterms:description "Spécifie le format audio."@fr ;
    rdfs:subClassOf ec:Format .

ec:AudioProgrammeType a owl:Class ;
    rdfs:label "Type de programme audio"@fr ;
    dcterms:description "pour définir un type d'AudioProgramme."@fr ;
    rdfs:subClassOf skos:Concept .

ec:AudioStream a owl:Class ;
    rdfs:label "Flux audio"@fr ;
    dcterms:description "Un AudioStreamFormat décrit un signal décodable - un signal PCM ou un flux Dolby E par exemple. Il est composé d'une ou plusieurs AudioTracks."@fr ;
    rdfs:subClassOf ec:Stream .

ec:AudioTrackPurpose a owl:Class ;
    rdfs:label "Objectif de la piste audio"@fr ;
    dcterms:description "Pour décrire l'objectif d'une piste audio, par exemple le doublage."@fr ;
    rdfs:subClassOf skos:Concept .

ec:AwardType a owl:Class ;
    rdfs:label "Type de prix"@fr ;
    dcterms:description "Pour définir un type d'attribution."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Campaign a owl:Class ;
    rdfs:label "Campagne"@fr ;
    dcterms:description "Une campagne définit une stratégie de publication de contenu (objets éditoriaux et ressources/médias/essence) auprès d'un public cible conformément à un plan de publication. Les stratégies de campagne peuvent être adaptées en fonction l'analyse de la Résonance de la Consommation des Evenements associée ( par exemple le nombre de like ou de téléchargements, etc ...). Les campagnes s'appliquent à différentes stratégies de diffusion, on peut citer par exemple les campagnes publicitaires ou les campagnes promotionnelles."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ResonanceCount ;
            owl:onProperty ec:hasInputResonance ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlan ;
            owl:onProperty ec:hasPublicationPlan ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:title ] ;
    skos:definition "une stratégie de coordination des efforts de publication en direction d'un public cible"@fr ;
    skos:example """- un effort publicitaire pour un produit, en publiant un ensemble de vidéos à un moment et sur un canal, quand et où le public cible peut être atteint efficacement
- une annonce de la couverture journalistique d'une élection gouvernementale à venir sous de nombreux angles différents et pour une variété de publics cibles, publiée sur plusieurs canaux de télévision linéaire, de radio linéaire, de médias sociaux, de portails de podcasts, etc."""@fr .

ec:CityCode a owl:Class ;
    rdfs:label "Code de la ville"@fr ;
    dcterms:description "Pour attribuer un code de ville."@fr ;
    rdfs:subClassOf skos:Concept .

ec:ClosedCaptions a owl:Class ;
    rdfs:label "Légende fermée"@fr ;
    dcterms:description "Le sous-titrage codé est fourni en tant que contenu."@fr ;
    rdfs:subClassOf ec:Captioning .

ec:ClosedSigning a owl:Class ;
    rdfs:label "Signalisation fermée"@fr ;
    dcterms:description "La signalisation fermée est fournie en tant que contenu séparé."@fr ;
    rdfs:subClassOf ec:Signing .

ec:ClosedSubtitling a owl:Class ;
    rdfs:label "Sous-titrage fermé"@fr ;
    dcterms:description "Les sous-titres fermés sont fournis en tant que contenu."@fr ;
    rdfs:subClassOf ec:Subtitling .

ec:Collection a owl:Class ;
    rdfs:label "Collection"@fr ;
    dcterms:description "Un groupe d'EditorialObjects. Il peut y avoir de nombreux types de collections pour lesquelles des sous-classes spécifiques doivent être définies. Dans le monde des archives, une collection correspond à tous les éléments appartenant à un individu / collectionneur."@fr ;
    rdfs:subClassOf ec:EditorialGroup .

ec:CommercialCode a owl:Class ;
    rdfs:label "Code commercial"@fr ;
    dcterms:description "Pour identifier un type de contenu commercial."@fr ;
    rdfs:subClassOf ec:Type .

ec:ContainerFormat a owl:Class ;
    rdfs:label "Format du conteneur"@fr ;
    dcterms:description "Pour définir le format d'un conteneur, par exemple IMF ou MXF. Il fournit des informations sur le format du conteneur / wrapper en complément des informations sur l'encodage du flux fournies dans 'channel', (par exemple mp3, wave, Quicktime, ogg)."@fr ;
    rdfs:subClassOf ec:Format .

ec:ContainerMimeType a owl:Class ;
    rdfs:label "Type Mime du conteneur"@fr ;
    dcterms:description "La définition du conteneur si elle est disponible en tant que un type MIME. Elle est fournie sous forme de texte libre dans une étiquette d'annotation ou comme identifiant pointant vers un terme dans un schéma de classification. Pour plus d'informations : http://www.iana.org/assignments/media-types/application/index.html."@fr ;
    rdfs:subClassOf ec:Format .

ec:ContentAlert a owl:Class ;
    rdfs:label "Alerte de contenu"@fr ;
    dcterms:description "Pour fournir des informations sur un type particulier de contenu potentiellement sensible."@fr ;
    rdfs:subClassOf ec:Type .

ec:ContentEditorialCode a owl:Class ;
    rdfs:label "Code éditorial"@fr ;
    dcterms:description "Pour définir un code de EditorialFormat"@fr ;
    rdfs:subClassOf ec:Type .

ec:ContractType a owl:Class ;
    rdfs:label "Type de contrat"@fr ;
    dcterms:description "Pour définir un type de contrat."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Costume a owl:Class ;
    rdfs:label "Costume"@fr ;
    dcterms:description "Identifier et décrire les costumes utilisés dans les productions."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Sticker ;
            owl:onProperty ec:hasSticker ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:costumeSizeInformation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:costumeTexture ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:gender ],
        ec:Artefact ;
    skos:definition "une robe d'une actrice/acteur utilisée dans une production"@fr ;
    skos:example "- les uniformes portés par l'équipage de Star Trek"@fr .

ec:CostumeType a owl:Class ;
    rdfs:label "Type de costume"@fr ;
    dcterms:description "Pour définir un type de costume."@fr ;
    rdfs:subClassOf skos:Concept .

ec:DepictedEvent a owl:Class ;
    rdfs:label "Événement décrit"@fr ;
    dcterms:description "Un DepictedEVent est un événement fictif, historique ou autre type d'événement auquel le contenu de l'objet éditorial ou de la ressource se rapporte à."@fr ;
    rdfs:subClassOf ec:Event .

ec:EditUnitCount a owl:Class ;
    rdfs:label "Modifier le nombre d'unités"@fr ;
    dcterms:description "Une unité de montage peut être un cadre, un échantillon ou une durée."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:long ;
            owl:onProperty ec:editUnit ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:long ;
            owl:onProperty ec:editUnitNumbering ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        ec:TimelinePoint .

ec:EditorialExtra a owl:Class ;
    rdfs:label "Éditorial Extra"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Programme ;
            owl:onProperty ec:hasProgramme ],
        ec:EditorialWork ;
    skos:definition "une œuvre qui sert de complément facultatif à une œuvre principal et qui vise à expliquer, à divertir, à faire de la publicité ou autre."@fr ;
    skos:example """Contenu supplémentaire pour un film de cinéma: bande-annonce, making of, bonus, outtakes, ...

"BehindTheScenes":
- Un éditorial extra qui rapport une histoire sur scenes de l'œuvre.
- petit film expliquant les scènes de cascades d'un film d'action

"Bonus":
- un Éditorial Extra destiné à enrichir le contenu d'une œuvre principal.
- Contenu additionnel pour un film à consommer séparément en tant que complément.

"Making of":
- Un film documentaire relatant le tournage ou la production d'un film ou d'une œuvre audiovisuelle (téléfilm, série télévisée…), voire d'une autre production artistique (bande dessinée par exemple).

"Outtakes":
- un Éditorial Extra rassemblant des prises de vue ou des scènes qui ont été triées en post-production, mais qui intéressent toujours les consommateurs pour le plaisir, la curiosité, etc.
- un clip avec une collection de chutes sur le DVD bonus d'un film

Bande annonce:
- une Éditorial Extra avec une durée de promotion typique de 2 minutes maximum, promouvant un programme, un feuilleton ou une série à publier dans le futur.
- Séquence AV faisant la promotion d’un film, d'une série ou d’une émission de télévision.
- un aperçu d'une minute de l'épisode de dimanche prochain de la série allemande "Tatort".
- un clip promotionnel pour la finale de la coupe du sport qui aura lieu ce soir"""@fr .

ec:EditorialObjectType a owl:Class ;
    rdfs:label "Type d'objet rédactionnel"@fr ;
    dcterms:description "Pour définir un type d'objet éditorial."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Emotion a owl:Class ;
    rdfs:label "Émotion"@fr ;
    dcterms:description "Une classe pour enregistrer les émotions."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasRelatedScene ],
        [ a owl:Restriction ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:EmotionType a owl:Class ;
    rdfs:label "Type d'émotion"@fr ;
    dcterms:description "Pour définir un type d'émotion."@fr ;
    rdfs:subClassOf skos:Concept .

ec:EventType a owl:Class ;
    rdfs:label "Type d'événement"@fr ;
    dcterms:description "Pour définir un type d'événement."@fr ;
    rdfs:subClassOf skos:Concept .

ec:ExclusivityType a owl:Class ;
    rdfs:label "Type d'exclusivité"@fr ;
    dcterms:description "Définir un type de droits d'exclusivité."@fr ;
    rdfs:subClassOf skos:Concept .

ec:FictionalEvent a owl:Class ;
    rdfs:label "Événement fictif"@fr ;
    dcterms:description "Pour décrire un événement fictif."@fr ;
    rdfs:subClassOf ec:Event .

ec:FictionalLocation a owl:Class ;
    rdfs:label "Lieu fictif"@fr ;
    dcterms:description "Pour décrire un lieu fictif."@fr ;
    rdfs:subClassOf ec:Location .

ec:FictionalOrganisation a owl:Class ;
    rdfs:label "Organisation fictive"@fr ;
    dcterms:description "Pour définir une organisation fictive."@fr ;
    rdfs:subClassOf ec:Organisation .

ec:Food a owl:Class ;
    rdfs:label "Alimentation"@fr ;
    dcterms:description "Pour décrire les aliments montrés ou consommés dans les productions."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasCuisineOrigin ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CuisineStyle ;
            owl:onProperty ec:hasCuisineStyle ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:FoodStyle ;
            owl:onProperty ec:hasFoodStyle ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:foodCategory ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:foodIngredient ],
        ec:Artefact .

ec:Generation a owl:Class ;
    rdfs:label "Génération"@fr ;
    dcterms:description "Identifie la génération d'une version d'une ressource, c'est-à-dire master, edit master, copie de distribution, etc."@fr ;
    rdfs:subClassOf ec:Format .

ec:Genre a owl:Class ;
    rdfs:label "Genre"@fr ;
    dcterms:description "Cette classe est utilisée pour fournir des informations sur le genre de l'EditorialObject. Cette information est fournie sous forme de texte libre dans une étiquette d'annotation ou sous forme d'identificateur pointant vers un terme dans un schéma de classification, par exemple http://www.ebu.ch/metadata/ontologies/skos/ebu_ContentGenreCS.rdf ou http://www.ebu.ch/metadata/ontologies/skos/ebu_EditorialFormatCodeCS.rdf."@fr ;
    rdfs:subClassOf ec:Type .

ec:IdentifierType a owl:Class ;
    rdfs:label "Type d'identifiant"@fr ;
    dcterms:description "Pour définir un type d'identifiant."@fr ;
    rdfs:subClassOf skos:Concept .

ec:IntentionCode a owl:Class ;
    rdfs:label "Code d'intention"@fr ;
    dcterms:description "Pour indiquer le but dans lequel le contenu a été créé."@fr ;
    rdfs:subClassOf ec:Type .

ec:Keyframe a owl:Class ;
    rdfs:label "cadre de la clé"@fr ;
    dcterms:description "Une image clé est une image extraite d'une vidéo, par exemple, représentative d'une partie d'une MediaResource."@fr ;
    rdfs:subClassOf ec:Picture .

ec:LocationType a owl:Class ;
    rdfs:label "Type d'emplacement"@fr ;
    dcterms:description "Pour définir un type d'emplacement."@fr ;
    rdfs:subClassOf skos:Concept .

ec:MediaResourceType a owl:Class ;
    rdfs:label "Type de ressource média"@fr ;
    dcterms:description "Pour définir un type de MediaResource."@fr ;
    rdfs:subClassOf skos:Concept .

ec:MediaType a owl:Class ;
    rdfs:label "Type de média"@fr ;
    dcterms:description "Pour fournir des informations supplémentaires sur le type de support."@fr ;
    rdfs:subClassOf ec:Format .

ec:NormalPlayTime a owl:Class ;
    rdfs:label "Temps de jeu normal"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:isoDuration ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:time ;
            owl:onProperty ec:timeOfDay ],
        ec:TimelinePoint .

ec:OpenCaptions a owl:Class ;
    rdfs:label "Légendes ouvertes"@fr ;
    dcterms:description "Les légendes ouvertes sont gravées dans l l'image."@fr ;
    rdfs:subClassOf ec:Captioning .

ec:OpenSigning a owl:Class ;
    rdfs:label "Signalisation ouverte"@fr ;
    dcterms:description "La signalisation ouverte est gravée dans l'image."@fr ;
    rdfs:subClassOf ec:Signing .

ec:OpenSubtitling a owl:Class ;
    rdfs:label "Ouvrir le sous-titrage"@fr ;
    dcterms:description "Les sous-titres ouverts sont gravés dans l l'image."@fr ;
    rdfs:subClassOf ec:Subtitling .

ec:OriginalLanguage a owl:Class ;
    rdfs:label "Langue"@fr ;
    dcterms:description "La langue d'origine dans laquelle l objet éditorial ou Resource a été créé et diffusé. Elle est fournie sous forme de texte libre dans une étiquette d'annotation ou en tant qu'identifiant pointant vers un terme dans une classification de classification."@fr ;
    rdfs:subClassOf ec:Language .

ec:PartType a owl:Class ;
    rdfs:label "Type de pièce"@fr ;
    dcterms:description "Pour définir un type ou une pièce."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Pictogram a owl:Class ;
    rdfs:label "Pictogramme"@fr ;
    dcterms:description "Une représentation visuelle / graphique d'un concept."@fr ;
    rdfs:subClassOf ec:Picture .

ec:PictureDisplayFormat a owl:Class ;
    rdfs:label "Code du format d'affichage des images"@fr ;
    dcterms:description "Pour définir un code de format d'affichage des images."@fr ;
    rdfs:subClassOf ec:Format .

ec:Props a owl:Class ;
    rdfs:label "Accessoires"@fr ;
    dcterms:description "Identifier et décrire les accessoires utilisés dans les productions (par exemple, les véhicules, les objets de formes et de marques diverses et leur fonction, etc.)"@fr ;
    rdfs:subClassOf ec:Artefact ;
    skos:definition "un artefact délibérément choisi pour apparaître dans une vidéo"@fr ;
    skos:example """- une voiture dans un film
- un meuble dans un film
- un buzzer dans un jeu télévisé"""@fr .

ec:Provenance a owl:Class ;
    rdfs:label "Origine"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty ec:hasProvenanceTarget ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isAttributedTo ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:DateTimeDescription ;
            owl:onProperty ec:hasDateCreated ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:DateTimeDescription ;
            owl:onProperty ec:hasDateModified ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "une chaîne de caractères unique associée à une entité"@fr ;
    skos:example """- la date de création d'un objet de données
- le système à partir duquel l'objet de données a été récupéré à l'origine"""@fr .

ec:Pseudonym a owl:Class ;
    rdfs:label "Pseudonyme"@fr ;
    dcterms:description "un nom fictif ; en particulier : nom de plume ou nom de scène"@fr ;
    rdfs:subClassOf ec:Person .

ec:PublicationChannelType a owl:Class ;
    rdfs:label "Type de canal de publication"@fr ;
    dcterms:description "Pour définir un type de canal de publication."@fr ;
    rdfs:subClassOf skos:Concept .

ec:PublicationEventType a owl:Class ;
    rdfs:label "Type d'événement de publication"@fr ;
    dcterms:description "Pour définir un type d'événement de publication."@fr ;
    rdfs:subClassOf skos:Concept .

ec:PublicationLog a owl:Class ;
    rdfs:label "Journal de bord de la publication"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasResourceOffset ;
            owl:someValuesFrom ec:TimelinePoint ],
        [ a owl:Restriction ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass ec:PublicationEvent ;
            owl:onProperty ec:logs ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ] ;
    skos:definition "une collection de PublicationEvents consécutifs d'un système de diffusion (typiquement linéaire)"@fr ;
    skos:example """- le "journal de bord" d'un système de diffusion TV linéaire pour une journée entière
- le "journal de bord" d'un système de diffusion radio linéaire pour la matinée"""@fr .

ec:PublicationPlanType a owl:Class ;
    rdfs:label "Type de plan de publication"@fr ;
    dcterms:description "Pour définir un type de plan de publication."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Relation a owl:Class ;
    rdfs:label "Relation"@fr ;
    dcterms:description "Pour définir les liens et les relations."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:hasRelationLink ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasRelationSource ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:relationOrderedGroupFlag ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:relationRunningOrderNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:relationTotalNumberOfGroupMembers ] .

ec:RelationType a owl:Class ;
    rdfs:label "Type de relation"@fr ;
    dcterms:description "Pour spécifier un type de relation."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Reminder a owl:Class ;
    rdfs:label "Rappel"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Promotion ;
            owl:onProperty ec:hasPromotion ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CampaignPackage ;
            owl:onProperty ec:isMemberOf ],
        ec:EditorialWork ;
    skos:definition "un EditorialWork faisant référence à une annonce, une promotion ou autre publiée précédemment, pour la rappeler à l'ordre"@fr ;
    skos:example "- une répétition de 4 secondes du logo et du jingle d'une compagnie d'assurance, quelques minutes après une publicité de 15 secondes"@fr .

ec:ResourceType a owl:Class ;
    rdfs:label "Type de Resource"@fr ;
    dcterms:description "Pour définir un type de Resource."@fr ;
    rdfs:subClassOf skos:Concept .

ec:RightsType a owl:Class ;
    rdfs:label "Type de droits"@fr ;
    dcterms:description "Pour définir un type de droits."@fr ;
    rdfs:subClassOf skos:Concept .

ec:SOMEPROGRAMME a ec:EditorialObject,
        owl:NamedIndividual ;
    ec:aspectRatio "16:9" .

ec:ServiceType a owl:Class ;
    rdfs:label "Type de service"@fr ;
    dcterms:description "Pour définir un type de service."@fr ;
    rdfs:subClassOf skos:Concept .

ec:SignLanguageCode a owl:Class ;
    rdfs:label "Code de la langue des signes"@fr ;
    dcterms:description "Identifier une langue des signes par son code."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Team a owl:Class ;
    rdfs:label "Équipe"@fr ;
    dcterms:description "Pour définir une équipe."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Person ;
            owl:onProperty ec:hasTeamMember ],
        ec:Organisation .

ec:Template a owl:Class ;
    rdfs:label "Modèle"@fr ;
    dcterms:description "Une essence définie comme un modèle avec tous les paramètres techniques associés."@fr ;
    rdfs:subClassOf ec:Essence .

ec:TerritoryCode a owl:Class ;
    rdfs:label "Code du territoire"@fr ;
    dcterms:description "Pour identifier un territoire, par exemple par son code ONU."@fr ;
    rdfs:subClassOf skos:Concept .

ec:TextAnnotation a owl:Class ;
    rdfs:label "Annotation de texte"@fr ;
    dcterms:description "Une classe spécifique à l'annotation d'un texte ou de portions de texte."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:characterEndIndex ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:characterStartIndex ],
        ec:Annotation .

ec:TextLineType a owl:Class ;
    rdfs:label "Type de ligne de texte"@fr ;
    dcterms:description "Pour définir un type TextLine."@fr ;
    rdfs:subClassOf skos:Concept .

ec:TextUsageType a owl:Class ;
    rdfs:label "Type d'utilisation du texte"@fr ;
    dcterms:description "Pour spécifier l'usage d'un texte."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Thumbnail a owl:Class ;
    rdfs:label "Vignette"@fr ;
    dcterms:description "Une vignette est une image de faible résolution qui peut être associée à EditorialObjects, par exemple MediaResources ou Contacts."@fr ;
    rdfs:subClassOf ec:Picture .

ec:TimeCode a owl:Class ;
    rdfs:label "Code temporel"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:timecodeExpression ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        ec:TimelinePoint .

ec:TimeCodeDropFrame a owl:Class ;
    rdfs:label "Code temporel avec dropframe"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:timecodeExpression ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        ec:TimelinePoint .

ec:TimedTextAuthoringTechnique a owl:Class ;
    rdfs:label "Technique de création de textes temporisés"@fr ;
    dcterms:description "Définir une technique de création de texte minuté."@fr ;
    rdfs:subClassOf ec:Format .

ec:TimedTextContentType a owl:Class ;
    rdfs:label "Type de contenu texte temporisé"@fr ;
    dcterms:description "Pour définir un type de texte minuté."@fr ;
    rdfs:subClassOf ec:Format .

ec:TimedTextSubtitleTargetFormat a owl:Class ;
    rdfs:label "Format cible des sous-titres en texte minuté"@fr ;
    dcterms:description "Pour définir un format de sous-titres en texte minuté."@fr ;
    rdfs:subClassOf ec:Format .

ec:TimelineTrackType a owl:Class ;
    rdfs:label "Type de piste de la ligne de temps"@fr ;
    dcterms:description "Pour spécifier un type ou un TimelineTrack."@fr ;
    rdfs:subClassOf skos:Concept .

ec:UncertainDate a owl:Class ;
    rdfs:label "Date incertaine"@fr ;
    dcterms:description "La date exprimée sous la forme d'un intervalle entre le début et la fin, pour les dates incertaines. Des informations supplémentaires peuvent être écrites dans la propriété description."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:period ],
        time:Instant ;
    owl:disjointWith time:DateTimeDescription .

ec:VideoFormat a owl:Class ;
    rdfs:label "Format vidéo"@fr ;
    dcterms:description "Spezifiziert das Videoformat der MedienResource."@fr ;
    rdfs:subClassOf ec:Format .

ec:VideoStream a owl:Class ;
    rdfs:label "Flux vidéo"@fr ;
    dcterms:description "Un flux vidéo décodable de bits."@fr ;
    rdfs:subClassOf ec:Stream .

ec:abridgedTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:animates a owl:ObjectProperty ;
    rdfs:label "anime"@fr ;
    dcterms:description "Indique qu'une personne anime un personnage à l’aide d’un artefact, comme une marionnette ou un dispositif d’animation."@fr ;
    owl:inverseOf ec:isAnimatedBy .

ec:commissions a owl:ObjectProperty ;
    owl:inverseOf ec:hasCommissioningContract .

ec:day a owl:DatatypeProperty ;
    rdfs:label "Jour"@fr ;
    rdfs:range xsd:integer .

ec:defines a owl:ObjectProperty ;
    owl:inverseOf ec:isDefinedBy .

ec:formatId a owl:DatatypeProperty ;
    rdfs:label "Id du format"@fr ;
    dcterms:description "Un Id attribué à un Format."@fr ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( xsd:anyURI xsd:string ) ] .

ec:grantsApproval a owl:ObjectProperty ;
    owl:inverseOf ec:hasApprover .

ec:hasAssociatedRelation a owl:ObjectProperty ;
    rdfs:label "Relation"@fr ;
    dcterms:description "Pour définir une Relation."@fr .

ec:hasClip a owl:ObjectProperty ;
    rdfs:label "a un clip"@fr .

ec:hasJob a owl:ObjectProperty ;
    owl:inverseOf ec:isOrderedBy .

ec:hasMemberAudience a owl:ObjectProperty ;
    rdfs:label "Public de membres"@fr ;
    dcterms:description "Pour identifier un membre de l'audience de (inclus dans) l'actuel an groupe d'audience."@fr .

ec:hasParentEditorialSegment a owl:ObjectProperty ;
    rdfs:label "a un segment éditorial parent"@fr .

ec:hasProvenance a owl:ObjectProperty ;
    rdfs:label "Provenance"@fr ;
    dcterms:description "La personne ou l'entreprise qui fournit les métadonnées."@fr,
        "Plage : chaîne, anyURI ou Concept."@fr ;
    owl:inverseOf ec:hasProvenanceTarget .

ec:hasRelatedResonanceEvent a owl:ObjectProperty ;
    rdfs:label "Événement de résonance connexe"@fr ;
    dcterms:description "Pour associer un ResonanceEvent à un EditorialObject."@fr .

ec:isReferencedBy a owl:ObjectProperty ;
    rdfs:label "Source de référence"@fr ;
    dcterms:description "Une ressource connexe qui fait référence, cite ou pointe d’une autre manière vers la ressource décrite."@fr ;
    owl:inverseOf ec:references .

ec:month a owl:DatatypeProperty ;
    rdfs:label "Mois"@fr ;
    rdfs:range xsd:integer .

ec:originalTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:serialTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:seriesTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:subtitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:translationTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:version a owl:DatatypeProperty ;
    rdfs:label "Version"@fr ;
    dcterms:description "Pour fournir des informations sur la version actuelle d'un EditorialObject."@fr ;
    rdfs:range rdfs:Literal .

ec:versionTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

ec:workingTitle a owl:NamedIndividual,
        skos:Concept ;
    skos:inScheme ec:alternativeTitleTypes .

rdfs:example a owl:AnnotationProperty .

rdfs:related a owl:ObjectProperty .

owl:maxQualifiedCardinality a owl:AnnotationProperty .

vs:term_status a owl:AnnotationProperty .

time:TRS a owl:Class ;
    rdfs:label "Système de référence temporel"@fr ;
    dcterms:description "Un système de référence temporel, tel qu'un système de référence à coordonnées temporelles (avec une origine, une direction et une échelle), une combinaison calendrier-horloge ou un système ordinal (éventuellement hiérarchique)."@fr .

<http://www.w3.org/ns/ma-ont#hasPermissions> a owl:ObjectProperty ;
    rdfs:label "Permissions"@fr ;
    dcterms:description "Pour définir les autorisations telles que définies dans l'ontologie des médias du W3C (ma-ont)"@fr ;
    skos:prefLabel "Permissions"^^xsd:string .

xkos:after a owl:ObjectProperty ;
    rdfs:label "après"@fr ;
    rdfs:subPropertyOf xkos:temporal .

xkos:before a owl:ObjectProperty ;
    rdfs:label "avant"@fr ;
    rdfs:subPropertyOf xkos:temporal .

xkos:next a owl:ObjectProperty ;
    rdfs:label "suivant"@fr ;
    rdfs:subPropertyOf xkos:succeeds .

xkos:previous a owl:ObjectProperty ;
    rdfs:label "précédent"@fr ;
    rdfs:subPropertyOf xkos:precedes .

dc:Agent a owl:Class ;
    rdfs:label "Agent"@fr ;
    dcterms:description "une ressource qui agit ou a le pouvoir d'agir."@fr .

dc:date a owl:AnnotationProperty ;
    rdfs:label "Date"@fr ;
    dcterms:description "Une date associée à une ressource."@fr ;
    rdfs:range xsd:date .

dc:source a owl:DatatypeProperty ;
    rdfs:label "Source :"@fr ;
    dcterms:description "Pour identifier une ressource comme étant la source d'une autre Resource."@fr ;
    rdfs:range rdfs:Literal .

ec:ActiveFormatDescriptorCode a owl:Class ;
    rdfs:label "Code du descripteur de format actif"@fr ;
    dcterms:description "Pour définir un code de format actif."@fr ;
    rdfs:subClassOf ec:Format .

ec:Affiliation a owl:Class ;
    rdfs:label "Affiliation"@fr ;
    dcterms:description "Une organisation à laquelle un contact est affilié (avec une période de validité)."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:onClass ec:Organisation ;
            owl:onProperty ec:isAffiliatedTo ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "l'association d'une personne à une organisation pour une période donnée"@fr ;
    skos:example """- l'emploi d'une personne à la BBC, de son embauche à sa retraite
- l'animation d'une émission hebdomadaire de la BBC sur une chaîne de radio pendant 8 ans"""@fr .

ec:AncillaryData a owl:Class ;
    rdfs:label "Données auxiliaires"@fr ;
    dcterms:description "Toute donnée auxiliaire fournie avec le contenu autres que le sous-titrage et le sous-titrage."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:WrappingType ;
            owl:onProperty ec:hasWrappingType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:DID ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:SDID ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:lineNumber ],
        ec:DataTrack .

ec:AncillaryDataFormat a owl:Class ;
    rdfs:label "Format des données auxiliaires"@fr ;
    dcterms:description "Pour définir le format des données auxiliaires telles que les les données patrimoniales qui étaient auparavant transportées dans des intervalles de suppression verticale. Ces données sont fournies sous forme de libre dans une étiquette d'annotation ou comme un identifiant pointant vers un terme dans un schéma de classification. de classification."@fr ;
    rdfs:subClassOf ec:DataFormat .

ec:AnimalBreedCode a owl:Class ;
    rdfs:label "Code de la race animale"@fr ;
    dcterms:description "Pour fournir un code de race pour un animal."@fr ;
    rdfs:subClassOf skos:Concept .

ec:AnimalColourCode a owl:Class ;
    rdfs:label "Code couleur des animaux"@fr ;
    dcterms:description "Pour fournir un code de couleur pour un animal.."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Annotation a owl:Class ;
    rdfs:label "Annotation"@fr ;
    dcterms:description "Une classe utilisée pour annoter les actifs."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasRelatedEvent ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasAnnotationCurationDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasAuthor ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasLocation ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:MediaResource ;
            owl:onProperty ec:isAnnotatedMediaResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:annotationConfidence ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:annotationPurpose ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:annotationSaliency ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasAnnotationAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty ec:hasAnnotationTarget ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ] .

ec:Article a owl:Class ;
    rdfs:label "Article"@fr ;
    rdfs:subClassOf ec:EditorialWork ;
    skos:definition "une œuvre éditoriale composée de texte, de graphiques, parfois de vidéo ou d'audio, créée pour être publiée sur des sites web, des blogs et d'autres canaux similaires aux publications papier plus traditionnelles."@fr ;
    skos:example "- un article de presse sur le site de la BBC"@fr .

ec:AssetValue a owl:Class ;
    rdfs:label "Valeur d'un actif"@fr ;
    dcterms:description "Permet de décrire la valeur d'un actif"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasAssetValueCurrency ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty ec:assetValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:AudioCodec a owl:Class ;
    rdfs:label "Codec audio"@fr ;
    dcterms:description "Pour fournir des informations sur un codec audio."@fr ;
    rdfs:subClassOf ec:Codec .

ec:AudioContent a owl:Class ;
    rdfs:label "Contenu audio"@fr ;
    dcterms:description "Un AudioContent définit un composant d'un programme (par exemple, une musique de fond musique), son association avec un audioGroup (par exemple, un 2.0 audioPackFormat de audioChannelFormats pour la reproduction stéréo), son association avec un audioStreamFormat, et son ensemble de paramètres d'intensité sonore."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessIntegratedLoudness ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxMomentary ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxShortTerm ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxTruepeak ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessRange ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:loudnessMethod ],
        ec:EditorialSegment .

ec:AudioDescription a owl:Class ;
    rdfs:label "Description audio"@fr ;
    dcterms:description "Une piste contenant une description audio."@fr ;
    rdfs:subClassOf ec:AudioTrack .

ec:AudioEncodingFormat a owl:Class ;
    rdfs:label "Format d'encodage audio"@fr ;
    dcterms:description "Le format d'encodage pour l'audio."@fr ;
    rdfs:subClassOf ec:EncodingFormat .

ec:AudioObject a owl:Class ;
    rdfs:label "Objet audio"@fr ;
    dcterms:description "Pour définir un objet audio en référence au Modèle de définition audio (ADM)"@fr ;
    rdfs:subClassOf ec:MediaResource ;
    skos:definition "une ressource média sous la forme d'un objet tel que décrit dans le modèle de définition audio (ADM)"@fr .

ec:AudioProgramme a owl:Class ;
    rdfs:label "Programme audio"@fr ;
    rdfs:isDefinedBy <https://tech.ebu.ch/docs/r/r128.pdf> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessIntegratedLoudness ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxMomentary ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxShortTerm ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessMaxTruepeak ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:loudnessRange ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:loudnessMethod ],
        ec:EditorialWork ;
    skos:definition "Un élément audiovisuel individuel et autonome, ou uniquement audio, destiné à être diffusé à la radio, à la télévision ou sur d'autres supports électroniques. Une publicité (annonce), une bande-annonce, un élément promotionnel (promo), un interstitiel ou un élément similaire (le « contenu court ») est également considéré comme un \"AudioProgramme\" dans ce contexte."@fr .

ec:AuditJob a owl:Class ;
    rdfs:label "Une tâche d'audit"@fr ;
    dcterms:description "L'évaluation de la conformité est effectuée par rapport à une mesure, Measure, associée à une règle, Rule, via un AuditJob."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:AuditReport ;
            owl:onProperty ec:hasAuditJobRelatedAuditReport ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Measure ;
            owl:onProperty ec:usesMeasure ],
        ec:ProductionJob ;
    skos:definition "évaluation de la conformité par rapport à une mesure"@fr ;
    skos:example """- mesurer le niveau de volume maximal de la piste audio d'un fichier vidéo
- mesurer la part du temps de parole dans un débat des candidats avant une élection
- mesurer la part des experts hommes/femmes dans l'ensemble des programmes d'un service de publication"""@fr .

ec:Biography a owl:Class ;
    rdfs:label "Biographie"@fr ;
    dcterms:description "Pour enregistrer une biographie."@fr ;
    rdfs:subClassOf ec:BibliographicalObject .

ec:CaptioningFormat a owl:Class ;
    rdfs:label "Format de sous-titrage"@fr ;
    dcterms:description "Définir le format du sous-titrage. L'utilisation principale du sous-titrage est la transcription pour les malentendants. Celle-ci est fournie sous forme de texte libre dans une étiquette d'annotation ou comme un identifiant pointant vers un terme dans un schéma de classification."@fr ;
    rdfs:subClassOf ec:DataFormat .

ec:CastMember a owl:Class ;
    rdfs:label "Membre de la distribution"@fr ;
    dcterms:description "Un membre de la liste des acteurs (une liste d'interprètes/acteurs et de personnages fictifs associés)."@fr ;
    rdfs:subClassOf ec:Person .

ec:ColourSpace a owl:Class ;
    rdfs:label "Espace couleur"@fr ;
    dcterms:description "L'espace-couleur d'une VideoResource. A espace couleur est défini comme du texte libre dans une étiquette d'annotation ou comme un identifiant pointant vers un terme dans un schéma de classification tel que http://www.ebu.ch/metadata/ontologies/skos/ebu_ColourCodeCS.rdf."@fr ;
    rdfs:subClassOf ec:Format .

ec:Component a owl:Class ;
    rdfs:label "Composant"@fr ;
    dcterms:description "Un composant, par exemple audio, vidéo, données ou autre, ou une MediaResource ou une Essence."@fr ;
    rdfs:subClassOf ec:MediaResource .

ec:ConsumptionCount a owl:Class ;
    rdfs:label "Comptage des consommations"@fr ;
    dcterms:description "Une agrégation de groupes de Consommateurs comptés"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionEvent ;
            owl:onProperty ec:hasConsumptionEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:audienceCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "le nombre réel et les circonstances des ConsumptionEvents pour un seul PublicationEvent"@fr ;
    skos:example """- 46% de part de marché des téléspectateurs français pour la finale de la coupe du monde de football 2022
- 72% de part de marché des téléspectateurs français âgés de 14 à 29 ans pour la finale de la coupe du monde de football 2022
- 18,7 millions de vues en direct des funérailles de l'ancien pape Benoît XVI en Europe
- 36973 vues de la vidéo youtube "Tom Hanks had an ICONIC chat with the Queen" de l'émission "The One Show" de la BBC publiée 6 mois plus tôt
- 2080 personnes présentes à la Liederhalle de Stuttgart pour un concert en direct de l'orchestre symphonique du SWR le 8 avril 2022"""@fr .

ec:ContainerCodec a owl:Class ;
    rdfs:label "Codec de conteneur"@fr ;
    dcterms:description "Pour identifier un codec de conteneur, par exemple MXF"@fr ;
    rdfs:subClassOf ec:Codec .

ec:ContainerEncodingFormat a owl:Class ;
    rdfs:label "Format d'encodage du conteneur"@fr ;
    dcterms:description "Pour définir le format d'encodage du Container."@fr ;
    rdfs:subClassOf ec:EncodingFormat .

ec:ContentEditorialFormat a owl:Class ;
    rdfs:label "Format rédactionnel"@fr ;
    dcterms:description "Pour définir un EditorialFormat"@fr ;
    rdfs:subClassOf ec:Type .

ec:ContractCost a owl:Class ;
    rdfs:label "Coût d'un contrat"@fr ;
    dcterms:description "Permet d'identifier les coûts associés à un contrat."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasContractCostAmountCurrency ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty ec:contractCostAmount ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Copyright a owl:Class ;
    rdfs:label "Copyright"@fr ;
    dcterms:description "Pour fournir un copyright d'auteur."@fr ;
    rdfs:subClassOf ec:Rights .

ec:CreativeCommons a owl:Class ;
    rdfs:label "Creative commons"@fr ;
    dcterms:description "Un ensemble de droits de creative commons."@fr ;
    rdfs:subClassOf ec:Rights .

ec:CrewMember a owl:Class ;
    rdfs:label "Équipe"@fr ;
    dcterms:description "Permet d'identifier un membre d'une équipe."@fr ;
    rdfs:subClassOf ec:Person .

ec:CuisineStyle a owl:Class ;
    rdfs:label "Style de cuisine"@fr ;
    dcterms:description "Pour identifier un style de cuisine."@fr ;
    rdfs:subClassOf skos:Concept .

ec:CurrencyCode a owl:Class ;
    rdfs:label "Code devise"@fr ;
    dcterms:description "Pour identifier une devise par son code ISO."@fr ;
    rdfs:subClassOf skos:Concept .

ec:DID a owl:DatatypeProperty ;
    rdfs:label "DID"@fr ;
    dcterms:description "Le mot Data Identifier (ainsi que le SDID, s'il est utilisé), indique le type de données auxiliaires auquel correspond le paquet au paquet."@fr ;
    rdfs:range xsd:integer .

ec:Department a owl:Class ;
    rdfs:label "Département"@fr ;
    dcterms:description "Un département au sein de l'organisation."@fr ;
    rdfs:subClassOf ec:Organisation .

ec:Disclaimer a owl:Class ;
    rdfs:label "Avis de non-responsabilité"@fr ;
    dcterms:description "Pour fournir une clause de non-responsabilité de toute forme."@fr ;
    rdfs:subClassOf ec:Rights .

ec:Document a owl:Class ;
    rdfs:label "Document"@fr ;
    dcterms:description "Pour décrire une publication sous la forme d'un document, par exemple une page web html (actualité) ou un document pdf, par exemple un script."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:DocumentFormat ;
            owl:onProperty ec:hasDocumentFormat ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EncodingFormat ;
            owl:onProperty ec:hasEncodingFormat ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:wordCount ],
        ec:Resource ;
    skos:definition "une ressource sous forme de texte et/ou de graphiques codés"@fr ;
    skos:example """- un fichier texte
- un livre papier
- une page web ou un bloc réutilisable de celle-ci"""@fr .

ec:DocumentFormat a owl:Class ;
    rdfs:label "Format du document"@fr ;
    dcterms:description "Pour fournir des informations techniques sur le format d'un document tel que l'orientation. Ces informations sont fournies sous forme de texte libre dans une d'une étiquette d'annotation ou comme un identifiant pointant vers un terme dans un de classification."@fr ;
    rdfs:subClassOf ec:Format .

ec:Dopesheet a owl:Class ;
    rdfs:label "Dopesheet"@fr ;
    dcterms:description "Fournit des informations supplémentaires sur un NewsItem, par exemple la date et le lieu, le sujet."@fr ;
    rdfs:subClassOf ec:Document .

ec:EditorialFormat a owl:Class ;
    rdfs:label "Format"@fr ;
    rdfs:subClassOf ec:EditorialGroup ;
    skos:definition "Un groupe éditorial développé avec un style éditorial, une mise en page de contenu, un modérateur, etc. spécifiques, pour cibler un public spécifique. Généralement utilisé pour classer les offres existantes ou en développer de nouvelles."@fr ;
    skos:example """- Un jeu télévisé animé par un animateur spécifique: "Rudis Raterunde"
- Un journal télévisé sur l'Asie: "Asia Report"
- Un journal télévisé du soir: "Tagesschau Main Edition à 20h"
- Une émission de débat en ligne pour les jeunes, avec des spectateurs en direct et un commentaire: "MixTalk\""""@fr .

ec:ExploitationIssues a owl:Class ;
    rdfs:label "Problèmes d'exploitation"@fr ;
    dcterms:description "Mettre en évidence les problèmes potentiels d'exploitation d'exploitation."@fr ;
    rdfs:subClassOf ec:Rights .

ec:FileFormat a owl:Class ;
    rdfs:label "Format de fichier"@fr ;
    dcterms:description "Un format de fichier pour les Resources autres que ressources audiovisuelles. Le format est défini comme texte libre ou pointant sur un terme dans un système de classification, par exemple http://www.ebu.ch/metadata/ontologies/skos/ebu_FileFormatCS.rdf."@fr ;
    rdfs:subClassOf ec:Format .

ec:FoodStyle a owl:Class ;
    rdfs:label "Style alimentaire"@fr ;
    dcterms:description "Pour définir un style d'alimentation."@fr ;
    rdfs:subClassOf skos:Concept .

ec:IPRRestrictions a owl:Class ;
    rdfs:label "Restrictions DPI"@fr ;
    dcterms:description "Fournir des informations sur la propriété intellectuelle."@fr ;
    rdfs:subClassOf ec:Rights .

ec:Item a owl:Class ;
    rdfs:label "Article"@fr ;
    dcterms:description "Un élément, par exemple newsItem ou sportItem"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Article ;
            owl:onProperty ec:hasArticle ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Dopesheet ;
            owl:onProperty ec:hasDopesheet ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Post ;
            owl:onProperty ec:hasPost ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Programme ;
            owl:onProperty ec:hasProgramme ],
        ec:EditorialWork ;
    skos:definition "un travail de rédaction à incorporer dans un programme, un article ou un message."@fr ;
    skos:example """- un article d'actualité à intégrer dans un programme d'information
- un clip d'enquête à intégrer dans un débat"""@fr .

ec:KeyCareerEvent a owl:Class ;
    rdfs:label "Événement de carrière clé"@fr ;
    dcterms:description "Décrire un événement clé de la carrière d'un contact."@fr ;
    rdfs:subClassOf ec:KeyEvent .

ec:KeyPersonalEvent a owl:Class ;
    rdfs:label "Événement personnel clé"@fr ;
    dcterms:description "Un événement personnel clé d'un contact."@fr ;
    rdfs:subClassOf ec:KeyEvent .

ec:Keyword a owl:Class ;
    rdfs:label "Mot-clé"@fr ;
    dcterms:description "Pour fournir des mots-clés et définir des concepts clés illustrant le contenu de la ressource ou de l'objet éditorial. Ceci est fourni sous forme de texte libre libre dans une étiquette d'annotation ou comme identificateur pointant vers un terme dans un schéma de classification. de classification."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Licensing a owl:Class ;
    rdfs:label "Licences"@fr ;
    dcterms:description "Pour définir les conditions de licence associées à un actif."@fr ;
    rdfs:subClassOf ec:Rights .

ec:LocationCode a owl:Class ;
    rdfs:label "Code de localisation."@fr ;
    dcterms:description "Un code donné à un emplacement."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Measure a owl:Class ;
    rdfs:label "Mesure"@fr ;
    dcterms:description "Une mesure associée à une règle, Rule, pour évaluer la conformité à travers des AuditJobs."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasUnit ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rule ;
            owl:onProperty ec:measures ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:measureValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:measureValueMax ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:measureValueMin ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "action de déterminer un nombre et une unité pour répondre à une question donnée, en comptant, comparant, agrégeant ou calculant."@fr ;
    skos:example """- déterminer le niveau de volume d'une piste audio
- compter les minutes dont dispose un orateur pendant un débat
- compter le nombre de femmes expertes dans tous les programmes de BBC One"""@fr .

ec:Medium a owl:Class ;
    rdfs:label "Moyen"@fr ;
    dcterms:description "Fournir des informations sur les formats de support dans lesquels la ressource est disponible. Cette information est fournie sous forme de texte libre dans une étiquette d'annotation ou comme un identifiant pointant vers un terme dans un schéma de classification."@fr ;
    rdfs:subClassOf ec:Format .

ec:MetadataTrack a owl:Class ;
    rdfs:label "Piste de métadonnées"@fr ;
    dcterms:description "Une piste sur laquelle sont intégrées des métadonnées (par exemple, MXF)."@fr ;
    rdfs:subClassOf ec:Track .

ec:PhysicalResource a owl:Class ;
    rdfs:label "Resource physique"@fr ;
    dcterms:description "Pour décrire une ressource physique, par exemple une bande."@fr ;
    rdfs:subClassOf ec:Resource .

ec:Post a owl:Class ;
    rdfs:label "Post"@fr ;
    rdfs:subClassOf ec:EditorialWork ;
    skos:definition "une œuvre éditoriale composée de texte, de graphiques, parfois de vidéo ou d'audio, créée pour être publiée sur des plateformes de médias sociaux ou autres."@fr ;
    skos:example """- un tweet sur Twitter
- une publication sur Facebook
- un post sur Instagram
- une vidéo postée sur Youtube"""@fr .

ec:ProductionOrder a owl:Class ;
    rdfs:label "Commande de production"@fr ;
    dcterms:description "L'acte d'ordonner la création/production, l'achat ou la réutilisation des ressources mediatiques. Les termes d'un commande de production sont définis par Contrat."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasProductionContract ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Promotion a owl:Class ;
    rdfs:label "Promotion"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:CampaignPackage ;
            owl:onProperty ec:isMemberOf ],
        ec:EditorialWork ;
    skos:definition "un EditorialWork à des fins publicitaires"@fr ;
    skos:example """- une publicité pour une compagnie d'assurance
- un clip de promotion pour un GSP, une de ses chaînes, ses marques"""@fr .

ec:PublicationHistory a owl:Class ;
    rdfs:label "Histoire de la publication"@fr ;
    dcterms:description "Une collection de PublicationEvents par lesquels une ressource a été publiée."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasPublicationEvent ;
            owl:someValuesFrom ec:PublicationEvent ] .

ec:PublicationMedium a owl:Class ;
    rdfs:label "Support de publication"@fr ;
    rdfs:subClassOf skos:Concept .

ec:Record a owl:Class ;
    rdfs:label "Enregistrement"@fr ;
    dcterms:description "L'enregistrement de la description d'un actif."@fr ;
    rdfs:subClassOf ec:BibliographicalObject .

ec:RegionCode a owl:Class ;
    rdfs:label "Code de région"@fr ;
    dcterms:description "Le code de région fait référence au code développé par l'Organisation internationale de normalisation (ISO). L'ISO a créé et maintient la norme ISO 3166 - Codes pour la représentation des noms de pays et de leurs subdivisions."@fr ;
    rdfs:subClassOf skos:Concept .

ec:ResonanceCount a owl:Class ;
    rdfs:label "Résonance"@fr ;
    dcterms:description "La raisonance est une agrégation des données relatives à la consommation de contenu par un groupe de consommateurs. Représente toutes les actions de consommation dénombrables ou perceptibles par les consommateurs au cours d'un ConsumptionEvent agrégées pour former une expression non individuelle, par exemple taux de clics, nombre d'appréciations, pourcentage de votes, nombre de téléchargements, likes, pourcentage de votes, nombre de téléchargements. L'analyse des données de résonance permet plus particulièrement d'affiner une stratégie de Campagne et son plan de publication, PublicationPlan."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:ResonanceEvent ;
            owl:onProperty ec:compilesResonanceEvents ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Locator ;
            owl:onProperty ec:hasLocator ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasMeasurementAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "l'agrégation des ResonanceEvents pour indiquer la performance d'un contenu ou d'un service"@fr ;
    skos:example """- part de marché des téléspectateurs sur une émission sportive en direct
- nombre de pages vues par semaine sur un site d'information
- nombre d'utilisateurs uniques quotidiens sur un site d'information
- nombre de likes sur un message instagram
- nombre de vues d'un film sur un portail VOD"""@fr .

ec:Review a owl:Class ;
    rdfs:label "Consulter"@fr ;
    dcterms:description "Pour fournir un examen."@fr ;
    rdfs:subClassOf ec:Item .

ec:RightsClearance a owl:Class ;
    rdfs:label "Apurement des droits"@fr ;
    dcterms:description "Pour signaler que les droits ont été effacés (ou pas)"@fr ;
    rdfs:subClassOf ec:Rights .

ec:SDID a owl:DatatypeProperty ;
    rdfs:label "SDID"@fr ;
    dcterms:description "Mot d'identification de données secondaires pour les données auxiliaires. Identificateur de mode d'envoi. Un identificateur qui indique le moment de la transmission pour les données de sous-titres codés."@fr ;
    rdfs:range xsd:integer .

ec:SigningFormat a owl:Class ;
    rdfs:label "Format de langue des signes"@fr ;
    dcterms:description "Représente le format de l’interprétation en langue des signes dans un contenu audiovisuel (p. ex. incrustation/in-vision, plein écran, superposition, avatar)."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Stage a owl:Class ;
    rdfs:label "Scène"@fr ;
    dcterms:description "Définit une scène."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Locator ;
            owl:onProperty ec:hasLocator ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasStageLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Standard a owl:Class ;
    rdfs:label "Standard"@fr ;
    dcterms:description "identifie la norme technique vidéo d'une ressource, c'est-à-dire NTSC ou PAL."@fr ;
    rdfs:subClassOf ec:Format .

ec:Sticker a owl:Class ;
    rdfs:label "Autocollant"@fr ;
    dcterms:description "Un autocollant associé à un Costume."@fr ;
    rdfs:subClassOf ec:Picture .

ec:StorageType a owl:Class ;
    rdfs:label "Type de stockage"@fr ;
    dcterms:description "Le type de stockage utilisé pour le référentiel. Il est fourni sous forme de texte libre dans une étiquette d'annotation ou sous forme d'identifiant pointant vers un terme dans un schéma de classification."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Subject a owl:Class ;
    rdfs:label "Sujet"@fr ;
    dcterms:description "Un terme décrivant le sujet couvert par l objet éditorial ou la ressource. Il est fourni sous forme de texte libre dans une étiquette d'annotation ou comme un identifiant pointant vers un terme dans un schéma de classification."@fr ;
    rdfs:subClassOf skos:Concept .

ec:SubtitlingFormat a owl:Class ;
    rdfs:label "Format de sous-titrage"@fr ;
    dcterms:description "Définir le format du sous-titrage. L'utilisation principale du sous-titrage est la traduction. Celle-ci est fournie sous forme de texte libre dans une étiquette d'annotation ou comme un identifiant pointant vers un terme dans une classification de classification."@fr ;
    rdfs:subClassOf ec:DataFormat .

ec:TextLine a owl:Class ;
    rdfs:label "Ligne de texte"@fr ;
    dcterms:description "Pour fournir des lignes de texte extraites de la ressource ou complémentaires à celle-ci."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Character ;
            owl:onProperty ec:hasRelatedCharacter ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasRelatedScene ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasTextLineSource ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:artefactBoxHeight ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:artefactBoxTopLeftCornerLineNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:artefactBoxTopLeftCornerPixelNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:artefactBoxWidth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineBoxHeight ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineBoxTopLeftCornerLineNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineBoxTopLeftCornerPixelNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineBoxWidth ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineContent ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:textLineOrder ] .

ec:Theme a owl:Class ;
    rdfs:label "Thème"@fr ;
    dcterms:description "Pour définir un thème associé à un actif."@fr ;
    rdfs:subClassOf skos:Concept .

ec:TimecodeTrack a owl:Class ;
    rdfs:label "Piste de timecode"@fr ;
    dcterms:description "Une piste avec des informations de timecode, par exemple en MXF."@fr ;
    rdfs:subClassOf ec:Track .

ec:Topic a owl:Class ;
    rdfs:label "Sujet"@fr ;
    dcterms:description "Un sujet de type à utiliser dans certains contextes. Ce est fourni comme texte libre dans une étiquette d'annotation ou comme identifiant pointant vers un terme dans un schéma de classification."@fr ;
    rdfs:subClassOf skos:Concept .

ec:TrackPurpose a owl:Class ;
    rdfs:label "Objectif de la voie"@fr ;
    dcterms:description "Définir le purpose d'une piste."@fr ;
    rdfs:subClassOf skos:Concept .

ec:TrackType a owl:Class ;
    rdfs:label "Type de voie"@fr ;
    dcterms:description "Pour définir un type de piste."@fr ;
    rdfs:subClassOf skos:Concept .

ec:UsageRights a owl:Class ;
    rdfs:label "Droits d'utilisation"@fr ;
    dcterms:description "Droits d'utilisation associés au contenu."@fr ;
    rdfs:subClassOf ec:Rights .

ec:VideoCodec a owl:Class ;
    rdfs:label "Codec vidéo"@fr ;
    dcterms:description "Pour fournir des informations sur un codec vidéo."@fr ;
    rdfs:subClassOf ec:Codec .

ec:VideoEncodingFormat a owl:Class ;
    rdfs:label "Format d'encodage vidéo"@fr ;
    dcterms:description "Le format d'encodage de la vidéo."@fr ;
    rdfs:subClassOf ec:EncodingFormat .

ec:VideoTrack a owl:Class ;
    rdfs:label "Piste vidéo"@fr ;
    dcterms:description "Une spécialisation de Track pour la vidéo afin de fournir un lien vers des propriétés de données spécifiques telles que le frameRate, etc. La langue des signes est un autre exemple possible de piste vidéo. Des VideoTracks spécifiques tels que Signing peuvent être définis comme sous-classes. Dans les systèmes avancés, différents VideoTracks peuvent être utilisés pour fournir par exemple différents angles de vue."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty ec:videoTrackNumber ],
        ec:Track .

ec:WrappingType a owl:Class ;
    rdfs:label "Type d'emballage"@fr ;
    dcterms:description "Pour définir un type d'emballage."@fr ;
    rdfs:subClassOf skos:Concept .

ec:age a owl:DatatypeProperty ;
    rdfs:label "Âge"@fr ;
    dcterms:description "L'âge en années d'un contact/personne."@fr ;
    rdfs:range xsd:integer .

ec:agentDbpedia a owl:DatatypeProperty ;
    rdfs:label "DBPedia"@fr ;
    dcterms:description "Un lien vers une page DBPedia."@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentLinkedData .

ec:agentFacebook a owl:DatatypeProperty ;
    rdfs:label "Facebook"@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentFee a owl:DatatypeProperty ;
    rdfs:label "Frais d'agent"@fr ;
    dcterms:description "Les honoraires d'un agent."@fr ;
    rdfs:range rdfs:Literal .

ec:agentFlickr a owl:DatatypeProperty ;
    rdfs:label "Flickr"@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentImdb a owl:DatatypeProperty ;
    rdfs:label "IMDB"@fr ;
    dcterms:description "Un lien vers une page imdb."@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentLinkedData .

ec:agentInstagram a owl:DatatypeProperty ;
    rdfs:label "Instagram"@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentLinkedIn a owl:DatatypeProperty ;
    rdfs:label "LinkedIn"@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentMobileTelephoneNumber a owl:DatatypeProperty ;
    rdfs:label "Mobile"@fr ;
    dcterms:description "Pour fournir le numéro de téléphone mobile d'un Agent (Contact/Personne ou organisation)"@fr ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ec:agentTelephoneNumber .

ec:agentPreviousName a owl:DatatypeProperty ;
    rdfs:label "Nom précédent"@fr ;
    dcterms:description "Pour fournir le nom précédent d'un contact/personne."@fr ;
    rdfs:range rdfs:Literal .

ec:agentRelatedInformationLink a owl:DatatypeProperty ;
    rdfs:label "Lien d'information connexe"@fr ;
    dcterms:description "Pour fournir un lien vers une ressource web contenant des informations relatives à un agent (contact/personne ou organisation)."@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentRelatedLink .

ec:agentRelatedPressLink a owl:DatatypeProperty ;
    rdfs:label "Lien presse connexe"@fr ;
    dcterms:description "Pour fournir un lien vers une ressource web contenant des informations relatives à un agent (contact/personne ou organisation)."@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentRelatedLink .

ec:agentTwitter a owl:DatatypeProperty ;
    rdfs:label "Twitter"@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:agentWikidata a owl:DatatypeProperty ;
    rdfs:label "Wikidata"@fr ;
    dcterms:description "Un lien vers une page de wikidata."@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentLinkedData .

ec:agentWikipedia a owl:DatatypeProperty ;
    rdfs:label "Wikipedia"@fr ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf ec:agentSocialMedia .

ec:animalCharacterName a owl:DatatypeProperty ;
    rdfs:label "Nom du personnage animal"@fr ;
    dcterms:description "Pour associer le nom d'un personnage fictif à un animal."@fr ;
    rdfs:range rdfs:Literal .

ec:animalCode a owl:DatatypeProperty ;
    rdfs:label "Code animal"@fr ;
    dcterms:description "Pour associer un code à un animal."@fr ;
    rdfs:range rdfs:Literal .

ec:animalPassport a owl:DatatypeProperty ;
    rdfs:label "Passeport pour animaux"@fr ;
    dcterms:description "Passeport d'un animal."@fr ;
    rdfs:range rdfs:Literal .

ec:annotationConfidence a owl:DatatypeProperty ;
    rdfs:label "Niveau de confiance dans l'annotation"@fr ;
    dcterms:description "Pour estimer la confiance dans une Annotation."@fr ;
    rdfs:range rdfs:Literal .

ec:annotationPurpose a owl:DatatypeProperty ;
    rdfs:label "Objectif de l'annotation"@fr ;
    dcterms:description "Définir l'objectif d'une annotation."@fr ;
    rdfs:range rdfs:Literal .

ec:annotationSaliency a owl:DatatypeProperty ;
    rdfs:label "Saillance des annotations"@fr ;
    dcterms:description "Pour estimer la saillance d'une Annotation."@fr ;
    rdfs:range rdfs:Literal .

ec:applyTo a owl:ObjectProperty ;
    rdfs:label "Actif"@fr ;
    dcterms:description "L'actif auquel les droits s'appliquent."@fr .

ec:approvedBy a owl:ObjectProperty ;
    rdfs:label "Agent"@fr ;
    dcterms:description "Pour identifier l'agent qui a approuvé la publication de l'objet EditorialObject. La propriété, lorsqu'elle est présente, servira de déclencheur pour la publication de l'objet Editorial."@fr .

ec:artefactAvailability a owl:DatatypeProperty ;
    rdfs:label "Indicateur de disponibilité de l'artefact"@fr ;
    dcterms:description "Pour signaler la disponibilité d'un artefact."@fr ;
    rdfs:range xsd:boolean .

ec:artefactBoxHeight a owl:DatatypeProperty ;
    rdfs:label "Hauteur de la boîte à artefacts."@fr ;
    dcterms:description "La hauteur de la boîte contenant l'artefact."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:artefactBoxTopLeftCornerLineNumber a owl:DatatypeProperty ;
    rdfs:label "Boîte d'artefact coin supérieur gauche position Y."@fr ;
    dcterms:description "Les coordonnées sur un axe vertical de la position du coin supérieur gauche de la boîte contenant l'Artefact."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:artefactBoxTopLeftCornerPixelNumber a owl:DatatypeProperty ;
    rdfs:label "Boîte d'artefact coin supérieur gauche position X."@fr ;
    dcterms:description "Les coordonnées sur un axe horizontal de la position du coin supérieur gauche de la boîte contenant l'Artefact."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:artefactBoxWidth a owl:DatatypeProperty ;
    rdfs:label "Largeur de la boîte à artefacts."@fr ;
    dcterms:description "La largeur de la boîte contenant l'artefact."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:artefactBrand a owl:DatatypeProperty ;
    rdfs:label "Marque d'un artefact"@fr ;
    dcterms:description "Pour spécifier la marque d'un artefact."@fr ;
    rdfs:range rdfs:Literal .

ec:artefactColour a owl:DatatypeProperty ;
    rdfs:label "Couleur(s) de l'artefact"@fr ;
    dcterms:description "Pour ournir le(s) clouleur(s) d'un artefact."@fr ;
    rdfs:range rdfs:Literal .

ec:artefactComment a owl:DatatypeProperty ;
    rdfs:label "Commentaire sur l'artefact"@fr ;
    dcterms:description "Pour fournir un commentaire contextuel sur un artefact."@fr ;
    rdfs:range rdfs:Literal .

ec:artefactModel a owl:DatatypeProperty ;
    rdfs:label "Modèle d'artefact"@fr ;
    dcterms:description "Pour spécifier un modèle d'un artefact."@fr ;
    rdfs:range rdfs:Literal .

ec:artefactPeriod a owl:DatatypeProperty ;
    rdfs:label "Période de l'artefact"@fr ;
    dcterms:description "Pour spécifier la période associée à un artefact."@fr ;
    rdfs:range rdfs:Literal .

ec:artefactPriceAmount a owl:DatatypeProperty ;
    rdfs:label "Prix de l'artefact"@fr ;
    dcterms:description "Pour préciser le prix d'un artefact."@fr ;
    rdfs:range rdfs:Literal .

ec:artefactReference a owl:DatatypeProperty ;
    rdfs:label "Référence de l'artefact"@fr ;
    dcterms:description "Pour spécifier une référence d'un Artefact."@fr ;
    rdfs:range xsd:anyURI .

ec:artefactStyle a owl:DatatypeProperty ;
    rdfs:label "Style de l'artefact"@fr ;
    dcterms:description "Pour spécifier le style associé à un artefact."@fr ;
    rdfs:range rdfs:Literal .

ec:artefactUsageHistory a owl:DatatypeProperty ;
    rdfs:label "Historique de l'utilisation de l'artefact"@fr ;
    dcterms:description "Pour fournir des informations sur l'historique d'utilisation d'un artefact."@fr ;
    rdfs:range rdfs:Literal .

ec:artefactWebsite a owl:DatatypeProperty ;
    rdfs:label "Site web d'Artefact"@fr ;
    dcterms:description "Pour indiquer un site web où l'on peut trouver plus d'informations sur l'artefact."@fr ;
    rdfs:range xsd:anyURI .

ec:assetValue a owl:DatatypeProperty ;
    rdfs:label "Valeur de l'actif"@fr ;
    dcterms:description "Donne la valeur estimée ou réelle d'un actif."@fr .

ec:audienceAgeHigh a owl:DatatypeProperty ;
    rdfs:label "Age maximum du public visé"@fr ;
    dcterms:description "L'âge maximum d'une audience."@fr .

ec:audienceAgeLow a owl:DatatypeProperty ;
    rdfs:label "Âge minimum du public visé."@fr ;
    dcterms:description "L'âge minimum d'une audience."@fr .

ec:audienceInterest a owl:DatatypeProperty ;
    rdfs:label "Intérêt du public"@fr ;
    dcterms:description "Les points d'intérêt d'une audience."@fr .

ec:audioBitRate a owl:DatatypeProperty ;
    rdfs:label "Débit binaire audio"@fr ;
    dcterms:description "Le débit binaire audio."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:audioBitRateMax a owl:DatatypeProperty ;
    rdfs:label "Débit binaire audio max."@fr ;
    dcterms:description "Le débit binaire audio maximal."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:audioBitRateMode a owl:DatatypeProperty ;
    rdfs:label "Mode de débit binaire audio"@fr ;
    dcterms:description "Le mode de débit binaire audio."@fr ;
    rdfs:range rdfs:Literal .

ec:audioEncodingLevel a owl:DatatypeProperty ;
    rdfs:label "Niveau d'encodage audio"@fr ;
    dcterms:description "Le niveau de codage tel que défini dans les spécifications."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:encodingLevel .

ec:audioEncodingProfile a owl:DatatypeProperty ;
    rdfs:label "Profil d'encodage audio"@fr ;
    dcterms:description "Le profil de codage tel que défini dans les spécifications."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:encodingProfile .

ec:audioTrackConfiguration a owl:DatatypeProperty ;
    rdfs:label "Configuration des pistes audio"@fr ;
    dcterms:description "La configuration des pistes audio contenues dans la MediaResource."@fr ;
    rdfs:range rdfs:Literal .

ec:audioTrackNumber a owl:DatatypeProperty ;
    rdfs:label "Numéro de piste audio"@fr ;
    dcterms:description "Permet d’identifier une piste audio parmi plusieurs dans une MediaResource."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:auditReportResults a owl:DatatypeProperty ;
    rdfs:label "Résultats du rapport d'audit"@fr ;
    dcterms:description "Pour exprimer les résultats combinés d'un ou plusieurs AuditJobs."@fr .

ec:awardCeremony a owl:DatatypeProperty ;
    rdfs:label "Cérémonie de remise des prix"@fr ;
    dcterms:description "Pour fournir un nom de cérémonie de remise de prix."@fr ;
    rdfs:range rdfs:Literal .

ec:basedOn a owl:ObjectProperty ;
    rdfs:label "Objet éditorial connexe"@fr ;
    dcterms:description "Pour identifier l'EditorialObject auquel se rapporte un ProductionJob à."@fr .

ec:belongsToAudience a owl:ObjectProperty ;
    rdfs:label "Public de parents"@fr ;
    dcterms:description "Le groupe d'audience parent auquel appartient un consommateur de."@fr .

ec:bitDepth a owl:DatatypeProperty ;
    rdfs:label "Profondeur de bit"@fr ;
    dcterms:description "Pour fournir le nombre bit à laquelle lz MediaResource a été encodée."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:bitRate a owl:DatatypeProperty ;
    rdfs:label "Bitrate"@fr ;
    dcterms:description "Pour fournir le débit binaire auquel la MediaResource peut être lue en bits/seconde. Débit binaire réel si constant, et débit binaire moyen si variable."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:bitRateMax a owl:DatatypeProperty ;
    rdfs:label "Débit binaire maximal"@fr ;
    dcterms:description "Le débit maximal lorsqu'il est variable, en bits par seconde."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:bitRateMode a owl:DatatypeProperty ;
    rdfs:label "Mode de débit binaire"@fr ;
    dcterms:description "Un drapeau pour indiquer si le débit binaire est fixe ou variable."@fr ;
    rdfs:range rdfs:Literal .

ec:bitRateOverall a owl:DatatypeProperty ;
    rdfs:label "Débit binaire global"@fr ;
    dcterms:description "Pour fournir le débit binaire global auquel la MediaResource peut être lue en bits/seconde. Débit binaire réel si constant, et débit binaire moyen si variable."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:bookmark a owl:DatatypeProperty ;
    rdfs:label "Bookmark"@fr ;
    dcterms:description "Pour fournir un signet."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:contentDescription .

ec:bringsRights a owl:ObjectProperty ;
    rdfs:label "Donne des droits"@fr ;
    dcterms:description "Les droits apparaissent comme une conséquence de l'engagement."@fr .

ec:canAccessPublicationChannel a owl:ObjectProperty ;
    rdfs:label "peut accéder au canal de publication"@fr .

ec:canAccessPublicationPlatform a owl:ObjectProperty ;
    rdfs:label "peut accéder à la plateforme de publication"@fr .

ec:characterEndIndex a owl:DatatypeProperty ;
    rdfs:label "Index de début de caractère d'annotation"@fr ;
    dcterms:description "Pour identifier l'indice de caractère de fin de la portion de texte à laquelle s'applique l'annotation."@fr ;
    rdfs:range xsd:integer .

ec:characterStartIndex a owl:DatatypeProperty ;
    rdfs:label "Indice du début du caractère du texte annoté"@fr ;

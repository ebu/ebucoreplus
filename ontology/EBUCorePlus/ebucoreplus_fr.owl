    rdfs:range xsd:integer .

ec:totalNumberOfVideoTracks a owl:DatatypeProperty ;
    rdfs:label "Nombre de pistes vidéo"@fr ;
    dcterms:description "Pour fournir le nombre total de pistes vidéo."@fr ;
    rdfs:range xsd:integer .

ec:transports a owl:ObjectProperty ;
    rdfs:label "Transports"@fr .

ec:username a owl:DatatypeProperty ;
    rdfs:label "Nom d'utilisateur :"@fr ;
    dcterms:description "Le nom d'utilisateur par lequel une personne est connue, par exemple lors de l'attribution d'une valeur d'évaluation."@fr ;
    rdfs:range rdfs:Literal .

ec:usesConsumptionDevice a owl:ObjectProperty ;
    rdfs:label "Dispositif de consommation"@fr ;
    dcterms:description "Plage : chaîne ou ConsumptionDevice"@fr .

ec:usesMeasure a owl:ObjectProperty ;
    rdfs:label "Mesure connexe"@fr ;
    dcterms:description "Pour associer une mesure à un AuditJob."@fr .

ec:videoBitRate a owl:DatatypeProperty ;
    rdfs:label "Débit binaire vidéo"@fr ;
    dcterms:description "Le débit binaire de la vidéo. Pour fournir le débit binaire auquel la MediaResource peut être lue en bits/seconde. Débit binaire actuel si constant, et débit binaire moyen si variable."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:videoBitRateMax a owl:DatatypeProperty ;
    rdfs:label "Débit binaire vidéo max"@fr ;
    dcterms:description "Le débit binaire vidéo maximum."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:videoBitRateMode a owl:DatatypeProperty ;
    rdfs:label "Mode de débit binaire vidéo"@fr ;
    dcterms:description "Le mode de débit binaire vidéo."@fr ;
    rdfs:range rdfs:Literal .

ec:videoDisplay a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Affichage vidéo"@fr ;
    dcterms:description "Un drapeau pour indiquer si le service exige un affichage vidéo."@fr .

ec:videoEncodingLevel a owl:DatatypeProperty ;
    rdfs:label "Niveau d'encodage vidéo"@fr ;
    dcterms:description "Le niveau de codage tel que défini dans les spécifications."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:encodingLevel .

ec:videoEncodingProfile a owl:DatatypeProperty ;
    rdfs:label "Profil d'encodage vidéo"@fr ;
    dcterms:description "Le niveau de codage tel que défini dans les spécifications."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:encodingProfile .

ec:videoTrackNumber a owl:DatatypeProperty ;
    rdfs:label "Numéro de piste vidéo"@fr ;
    dcterms:description "Permet d’identifier une piste vidéo parmi plusieurs dans une MediaResource."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:webcam a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Webcam"@fr ;
    dcterms:description "Un drapeau pour indiquer si le service nécessite une webcam."@fr .

ec:width a owl:DatatypeProperty ;
    rdfs:label "Largeur"@fr ;
    dcterms:description "La largeur d'une image vidéo, par exemple, généralement exprimée en nombre de pixels, ou image/photo en millimètres."@fr ;
    rdfs:range xsd:integer .

ec:widthUnit a owl:DatatypeProperty ;
    rdfs:label "Unité de largeur"@fr ;
    dcterms:description "L'unité utilisée pour mesurer une largeur, par exemple en pixels ou en nombre de lignes ou en millimètres ou autre."@fr ;
    rdfs:range rdfs:Literal .

ec:wordCount a owl:DatatypeProperty ;
    rdfs:label "Nombre de mots"@fr ;
    dcterms:description "Le nombre de mots contenus dans un document."@fr ;
    rdfs:range xsd:integer .

<http://www.opengis.net/def/uom/ISO-8601/0/Gregorian> a owl:NamedIndividual .

xsd:date a rdfs:Datatype .

time:day a owl:DatatypeProperty ;
    rdfs:label "jour"@fr ;
    rdfs:range xsd:gDay .

time:hasTRS a owl:ObjectProperty ;
    rdfs:label "A un TRS"@fr ;
    dcterms:description "Le système de référence temporel utilisé par une description de position ou d'étendue temporelle."@fr .

time:inXSDDateTimeStamp a owl:DatatypeProperty ;
    rdfs:range xsd:dateTimeStamp .

time:month a owl:DatatypeProperty ;
    rdfs:label "mois"@fr ;
    rdfs:range xsd:gMonth .

time:year a owl:DatatypeProperty ;
    rdfs:label "année"@fr ;
    rdfs:range xsd:gYear .

xkos:precedes a owl:ObjectProperty ;
    rdfs:label "précède"@fr ;
    rdfs:subPropertyOf xkos:sequential .

xkos:succeeds a owl:ObjectProperty ;
    rdfs:label "réussit"@fr ;
    rdfs:subPropertyOf xkos:sequential .

ec:AccessConditions a owl:Class ;
    rdfs:label "Conditions d'accès"@fr ;
    dcterms:description "Les conditions dans lesquelles le contenu est accessible."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasGeoBlockingBlacklist ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasGeoBlockingWhitelist ],
        ec:Rights .

ec:AlternativeTitle a owl:Class ;
    rdfs:label "Titre alternatif"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:onProperty ec:title ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Animal a owl:Class ;
    rdfs:label "Animal"@fr ;
    dcterms:description "Pour identifier un animal."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:AnimalBreedCode ;
            owl:onProperty ec:hasAnimalBreedCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AnimalColourCode ;
            owl:onProperty ec:hasAnimalColourCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasAnimalGroom ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Involvement ;
            owl:onProperty ec:hasAnimalRole ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasOwner ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Character ;
            owl:onProperty ec:portrays ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfBirth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfDeath ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:animalCharacterName ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:animalCode ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:animalPassport ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:gender ] .

ec:AuditReport a owl:Class ;
    rdfs:label "Rapport d'audit"@fr ;
    dcterms:description "Un rapport d'audit regroupe les résultats des tâche de contrôle auxquelles il est lié."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasApprover ],
        [ a owl:Restriction ;
            owl:allValuesFrom time:Instant ;
            owl:onProperty ec:hasAuditReportDate ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AuditJob ;
            owl:onProperty ec:hasRelatedAuditJob ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rule ;
            owl:onProperty ec:referencesRule ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:auditReportResults ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Award a owl:Class ;
    rdfs:label "Prix"@fr ;
    dcterms:description "Pour décrire un prix et les informations associées."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasRelatedEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isAwardedTo ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasAwardDate ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:awardCeremony ] .

ec:CampaignPackage a owl:Class ;
    rdfs:label "Paquet de campagne"@fr ;
    rdfs:subClassOf ec:EditorialGroup ;
    skos:definition "un groupe d'EditorialObjects pour faire la publicité d'un produit, d'un service, d'un événement ..."@fr ;
    skos:example """- un ensemble de publicités différentes pour un produit
- un ensemble de bandes-annonces différentes pour un film"""@fr .

ec:Consumer a owl:Class ;
    rdfs:label "Consommateur"@fr ;
    dcterms:description "Un individu qui consomme le service en utilisant un ConsumptionDevice. Le Consommateur peut être associé à une Audience. Ses actions conduisent à des données autour des ConsumptionEvents et des ResonanceEvents associés. Un consommateur peut être enregistré auprès d'un service par le biais d'un compte contenant des informations plus ou moins détaillées sur ce consommateur (par exemple, âge, sexe, situation matrimoniale, adresse). Ces informations sont définies plus précisément dans la licence de consommation, le cas échéant."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:belongsToAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionEvent ;
            owl:onProperty ec:hasAssociatedConsumptionEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:hasRegistration ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDevice ;
            owl:onProperty ec:usesConsumptionDevice ],
        ec:Person ;
    skos:definition "une personne consommant un service de médias"@fr ;
    skos:example """- un auditeur de radio
- un spectateur de flux vidéo"""@fr .

ec:ConsumptionDeviceProfile a owl:Class ;
    rdfs:label "Profile d'un appareil de consommation"@fr ;
    dcterms:description "Profile d'un appareil permettant de consommer du contenu médiatique. Cela peut-être un nom de modèle avec une version de hardware ou de software."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:canAccessPublicationChannel ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlatform ;
            owl:onProperty ec:canAccessPublicationPlatform ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasGeoLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:internetConnectivity ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:microphone ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:radioTuner ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:soundOutput ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:textInput ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:timeshift ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:videoDisplay ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:webcam ] ;
    skos:definition "un certain nombre de propriétés d'un appareil de consommation individuel qui permettent la classification du dispositif"@fr ;
    skos:example """- un smartphone Apple avec une version iOS > 16
- une smart TV avec un écran de 50' à 60' et supportant le HDR
- un casque VR"""@fr .

ec:ConsumptionLicence a owl:Class ;
    rdfs:label "Licence de consommation"@fr ;
    dcterms:description "Licence attribuée à un consommateur, Consumer, définissant les conditions de consommation d'un contenu. La licence de consommation, ConsumptionLicence, est vérifiée par un mécanisme généralement situé dans l'appareil, Device, et appelé DRM (Digital Rights Management)"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDevice ;
            owl:onProperty ec:coversConsumptionDevice ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Contract ;
            owl:onProperty ec:hasConsumptionLicenceLink ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:consumptionLicenceText ] ;
    skos:definition "un permis de consommer un service de médias"@fr ;
    skos:example """- un abonnement au streaming illimité de spotify, englobant 3 appareils
- un abonnement d'essai de 3 mois à un service de VoD
- le droit de consommer des services de radiodiffusion en clair en tant que résident d'un pays."""@fr .

ec:CoverageRestrictions a owl:Class ;
    rdfs:label "Restrictions de couverture"@fr ;
    dcterms:description "Fournir des informations sur les éventuelles restrictions concernant la couverture temporelle et spatiale pour la publication."@fr ;
    rdfs:subClassOf ec:Rights .

ec:DataTrack a owl:Class ;
    rdfs:label "Suivi des données"@fr ;
    dcterms:description "Piste de données auxiliaires, par exemple le \"sous-titrage\" ou le \"captioning\". ou \"sous-titrage\" en plus des pistes vidéo et audio."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:DataFormat ;
            owl:onProperty ec:hasDataFormat ],
        ec:Track .

ec:ImageCodec a owl:Class ;
    rdfs:label "Codec d'image"@fr ;
    dcterms:description "pour identifier un codec pour les images"@fr ;
    rdfs:subClassOf ec:Codec .

ec:ImageFormat a owl:Class ;
    rdfs:label "Format de l'image"@fr ;
    dcterms:description "Pour fournir des informations techniques sur le format d'une image, comme l'orientation. Ces informations sont fournies sous forme de texte libre dans une d'annotation ou comme identifiant pointant vers un terme dans un schéma de classification. de classification."@fr ;
    rdfs:subClassOf ec:Format .

ec:KeyEvent a owl:Class ;
    rdfs:label "Événement clé"@fr ;
    dcterms:description "Pour décrire un événement important."@fr ;
    rdfs:subClassOf ec:Event .

ec:MarketingBrand a owl:Class ;
    rdfs:label "Marque"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isOwnedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "un nom, souvent accompagné d'un logo, et donné à un bien ou à un service ou à un groupe de ceux-ci pour les distinguer des biens ou des services fournis par d'autres fabricants ou commerçants."@fr ;
    skos:example """- le nom d'une organisation PSM : "BBC"
- le nom d'une chaîne média : "BBC4"
- le nom d'une série : "Downton Abbey"
- le nom d'une série : "BBC News\""""@fr .

ec:MediaFragment a owl:Class ;
    rdfs:label "Fragment de média"@fr ;
    dcterms:description "Un MediaFragment est un segment temporel ou spatial d'une ressource identifiée par un URI MediaGragment (http://www.w3.org/2008/WebVideo/Fragments/WD-media-fragments-spec/)."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:isMediaFragmentOf ],
        ec:MediaResource ;
    skos:definition "une ressource média qui est un segment temporel ou spatial d'une ressource telle que définie par un URI MediaFragment (http://www.w3.org/2008/WebVideo/Fragments/WD-media-fragments-spec/)."@fr .

ec:MimeType a owl:Class ;
    rdfs:label "Type Mime"@fr ;
    dcterms:description "La définition du conteneur si elle est disponible en tant que un type MIME. Elle est fournie sous forme de texte libre dans une étiquette d'annotation ou comme identifiant pointant vers un terme dans un schéma de classification. Pour plus d'informations : http://www.iana.org/assignments/media-types/index.html."@fr ;
    rdfs:subClassOf ec:Format .

ec:OnStagePosition a owl:Class ;
    rdfs:label "Position sur scène"@fr ;
    dcterms:description "Spécifie la position d'un agent, Agent, ou d'un appareil de production, ProductionDevice sur la scène, Stage."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Stage ;
            owl:onProperty ec:hasRelatedStage ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty ec:onStagePositionCoordinateX ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty ec:onStagePositionCoordinateY ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty ec:onStagePositionCoordinateZ ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:onStagePositionCoordinatesReferencePoint ] .

ec:ResonanceEvent a owl:Class ;
    rdfs:label "Événement de résonance"@fr ;
    dcterms:description """Un évènement de résonance est défini comme des données relatives à la consommation de contenu par un consommateur utilisant un dispositif de consommation particulier.
Ces données représente toutes les actions individuelles comptabilisables ou perceptibles par les consommateurs au cours d'un ConsumptionEvent utilisant un ConsumptionDevice particulier, par exemple clics, likes, commentaires, votes, préférences tweets, téléchargements.
Tous les ResonanceEvents sont liés à un ConsumptionEvent et à l'Essence associée ou à l'EditorialObject associé.
Les ResonanceEvents représentent des données brutes, qui doivent être agrégées (par exemple, additionnées). Ces données peuvent être considérées comme des "big data" et nécessitent une technologie et des techniques appropriées (par exemple, des algorithmes de traitement).
L'agrégation de ces données est un ensemble de résultats de résonance."""@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:ConsumptionEvent ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:EditorialObject ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:PublicationChannel ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:PublicationEvent ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:PublicationPlatform ],
        [ a owl:Restriction ;
            owl:onProperty ec:references ;
            owl:someValuesFrom ec:PublicationService ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Consumer ;
            owl:onProperty ec:hasAssociatedConsumer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Locator ;
            owl:onProperty ec:hasLocator ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "une action liée à la consommation, dénombrable ou perceptible, effectuée par un consommateur pendant ou après un événement de consommation."@fr ;
    skos:example """- éteindre le téléviseur
- passer à une autre chaîne de radio
- mettre en pause la lecture d'une vidéo provenant d'un portail VOD
- rechercher un contenu sur un portail de vidéo à la demande
- liker, partager ou commenter un message sur Twitter
- commenter une vidéo sur youtube
- appeler la hotline des programmes du PSM par téléphone pour se plaindre
- évaluer une émission de radio dans l'application de la station de radio."""@fr .

ec:Serial a owl:Class ;
    rdfs:label "Série"@fr ;
    dcterms:description "œuvres apparaissant (comme dans un magazine ou à la télévision) en parties"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasEpisode ;
            owl:someValuesFrom ec:Programme ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Season ;
            owl:onProperty ec:hasSeason ],
        ec:EditorialGroup ;
    skos:definition "un groupe éditorial racontant une histoire en plusieurs parties, chacune d'entre elles poursuivant la partie précédente."@fr ;
    skos:example "- Série allemande \"Babylon Berlin\" avec plusieurs saisons"@fr .

ec:Series a owl:Class ;
    rdfs:label "Série"@fr ;
    dcterms:description "Les séries sont un type particulier de collection. TV ou radio sont composées d'épisodes. Les épisodes suivent souvent un schéma de publication régulier ou traitent de sujets similaires ou des mêmes personnages."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasEpisode ;
            owl:someValuesFrom ec:Programme ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Season ;
            owl:onProperty ec:hasSeason ],
        ec:EditorialGroup ;
    skos:definition "un groupe éditorial de programmes, regroupés par personnages ou sujets ou schéma de publication, et non par une histoire séquentielle"@fr ;
    skos:example """- Série ABC "Friends" (en anglais)
- Le programme d'information quotidien de la BBC "BBC News".
- Tatort, le feuilleton du dimanche soir d'ARD"""@fr .

ec:Shot a owl:Class ;
    rdfs:label "Coup de feu"@fr ;
    dcterms:description "Une séquence de film photographiée en continu par une seule caméra."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasScene ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Take ;
            owl:onProperty ec:hasTake ],
        ec:EditorialSegment ;
    owl:disjointWith ec:Take ;
    skos:definition "un segment éditorial filmé avec une seule caméra, sans interruption."@fr ;
    skos:example "- une partie de la scène finale de \"Casablance\" montrant Humphrey Bogart de dos tout en regardant Ingrid Bergman et Paul Henreid se diriger vers l'avion, filmée par une seule caméra sans interruption"@fr .

ec:StaffMember a owl:Class ;
    rdfs:label "Membre du personnel."@fr ;
    dcterms:description "Un membre du personnel."@fr ;
    rdfs:subClassOf ec:Person .

ec:Stream a owl:Class ;
    rdfs:label "Stream"@fr ;
    dcterms:description "Un flux continu de bits."@fr ;
    rdfs:subClassOf ec:Component ;
    skos:definition "un Composant sous forme d'un flux continu de bits"@fr ;
    skos:example """- un flux audio provenant d'un service audio à la demande
- un flux vidéo provenant d'un service de vidéo à la demande"""@fr .

ec:TimelineTrack a owl:Class ;
    rdfs:label "Piste chronologique"@fr ;
    dcterms:description "Permet de définir une séquence temporelle d'EditorialObjects."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:hasTimelineTrackPart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasDuration ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:UsageRestrictions a owl:Class ;
    rdfs:label "Restrictions d'utilisation"@fr ;
    dcterms:description "Pour définir un ensemble de UsageRestrictions."@fr ;
    rdfs:subClassOf ec:Rights .

ec:abstract a owl:DatatypeProperty ;
    rdfs:label "Résumé"@fr ;
    dcterms:description "Pour fournir un résumé."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:contentDescription .

ec:agentWebHomepage a owl:DatatypeProperty ;
    rdfs:label "Page d'accueil"@fr ;
    dcterms:description "Pour fournir l'adresse de la page web d'un agent (contact/personne ou organisation)."@fr ;
    rdfs:range xsd:anyURI .

ec:aspectRatio a owl:DatatypeProperty ;
    rdfs:label "Rapport d'aspect"@fr ;
    dcterms:description "Pour spécifier le rapport d'aspect."@fr ;
    rdfs:range xsd:string .

ec:audienceCount a owl:DatatypeProperty ;
    rdfs:label "Valeur d'audience"@fr ;
    dcterms:description "La portée de l'audience en nombre ou en pourcentage."@fr .

ec:frameHeight a owl:DatatypeProperty ;
    rdfs:label "Hauteur du cadre"@fr ;
    dcterms:description "La hauteur d'une image vidéo."@fr ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf ec:height .

ec:frameHeightUnit a owl:DatatypeProperty ;
    rdfs:label "Unité de hauteur du cadre"@fr ;
    dcterms:description "L'unité utilisée pour mesurer la hauteur d'un cadre."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:heightUnit .

ec:frameWidth a owl:DatatypeProperty ;
    rdfs:label "Largeur du cadre"@fr ;
    dcterms:description "La largeur d'une image vidéo."@fr ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf ec:width .

ec:frameWidthUnit a owl:DatatypeProperty ;
    rdfs:label "Unité de largeur du cadre"@fr ;
    dcterms:description "L'unité utilisée pour mesurer la largeur d'un cadre."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:widthUnit .

ec:hasAccessConditions a owl:ObjectProperty ;
    rdfs:label "Conditions d'accès"@fr ;
    dcterms:description "Pour exprimer les conditions/restrictions d'accès."@fr ;
    rdfs:subPropertyOf ec:hasRights .

ec:hasAlternativeTitle a owl:ObjectProperty ;
    rdfs:label "a un titre alternatif"@fr .

ec:hasApprover a owl:ObjectProperty ;
    rdfs:label "Approuvé par"@fr ;
    dcterms:description "Pour identifier un agent qui a approuvé un rapport d'audit."@fr .

ec:hasAssociatedArtefact a owl:ObjectProperty ;
    rdfs:label "Artefact connexe"@fr ;
    dcterms:description "Un artefact lié à un agent."@fr .

ec:hasBrand a owl:ObjectProperty ;
    rdfs:label "Marque"@fr ;
    dcterms:description "Pour identifier une Marque."@fr .

ec:hasCharacter a owl:ObjectProperty ;
    rdfs:label "Caractère"@fr,
        "Personnage fictif."@fr ;
    dcterms:description "Pour identifier un personnage."@fr,
        "Pour énumérer les personnages d'une fiction."@fr .

ec:hasCommissioningContract a owl:ObjectProperty ;
    rdfs:label "Contrat"@fr ;
    dcterms:description "Le contrat par lequel un objet éditorial est commissionné."@fr .

ec:hasContributor a owl:ObjectProperty ;
    rdfs:label "Contributeur"@fr ;
    dcterms:description "Pour identifier un contributeur à une ressource, un EditorialObject, un Événement..."@fr .

ec:hasCoverageRestrictions a owl:ObjectProperty ;
    rdfs:label "Restrictions de couverture"@fr ;
    dcterms:description "Pour exprimer les restrictions de couverture."@fr ;
    rdfs:subPropertyOf ec:hasRights .

ec:hasCreator a owl:ObjectProperty ;
    rdfs:label "Créateur"@fr ;
    dcterms:description "Pour identifier un agent impliqué dans la création de la ressource ou de l'objet éditorial."@fr .

ec:hasDateDeleted a owl:ObjectProperty ;
    rdfs:label "Date de suppression"@fr ;
    dcterms:description "La date à laquelle la ressource a été supprimée."@fr ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasDateModified a owl:ObjectProperty ;
    rdfs:label "Date/heure de modification"@fr ;
    dcterms:description "Pour indiquer la date à laquelle l'actif a été modifié."@fr ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasDateOfBirth a owl:ObjectProperty ;
    rdfs:label "Date de naissance"@fr ;
    dcterms:description "La date de naissance d'un contact/personne."@fr ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasDateOfDeath a owl:ObjectProperty ;
    rdfs:label "Date du décès"@fr ;
    dcterms:description "La date à laquelle un contact/personne est décédé."@fr ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasEditorialWork a owl:ObjectProperty ;
    rdfs:label "a un travail éditorial"@fr ;
    rdfs:subPropertyOf ec:isMemberOf .

ec:hasImageCodec a owl:ObjectProperty ;
    rdfs:label "Codec d'image"@fr ;
    dcterms:description "Pour spécifier le codec d'une image."@fr .

ec:hasImageFormat a owl:ObjectProperty ;
    rdfs:label "Format d'image"@fr ;
    dcterms:description "Pour spécifier le format d'une image."@fr .

ec:hasProvenanceTarget a owl:ObjectProperty ;
    rdfs:label "Cible de provenance"@fr ;
    dcterms:description "L'instance d'un objet sourcé par la Provenance."@fr .

ec:hasPublicationChannel a owl:ObjectProperty ;
    rdfs:label "a un canal de publication"@fr .

ec:hasRelatedPicture a owl:ObjectProperty ;
    rdfs:label "Photo"@fr ;
    dcterms:description "Pour associer une image à un EditorialObject"@fr .

ec:hasRelatedPublicationEvent a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "Événement de publication"@fr ;
    dcterms:description "Pour identifier le PublicationEvent associé à la ressource."@fr .

ec:hasRelatedPublicationService a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "Service de publication connexe"@fr ;
    dcterms:description "Établir une relation avec les services de publication."@fr .

ec:hasResourceOffset a owl:ObjectProperty ;
    rdfs:label "Compensation des ressources"@fr ;
    dcterms:description "Le décalage de départ dans une ressource."@fr .

ec:hasScene a owl:ObjectProperty ;
    rdfs:label "a une scène"@fr ;
    rdfs:subPropertyOf ec:hasPart .

ec:hasSeason a owl:ObjectProperty ;
    rdfs:label "Saison"@fr ;
    dcterms:description "Pour identifier les saisons d'une série."@fr .

ec:hasStorageType a owl:ObjectProperty ;
    rdfs:label "Type de stockage"@fr ;
    dcterms:description "Définir un type de stockage associé à un localisateur à partir duquel une ressource peut être accédée ou peut être récupérée."@fr .

ec:hasTake a owl:ObjectProperty ;
    rdfs:label "a des prises"@fr ;
    rdfs:subPropertyOf ec:hasPart .

ec:hasUsageRestrictions a owl:ObjectProperty ;
    rdfs:label "Restrictions d'utilisation"@fr ;
    dcterms:description "Pour exprimer des restrictions d'utilisation."@fr ;
    rdfs:subPropertyOf ec:hasRights .

ec:isAnimatedBy a owl:ObjectProperty ;
    rdfs:label "est animé par"@fr ;
    dcterms:description "Personnage, animé par une person utilisant un artefact"@fr .

ec:isAwardedTo a owl:ObjectProperty ;
    rdfs:label "décerné à"@fr .

ec:isChildOf a owl:ObjectProperty ;
    rdfs:label "Parent"@fr ;
    dcterms:description "Pour lier un concept à un parent."@fr .

ec:isCloneOf a owl:ObjectProperty ;
    rdfs:label "Cloner la source"@fr ;
    dcterms:description "Pour identifier la source d'une MediaResource clonée"@fr .

ec:isDefinedBy a owl:ObjectProperty ;
    rdfs:label "Contrat connexe"@fr ;
    dcterms:description "Pour identifier le contrat par lequel une règle a été définie."@fr .

ec:isDerivedFrom a owl:ObjectProperty ;
    rdfs:label "Dérivé de"@fr ;
    dcterms:description "Identifie une relation basée sur le contenu entre deux ressources."@fr .

ec:isDubOf a owl:ObjectProperty ;
    rdfs:label "Doublé de"@fr ;
    dcterms:description "l'origine d'une MediaResource doublée."@fr .

ec:isInstantiatedBy a owl:ObjectProperty ;
    rdfs:label "Resource médiatique"@fr ;
    dcterms:description "Pour identifier une MediaResource instanciant un EditorialObject."@fr .

ec:isMasterOf a owl:ObjectProperty ;
    rdfs:label "Resource média dérivée"@fr ;
    dcterms:description "Pour identifier le maître d'une ressource média dérivée."@fr .

ec:isMediaFragmentOf a owl:ObjectProperty ;
    rdfs:label "Source du fragment de média"@fr ;
    dcterms:description "Pour identifier la ressource média à laquelle appartient un fragment de média"@fr .

ec:isOrderedBy a owl:ObjectProperty ;
    rdfs:label "Contrat"@fr ;
    dcterms:description "Le contrat par lequel un ProductionJob est commandée."@fr .

ec:isPartOf a owl:ObjectProperty ;
    rdfs:label "Objet de la rédaction"@fr ;
    dcterms:description "Pour identifier l'objet éditorial auquel appartient une partie."@fr .

ec:isPortrayedBy a owl:ObjectProperty ;
    rdfs:label "est dépeint par"@fr ;
    dcterms:description "Relation entre un personnage fictif et l'animal qui est représenté dans la scène."@fr ;
    owl:inverseOf ec:portrays .

ec:isPreviousInSequence a owl:ObjectProperty ;
    rdfs:label "Précédant"@fr ;
    dcterms:description "Un lien vers un objet éditorial précédant l'objet éditorial actuel dans une séquence ordonnée."@fr .

ec:isRequiredBy a owl:ObjectProperty ;
    rdfs:label "Requis"@fr ;
    dcterms:description "Pour exprimer des relations fortes entre les EditorialObjects"@fr ;
    owl:inverseOf ec:requires .

ec:isTimelineTrackPartOf a owl:ObjectProperty ;
    rdfs:label "Objet de la rédaction"@fr ;
    dcterms:description "Pour associer un EditorialObject à une partie de la TimelineTrack."@fr .

ec:isTrackPartOf a owl:ObjectProperty ;
    rdfs:label "Source de la partie de la voie"@fr ;
    dcterms:description "Un élément pour identifier une partie d'une piste par un titre, une heure de début et une heure de fin dans la source et la destination du média."@fr .

ec:isVersionOf a owl:ObjectProperty ;
    rdfs:label "Version de"@fr ;
    dcterms:description "Pour identifier les versions connexes."@fr .

ec:loudnessIntegratedLoudness a owl:DatatypeProperty ;
    rdfs:label "loudness intégré"@fr ;
    dcterms:description "La valeur de l'intensité sonore intégrée mesurée au niveau de l'AudioProgramme ou de l'AudioContent."@fr ;
    rdfs:range xsd:float .

ec:loudnessMaxMomentary a owl:DatatypeProperty ;
    rdfs:label "Intensité sonore maximale momentanée"@fr ;
    dcterms:description "La valeur de l'intensité sonore maximale momentanée mesurée au niveau de l'AudioProgramme ou de l'AudioContent."@fr ;
    rdfs:range xsd:float .

ec:loudnessMaxShortTerm a owl:DatatypeProperty ;
    rdfs:label "Sonie maximale à court terme"@fr ;
    dcterms:description "La valeur de l'intensité sonore maximale à court terme mesurée au niveau de l'AudioProgramme ou de l'AudioContent."@fr ;
    rdfs:range xsd:float .

ec:loudnessMaxTruepeak a owl:DatatypeProperty ;
    rdfs:label "Max true peak loudness"@fr ;
    dcterms:description "La valeur de l'intensité sonore maximale de crête vraie mesurée au niveau de l'AudioProgramme ou de l'AudioContent."@fr ;
    rdfs:range xsd:float .

ec:loudnessMethod a owl:DatatypeProperty ;
    rdfs:label "Méthode de sonorité"@fr ;
    dcterms:description "La méthode de mesure de l'intensité sonore au niveau de l'AudioProgramme ou de l'AudioContent."@fr ;
    rdfs:range rdfs:Literal .

ec:loudnessRange a owl:DatatypeProperty ;
    rdfs:label "Plage de sonorité"@fr ;
    dcterms:description "La plage d'intensité sonore mesurée au niveau de l'AudioProgramme ou de l'AudioContent."@fr ;
    rdfs:range xsd:float .

ec:occursIn a owl:ObjectProperty .

ec:offers a owl:ObjectProperty ;
    rdfs:label "Offres de service"@fr,
        "Événements de publication"@fr ;
    dcterms:description "Pour identifier les PublicationEvents disponibles via un service."@fr .

ec:playbackSpeed a owl:DatatypeProperty ;
    rdfs:label "Vitesse de lecture"@fr ;
    dcterms:description "Identifie le taux d'unités par rapport au temps auquel la ressource doit être lue pour la consommation humaine. Si l'unité de mesure est connue, utilisez les sous-propriétés framesPerSecond ou inchesPerSecond."@fr ;
    rdfs:range xsd:double .

ec:playsCharacter a owl:ObjectProperty ;
    rdfs:label "joue un personnage"@fr ;
    dcterms:description "Un personnage joué par une personne. La relation implique que la personne a des droits intellectuels sur l'interprétation du personnage."@fr .

ec:portrays a owl:ObjectProperty ;
    rdfs:label "dépeint"@fr ;
    dcterms:description "Un animal qui apparaît comme un personnage autre que lui-même."@fr .

ec:promotes a owl:ObjectProperty ;
    rdfs:label "favorise"@fr ;
    dcterms:description "Le contenu fait la promotion d'un autre contenu"@fr .

ec:publishes a owl:ObjectProperty ;
    rdfs:label "Objet de la rédaction"@fr ;
    dcterms:description "L'objet éditorial associé à un PublicationEvent."@fr .

ec:replaces a owl:ObjectProperty ;
    rdfs:label "Remplace"@fr ;
    dcterms:description "Pour identifier la substitution."@fr .

ec:resolution a owl:DatatypeProperty ;
    rdfs:label "Résolution"@fr ;
    dcterms:description "Pour définir la résolution d'un actif, par exemple une vidéo, une image..."@fr ;
    rdfs:range rdfs:Literal .

ec:timecodeExpression a owl:DatatypeProperty ;
    rdfs:label "expression du timecode"@fr ;
    dcterms:description "Un temps exprimé sous forme de timecode."@fr ;
    rdfs:range xsd:string .

ec:usesProductionDevice a owl:ObjectProperty ;
    rdfs:label "Dispositif de production"@fr ;
    dcterms:description "Pour identifier un ProductionDevice associé à un ProductionJob."@fr .

xsd:gDay a rdfs:Datatype .

xsd:gMonth a rdfs:Datatype .

xsd:gYear a rdfs:Datatype .

xsd:time a rdfs:Datatype .

xkos:temporal a owl:ObjectProperty ;
    rdfs:label "temporel"@fr ;
    rdfs:subPropertyOf xkos:sequential .

ec:AudioTrack a owl:Class ;
    rdfs:label "Piste audio"@fr ;
    dcterms:description "Une audioTrack est le conteneur de données audio de base d'un support. L'attribut est une référence non ambiguë à ce conteneur dans un support donné."@fr ;
    rdfs:subClassOf ec:Track .

ec:Captioning a owl:Class ;
    rdfs:label "Sous-titrage"@fr ;
    dcterms:description "Pour signaler la présence de malentendants sous-titrage."@fr ;
    rdfs:subClassOf ec:Track .

ec:ConsumptionDevice a owl:Class ;
    rdfs:label "Appareil de consommation"@fr ;
    dcterms:description "Un appareil utilisé pour consommer un contenu médiatique."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDeviceProfile ;
            owl:onProperty ec:compliesWith ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasConsumptionDeviceManufacturer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Essence ;
            owl:onProperty ec:renders ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:consumptionDeviceBrand ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:consumptionDeviceBrowser ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:consumptionDeviceModel ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:consumptionDeviceOS ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "un appareil permettant d'utiliser les services de médias"@fr ;
    skos:example """- un smartphone
- un téléviseur intelligent
- un poste de radio fm
- un beamer alimenté par un signal média et projetant sur un écran"""@fr .

ec:Contact a owl:Class ;
    rdfs:label "Contact"@fr ;
    dcterms:description "Un contact pour un personne ou une organisation"@fr ;
    rdfs:subClassOf ec:Person .

ec:ProductionDevice a owl:Class ;
    rdfs:label "Appareil de production"@fr ;
    dcterms:description "Un appareil utilisé pour créer/traiter une ressource médiatique, MediaResource."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:OnStagePosition ;
            owl:onProperty ec:hasProductionDeviceOnStagePosition ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasUsageContract ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "un outil pour faciliter les activités dans une tâche de production"@fr ;
    skos:example """- une caméra
- un microphone
- un mixeur vidéo ou son
- un monteur vidéo ou son
- des spots
- un mur de LED"""@fr .

ec:PublicationPlan a owl:Class ;
    rdfs:label "Plan de publication"@fr ;
    dcterms:description """Un PublicationPlan décrit un calendrier de PublicationEvents ainsi que leurs audiences. La réalisation d'un plan de publication, PublicationPlan, peut nécessiter l'acquisition ou la création spécifique d'un contenu défini comme une paire d'objets éditoriaux, EditorialObjects, et d'essences, d'Essence. Ceci se produit par le biais d'ordres de production, ProductionOrders.
Un plan de publication peut être le résultat de plans ou sous plans de publication associés.
Exemple 1 : Une campagne publicitaire pour un produit consiste en un ensemble d'événements de publication, PublicationPlan, planifiée.
Exemple 2 : Un film de fiction est promu avec plusieurs bandes annonces publiées avant la publication du film."""@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasPublicationEvent ;
            owl:someValuesFrom ec:PublicationEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:hasAsset ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionOrder ;
            owl:onProperty ec:hasAssociatedProductionOrder ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasBusinessContract ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlan ;
            owl:onProperty ec:hasPublicationPlanMember ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasStakeholder ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlan ;
            owl:onProperty ec:isMemberOf ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Collection ;
            owl:onProperty ec:hasPublicationPlanStatus ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:publicationPlanTitle ] ;
    skos:definition "un plan pour un ou plusieurs PublicationEvents pour s'adresser à un public cible, ou une hiérarchie de PublicationPlans"@fr ;
    skos:example """- la date, l'heure et le canal prévus pour la publication d'un film
- les dates, heures et chaînes prévues pour la publication des épisodes d'un feuilleton
- l'horaire prévu pour une chaîne pendant une journée
- les dates, heures et canaux prévus pour une collection de contenus sur un thème commun"""@fr .

ec:Rule a owl:Class ;
    rdfs:label "Règle"@fr,
        "Une règle définie à partir de contraintes légales, techniques, éditoriales ou réglementaires."@fr ;
    dcterms:description "Une règle définie à partir de contraintes légales, techniques, éditoriales ou réglementaires."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasPriority ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rule ;
            owl:onProperty ec:hasRelatedRule ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:isDefinedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:ruleStatement ] ;
    skos:definition "une directive légale, réglementaire, technique ou éditoriale"@fr ;
    skos:example """- le niveau de volume de la piste audio doit être inférieur à 0dB
- le temps de parole dans un débat entre deux candidats doit être égal
- la part des experts hommes/femmes dans tous les programmes de BBC One doit être de 50% chacun"""@fr .

ec:Season a owl:Class ;
    rdfs:label "Saison"@fr ;
    dcterms:description "Une série peut être composée d'une ou plusieurs saisons regroupant un certain nombre d'épisodes. Pour cette raison, les saisons sont liées aux séries à l'aide de la propriété isRelatedTo."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:hasEpisode ;
            owl:someValuesFrom ec:Programme ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Serial ;
            owl:onProperty ec:hasSerial ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Series ;
            owl:onProperty ec:isSeasonOf ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:seasonNumber ],
        ec:EditorialGroup ;
    skos:definition "un sous-groupe d'épisodes d'un feuilleton ou d'une série, généralement regroupés en raison d'une période de production commune."@fr ;
    skos:example """- les 216 épisodes de 2018 de la série "EastEnder" de la BBC
- la saison 1 avec 8 épisodes de la série allemande "Babylon Berlin"."""@fr .

ec:Signing a owl:Class ;
    rdfs:label "Langue des signes"@fr ;
    dcterms:description "Indique la présence d’une interprétation en langue des signes dans le contenu audiovisuel (pour les personnes sourdes et malentendantes). Le type (p. ex. incrustation/in-vision) et la langue des signes peuvent être précisés via les propriétés appropriées."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:SigningFormat ;
            owl:onProperty ec:hasSigningFormat ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasSigningSource ],
        ec:Track .

ec:Subtitling a owl:Class ;
    rdfs:label "Sous-titrage"@fr ;
    dcterms:description "Pour signaler la présence de sous-titres pour traduction dans des langues alternatives."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasSubtitlingSource ],
        ec:Track .

ec:agentEmailAddress a owl:DatatypeProperty ;
    rdfs:label "e-mail"@fr ;
    dcterms:description "Pour fournir une adresse e-mail."@fr ;
    rdfs:range xsd:string .

ec:agentRelatedLink a owl:DatatypeProperty ;
    rdfs:label "Lien connexe"@fr ;
    dcterms:description "Fournir un lien vers, par exemple, une ressource Web liée à un agent."@fr ;
    rdfs:range xsd:anyURI .

ec:encodingLevel a owl:DatatypeProperty ;
    rdfs:label "Niveau de codage"@fr ;
    dcterms:description "Pour définir un niveau d'encodage."@fr ;
    rdfs:range rdfs:Literal .

ec:encodingProfile a owl:DatatypeProperty ;
    rdfs:label "Profil d'encodage"@fr ;
    dcterms:description "Le profil de codage tel que défini dans les spécifications."@fr ;
    rdfs:range rdfs:Literal .

ec:gender a owl:DatatypeProperty ;
    rdfs:label "Genre"@fr ;
    dcterms:description "Le genre d'une personne, par exemple, homme ou femme."@fr ;
    rdfs:range rdfs:Literal .

ec:hasContact a owl:ObjectProperty ;
    rdfs:label "Contact"@fr ;
    dcterms:description "Pour fournir des informations sur un contact pour une Organisation ou une personne physique (par exemple, l'agent d'un acteur)."@fr .

ec:hasCoverage a owl:ObjectProperty ;
    rdfs:label "Couverture"@fr ;
    dcterms:description "Pour fournir des informations sur la couverture."@fr .

ec:hasDateCreated a owl:ObjectProperty ;
    rdfs:label "Date/heure de création"@fr ;
    dcterms:description "La date de création de l'actif."@fr ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasEditorialGroup a owl:ObjectProperty ;
    rdfs:label "a groupe de rédaction"@fr ;
    rdfs:subPropertyOf ec:isMemberOf .

ec:hasEncodingFormat a owl:ObjectProperty ;
    rdfs:label "Format de codage"@fr ;
    dcterms:description "Pour décrire tout format d'encodage utilisé pour produire du contenu."@fr ;
    rdfs:subPropertyOf ec:hasFormat .

ec:hasEpisode a owl:ObjectProperty ;
    rdfs:label "Episode"@fr ;
    dcterms:description "Pour identifier les épisodes d'une série"@fr .

ec:hasLanguage a owl:ObjectProperty ;
    rdfs:label "Langue"@fr ;
    dcterms:description "Pour associer une langue à un actif. Un vocabulaire contrôlé basé sur le BCP 47 est recommandé. Cette propriété peut également être utilisée pour identifier la présence d'une langue des signes (RFC 5646). Par héritage, la propriété hasLanguage s'applique indifféremment aux niveaux MediaResource / Fragment / Piste aux niveaux desquels l'usage est défini. Les meilleures pratiques recommandent de d'utiliser le meilleur niveau de granularité possible pour décrire l'utilisation de la langue dans une ressource multimédia, y compris au niveau des fragments. MediaResource, y compris aux niveaux Fragment et Track."@fr .

ec:hasProgramme a owl:ObjectProperty ;
    rdfs:label "a un programme"@fr .

ec:hasPublicationEvent a owl:ObjectProperty ;
    rdfs:label "Événement de publication"@fr ;
    dcterms:description "Pour associer les PublicationEvents à canaux de publication ou en tant qu'éléments d'une PublicationHistory ou d'une PublicationPlanning."@fr .

ec:hasRelatedEditorialObject a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "Objet éditorial connexe"@fr ;
    dcterms:description "Pour identifier les EditorialObjects connexes."@fr .

ec:hasRelatedScene a owl:ObjectProperty ;
    rdfs:label "Scène connexe"@fr ;
    dcterms:description "Pour associer un concept à une Scène"@fr .

ec:requires a owl:ObjectProperty ;
    rdfs:label "Nécessite"@fr ;
    dcterms:description "Pour exprimer la dépendance."@fr .

xkos:sequential a owl:ObjectProperty ;
    rdfs:label "séquentiel"@fr ;
    rdfs:subPropertyOf skos:related .

ec:BibliographicalObject a owl:Class ;
    rdfs:label "Objet bibliographique"@fr ;
    dcterms:description "Documents de nature diverse."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:BibliographicalObject ;
            owl:onProperty ec:references ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:references ],
        ec:Asset .

ec:ConsumptionEvent a owl:Class ;
    rdfs:label "Événement de consommation"@fr ;
    dcterms:description "Un événement de consommation, ConsumptionEvent, décrit la consommation de contenu médiatique durant un évènement de publication, PublicationEvent. Pour les services linéaires, le ConsumptionEvent et le PuclicationEvent, se produisent en même temps. Pour les services non linéaires, le consommateur décide du moment du ConsumptionEvent. Dans les deux cas, un ConsumptionEvent génère un évènement de raisonance, ResonanceEvent qui est agrégé aux données de raisonance, ResonanceData."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Essence ;
            owl:onProperty ec:consumesEssence ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Consumer ;
            owl:onProperty ec:hasConsumer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:TimelinePoint ;
            owl:onProperty ec:hasConsumptionEventResumePoint ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDevice ;
            owl:onProperty ec:hasDevice ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionEvent ;
            owl:onProperty ec:hasRelatedConsumptionEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationEvent ;
            owl:onProperty ec:hasRelatedPublicationEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:occursIn ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:occursIn ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationPlatform ;
            owl:onProperty ec:occursOn ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionLicence ;
            owl:onProperty ec:requiresLicence ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ResonanceEvent ;
            owl:onProperty ec:resultsIn ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Account ;
            owl:onProperty ec:accountingTo ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasEnd ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasStart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "le cas où un consommateur consomme un service de médias"@fr ;
    skos:example """- une personne regardant une émission d'information sur la télévision linéaire
- une famille qui écoute la radio linéaire en prenant son petit-déjeuner à la maison
- un couple sur le canapé de leur salon en train de regarder un film en streaming depuis un service de VoD"""@fr .

ec:DataFormat a owl:Class ;
    rdfs:label "Format des data"@fr ;
    dcterms:description "Spécifie le format utilisé pour les data"@fr ;
    rdfs:subClassOf ec:Format .

ec:Locator a owl:Class ;
    rdfs:label "Localisateur"@fr ;
    dcterms:description "Les attributs personnalisés doivent être associés par les implémenteurs."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:locatorTargetInformation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Organisation a owl:Class ;
    rdfs:label "Organisation"@fr ;
    dcterms:description "Une organisation (entreprise, société, fédération, etc.) ou un agent moral (organisme gouvernemental)."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Department ;
            owl:onProperty ec:hasDepartment ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:StaffMember ;
            owl:onProperty ec:hasOrganisationStaff ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:StaffMember ;
            owl:onProperty ec:hasStaffMember ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        ec:Agent ;
    skos:definition "un agent sous la forme d'une structure administrative et fonctionnelle participant à des activités liées aux médias"@fr ;
    skos:example """- Organisations PSM
- UER
- société de gestion collective
- studios de cinéma
- cinémas
- syndicat des auteurs"""@fr .

ec:ProductionJob a owl:Class ;
    rdfs:label "Tâche de production"@fr ;
    dcterms:description "Une tâche / un processus à exécuter pour manipuler/créer/modifier/stocker/etc. des MediaResources et Essences telles que définies dans un EditorialObject. Il est commandé par contrat, Contract."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:basedOn ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:createsMetadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Involvement ;
            owl:onProperty ec:hasContributor ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:hasInputMediaResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasInputResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Essence ;
            owl:onProperty ec:hasOutputEssence ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:hasOutputMediaResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasOutputResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionJob ;
            owl:onProperty ec:hasPreviousRelated ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasProductionJobEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasProductionJobLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionJob ;
            owl:onProperty ec:hasSubJob ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:isOrderedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionDevice ;
            owl:onProperty ec:usesProductionDevice ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "une tâche ou un ensemble de tâches pour créer, modifier, manipuler, stocker, etc. une ressource médiatique"@fr ;
    skos:example """- la production d'une émission en direct pour la diffusion
- le tournage et le montage d'un clip d'information
- la production externalisée d'un film complet"""@fr .

ec:PublicationPlatform a owl:Class ;
    rdfs:label "Plate-forme de publication"@fr ;
    dcterms:description "Une plateforme comme celle d'un réseau ou d'un opérateur."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:accountingTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:hasPublicationChannel ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:hasRelatedPublicationService ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isOwnedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:offers ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionDeviceProfile ;
            owl:onProperty ec:supportsConsumptionDeviceProfile ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "une installation qui permet de connecter des sources et des cibles de contenu par des canaux uni- ou bidirectionnels"@fr ;
    skos:example """- la plate-forme de diffusion DVB-S d'Eutelsat
- la plateforme de vidéo à la demande youtube
- tous les serveurs accessibles via les protocoles internet et offrant/prenant du contenu codé en HTML ou similaire
- Fortnite, Decentraland ou Roblox comme métaverses"""@fr .

ec:Take a owl:Class ;
    rdfs:label "Prenez"@fr ;
    dcterms:description "Une version particulière d'une scène ou d'une séquence sonore ou visuelle photographiée ou enregistrée en continu à un moment donné."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Scene ;
            owl:onProperty ec:hasScene ],
        ec:EditorialSegment ;
    skos:definition "une instance particulière d'un plan ou d'une scène parmi un certain nombre d'instances similaires en vue d'une sélection pendant la postproduction."@fr ;
    skos:example "- une ŒuvreRédactionnelle est constituée de prises sélectionnées, tandis que les prises écartées sont parfois publiées comme \"outtakes\", dont on peut facilement trouver des exemples sur le web"@fr .

ec:accountingTo a owl:ObjectProperty ;
    rdfs:label "Compte"@fr ;
    dcterms:description "Un compte de consommateur pour un service particulier."@fr .

ec:agentLinkedData a owl:DatatypeProperty ;
    rdfs:label "Données liées à l'agent"@fr ;
    dcterms:description "Pour fournir un lien avec les données liées. Range: une URL ou une URI."@fr ;
    rdfs:range xsd:anyURI .

ec:hasCodec a owl:ObjectProperty ;
    rdfs:label "Codec"@fr ;
    dcterms:description "Pour identifier un Codec utilisé pour créer une ressource."@fr .

ec:hasDuration a owl:ObjectProperty .

ec:hasLocator a owl:ObjectProperty ;
    rdfs:label "Localisateur"@fr ;
    dcterms:description "Un localisateur à partir duquel la ressource est accessible."@fr .

ec:hasPart a owl:ObjectProperty ;
    rdfs:label "Partie"@fr ;
    dcterms:description "Pour définir des parties (segments, fragments, plans, etc.) au sein d'un EditorialObject."@fr ;
    owl:inverseOf ec:isPartOf .

ec:isOwnedBy a owl:ObjectProperty ;
    rdfs:label "est possédé par"@fr ;
    dcterms:description "Pour identifier l’Agent (Contact, Personne ou Organisation) qui possède une Marque, un Canal de publication, une Plateforme de publication ou un Service de publication."@fr ;
    owl:inverseOf ec:owns .

ec:title a owl:DatatypeProperty ;
    rdfs:label "Titre"@fr ;
    dcterms:description "Toutes les valeurs du système de classification du statut du titre de l'UER (https://github.com/ebu/ebu_cs/blob/main/metadata/cs/ebu_TitleStatusCodeCS.xml) sont des candidats sous-propriétés de la propriété title comme implémenté par exemple avec alternativeTitle."@fr ;
    rdfs:range rdfs:Literal .

time:DateTimeDescription a owl:Class ;
    rdfs:label "Description de la date et de l'heure"@fr ;
    dcterms:description "Description de la date et de l'heure structurée avec des valeurs distinctes pour les différents éléments d'un système calendrier-horloge. Le système de référence temporel est fixé au calendrier grégorien, et la plage des propriétés année, mois, jour est limitée aux types XML Schema correspondants xsd:gYear, xsd:gMonth et xsd:gDay, respectivement."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:gDay ;
            owl:onProperty time:day ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:gMonth ;
            owl:onProperty time:month ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:gYear ;
            owl:onProperty time:year ],
        time:Instant .

ec:Character a owl:Class ;
    rdfs:label "Caractère"@fr ;
    dcterms:description "Par exemple, un contact / une personne fictive."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasEmbodyingArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Person ;
            owl:onProperty ec:isAnimatedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Involvement ;
            owl:onProperty ec:isPlayedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Animal ;
            owl:onProperty ec:isPortrayedBy ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Person ;
            owl:onProperty ec:hasFictitiousPerson ],
        ec:Person .

ec:Codec a owl:Class ;
    rdfs:label "Codec"@fr ;
    dcterms:description "Pour fournir des informations sur un codec."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasCodecVendor ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:codecFamily ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:codecVersion ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:EditorialSegment a owl:Class ;
    rdfs:label "Segment éditorial"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ec:isPartOf ;
            owl:someValuesFrom ec:EditorialObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialGroup ;
            owl:onProperty ec:hasEditorialGroup ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialWork ;
            owl:onProperty ec:hasEditorialWork ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:segmentNumber ],
        ec:EditorialObject ;
    skos:definition "un objet éditorial représentant une fraction d'un objet éditorial"@fr ;
    skos:example """- une scène de film
- un extrait d'interview
- l'introduction d'une chanson
- un paragraphe d'un texte"""@fr .

ec:Language a owl:Class ;
    rdfs:label "Langue"@fr ;
    dcterms:description "Fournir des informations sur les langues présentes dans l'EditorialObject et son objectif. Ces informations sont fournies sous forme de texte libre dans une étiquette d'annotation ou comme un identifiant pointant vers un terme dans un système de classification. D'autres types spécifiques à la langue peuvent être ajoutés en tant que sous-classes de la langue."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Scene a owl:Class ;
    rdfs:label "Scène"@fr ;
    dcterms:description "Une séquence d'action continue"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Programme ;
            owl:onProperty ec:hasProgramme ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Shot ;
            owl:onProperty ec:hasShot ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Take ;
            owl:onProperty ec:hasTake ],
        ec:EditorialSegment ;
    owl:disjointWith ec:Shot,
        ec:Take ;
    skos:definition "un segment éditorial incorporé dans un travail éditorial et représentant une partie d'une histoire sans saut dans le temps ou le lieu."@fr ;
    skos:example "- le dernier adieu de Humphrey Bogart et Ingrid Bergman à l'aéroport de Casablanca dans le film du même nom."@fr .

ec:hasConsumptionCount a owl:ObjectProperty ;
    rdfs:label "a compte de la consommation"@fr ;
    dcterms:description "Le nombre et la relation avec le public réel."@fr .

ec:hasLocation a owl:ObjectProperty ;
    rdfs:label "Emplacement"@fr ;
    dcterms:description "Un emplacement associé à l'objet ou au concept."@fr .

ec:hasRelatedArtefact a owl:ObjectProperty ;
    rdfs:label "Artéfact connexe"@fr ;
    dcterms:description "Identifier un artefact lié à EditorialObject ou à un concept."@fr .

ec:hasRelatedEvent a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "événement connexe"@fr ;
    dcterms:description "un événement associé au concept"@fr .

ec:hasRelatedResource a owl:ObjectProperty ;
    rdfs:label "Resource connexe"@fr ;
    dcterms:description "Pour identifier une ressource associée à un actif ou un EditorialObject ou un PublicationEvent ou une autre ressource."@fr .

ec:Account a owl:Class ;
    rdfs:label "Compte"@fr ;
    dcterms:description "Un compte d'inscription à un service. Les informations relatives au compte peuvent varier d'un service à l'autre. Ces informations couvrent par exemple un nom, un surnom, un loggin, un âge, le sexe, des domaines d'intérêt."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionLicence ;
            owl:onProperty ec:holdsLicence ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasConsumptionContract ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:hasRelatedAccount ] ;
    skos:definition "une identité d'enregistrement pour un service de médias"@fr ;
    skos:example """- un utilisateur enregistré pour accéder à Netflix
- une famille enregistrée avec des surnoms et des appareils pour accéder à un service de VOD"""@fr .

ec:EncodingFormat a owl:Class ;
    rdfs:label "Encodage"@fr ;
    dcterms:description "Fournir une définition du format d'encodage pour l'audio et la vidéo. Cette définition est fournie sous forme de texte libre dans une étiquette d'annotation ou comme un identificateur pointant vers un terme dans un schéma de classification, par ex. http://www.ebu.ch/metadata/ontologies/skos/ebu_AudioCompressionCodeCS.rdf ou http://www.ebu.ch/metadata/ontologies/skos/ebu_VideoCompressionCodeCS.rdf."@fr ;
    rdfs:subClassOf ec:Format .

ec:Essence a owl:Class ;
    rdfs:label "Essence"@fr ;
    dcterms:description "C'est une ressource multimédia, MediaResource,qui peut être composée d'une ou plusieurs Pistes, Tracks. une ressource multimédia est définie par un objet éditorial d'un domaine éditorial, EditorialObject (Editorial Domain). Cet EditorialObject peut être matérialisé par des essences dans un ou plusieurs formats pour différents médias ou plateformes de diffusion."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationEvent ;
            owl:onProperty ec:hasRelatedPublicationEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:isComposedOf ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:readyForPublication ],
        ec:MediaResource ;
    skos:definition "une ressource média sous la forme d'un fichier simple ou d'un paquet de fichiers complexes pour la diffusion ou la publication."@fr ;
    skos:example """- un fichier mxf
- un paquet de fichiers fourni par un appareil photo d'une marque spécifique"""@fr .

ec:Programme a owl:Class ;
    rdfs:label "Programme"@fr ;
    dcterms:description "Un EditorialObject correspondant à une MediaResource prête à être publiée."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Season ;
            owl:onProperty ec:isEpisodeOfSeason ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Serial ;
            owl:onProperty ec:isEpisodeOfSerial ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Series ;
            owl:onProperty ec:isEpisodeOfSeries ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:episodeNumber ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:episodeNumberInSeason ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:episodeNumberInSerial ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:episodeNumberInSeries ],
        ec:EditorialWork ;
    skos:definition "une Œuvre de rédaction en tant que pièce autonome ou épisode d'un feuilleton ou d'une série, destinée à être consommée comme un tout."@fr ;
    skos:example """- le film "Titanic"
- l'épisode 2 "Le banquier aveugle" de la série "Sherlock", une série policière
- l'épisode du jour de "BBC News", la série d'émissions d'information quotidienne
- l'épisode 2 "Frozen Worlds" de la série "Our Planet", une série documentaire sur la nature
- l'épisode de lundi prochain de la série "Panorama" de la BBC, un reportage politique"""@fr .

ec:Rating a owl:Class ;
    rdfs:label "Classement"@fr ;
    dcterms:description "Toutes les informations concernant la note/évaluation donnée à une ressource média par un Agent c'est-à-dire une personne/Contact ou Organisation."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Picture ;
            owl:onProperty ec:hasPictogram ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasTerritoryExcludes ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasTerritoryIncludes ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Agent ;
            owl:onProperty ec:hasRatingProvider ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:reason ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingValue ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:notRated ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingScaleMax ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingScaleMin ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingSystemEnvironment ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:ratingSystemName ] .

ec:agentTelephoneNumber a owl:DatatypeProperty ;
    rdfs:label "Téléphone"@fr ;
    dcterms:description "Pour fournir le numéro de téléphone d'un agent (Contact/Personne ou Organisation)."@fr ;
    rdfs:range xsd:string .

ec:hasEnd a owl:ObjectProperty .

ec:hasStart a owl:ObjectProperty ;
    rdfs:label "Début"@fr .

ec:hasTargetAudience a owl:ObjectProperty ;
    rdfs:label "Public cible"@fr ;
    dcterms:description "Pour associer une TargetAudience (par exemple, pour l'orientation parentale ou le ciblage d'un groupe social particulier) à un EditorialObject."@fr,
        "Pour identifier le public cible associé à un PublicationEvent."@fr .

ec:Involvement a owl:Class ;
    rdfs:label "Implication"@fr ;
    dcterms:description "Permet de définir le rôle, Role, joué par un agent, Agent. Un rôle sera identifié, par exemple, par un Concept d'un schéma de classification SKOS."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Rights ;
            owl:onProperty ec:bringsRights ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:OnStagePosition ;
            owl:onProperty ec:hasAgentOnStagePosition ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasAssociatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Character ;
            owl:onProperty ec:playsCharacter ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ProductionDevice ;
            owl:onProperty ec:usesProductionDevice ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "la participation d'un Agent dans la création ou la publication d'une ressourceMédia"@fr ;
    skos:example """- rédiger un scénario pour une production cinématographique
- réalisation d'un film
- ingénierie du son d'un talk-show
- création d'effets spéciaux pour un film"""@fr .

ec:PublicationChannel a owl:Class ;
    rdfs:label "Canal de publication"@fr ;
    dcterms:description "Un canal par lequel le contenu est publié. Il peut prendre diverses formes au-delà de la diffusion et du streaming sur Internet, par exemple la distribution physique de CD /DVD, etc."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:accountingTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:hasRelatedPublicationChannel ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:isOperatedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isOwnedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:transports ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "une connexion pour échanger du contenu entre le fournisseur et le consommateur, opérée sur une plateforme de publication."@fr ;
    skos:example """- le canal DVB-S à 10714 MHz H sur le satellite Astra 2E pour le service vidéo linéaire "BBC One HD".
- le canal DVB-T E23 à Londres/Chrystal Palace pour le service vidéo linéaire "BBC One London".
- le flux vidéo en direct "BBC One" dans le cadre de BBC iPlayer
- la chaîne @bbcradio1 sur youtube pour le service vidéo à la demande "BBC Radio 1 visual radio".
- la chaîne @elonmusk sur twitter pour le service de texte social "Elon Musk's Tweets"."""@fr .

ec:Type a owl:Class ;
    rdfs:label "Type"@fr ;
    dcterms:description "Une expression de type sous forme textuelle ou en tant que terme d'un schéma de classification."@fr ;
    rdfs:subClassOf skos:Concept .

ec:agentSocialMedia a owl:DatatypeProperty ;
    rdfs:label "Médias sociaux"@fr ;
    dcterms:description "Liens vers les médias sociaux d'un agent."@fr ;
    rdfs:range xsd:anyURI .

ec:isMemberOf a owl:ObjectProperty ;
    rdfs:label "Membre de"@fr ;
    dcterms:description "Pour identifier un groupe dont un objet éditorial est membre."@fr .

ec:Logo a owl:Class ;
    rdfs:label "Logo"@fr ;
    dcterms:description "Un Logo permet d'identifier visuellement une organisation, un service de publication, un canal de publication, ou un classement / parentalGuidance"@fr ;
    rdfs:subClassOf ec:Picture .

ec:PublicationEvent a owl:Class ;
    rdfs:label "Événement de publication"@fr ;
    dcterms:description "Décrit toute apparition, manifestation, d'un objet éditorial, EditorialObjec et d'une essence associée, Essence, sur n'importe quel média (en direct, à la demande, à la télévision, etc.). Un PublicationEvent peut être par exemple, un événement programmé, un événement diffusé (à l'origine non programmé comme les \"dernières nouvelles\"), ou des événements non linéaires à la demande et des diffusions en direct."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:AccessConditions ;
            owl:onProperty ec:hasAccessConditions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AlternativeTitle ;
            owl:onProperty ec:hasAlternativeTitle ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ConsumptionCount ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CoverageRestrictions ;
            owl:onProperty ec:hasCoverageRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationChannel ;
            owl:onProperty ec:hasPublicationChannel ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationEvent ;
            owl:onProperty ec:hasPublicationEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationMedium ;
            owl:onProperty ec:hasPublicationMedium ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasPublicationRegion ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasRestrictedAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rights ;
            owl:onProperty ec:hasRights ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:UsageRestrictions ;
            owl:onProperty ec:hasUsageRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:isOfferedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Essence ;
            owl:onProperty ec:playsOut ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:publishes ],
        [ a owl:Restriction ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasDuration ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:DateTimeDescription ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasScheduleDate ],
        [ a owl:Restriction ;
            owl:onProperty ec:title ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:abstract ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:firstShowing ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:firstShowingThisService ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:free ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:live ] ;
    owl:disjointWith ec:Rating ;
    skos:definition "l'événement de publication d'une Essence par un service à un canal sous conditions de droits"@fr ;
    skos:example """- la diffusion de la finale de la coupe du monde de football 2022 dans un service de vidéo en direct par satellite par la BBC en Grande-Bretagne
- la publication du texte d'Elon Musk "Next I'm buying Coca Cola to put the cocaine back in" sur twitter, le 27 avril 2022, dans sa chaîne @elonmusk"""@fr .

ec:alternativeTitleTypes a owl:NamedIndividual,
        skos:ConceptScheme .

ec:hasLogo a owl:ObjectProperty ;
    rdfs:label "Lien vers le logo"@fr,
        "Logo"@fr ;
    dcterms:description "Les logos peuvent être utilisés dans une variété de contextes. Le logo peut être associé à une organisation, un service ou un canal de publication."@fr,
        "Pour fournir un lien vers un logo"@fr .

ec:hasRelatedAgent a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "Agent connexe"@fr ;
    dcterms:description "Pour associer un concept à un agent (par exemple, une personne ou un personnage)."@fr ;
    owl:inverseOf ec:isRelatedAgent .

ec:CountryCode a owl:Class ;
    rdfs:label "Code pays"@fr ;
    dcterms:description "Pour identifier un pays par son code ISO."@fr ;
    rdfs:subClassOf skos:Concept .

ec:Event a owl:Class ;
    rdfs:label "Événement"@fr ;
    dcterms:description "Un événement lié à une ressource, par exemple tel qu'il est décrit dans la ressource. Ainsi cet évènement peut être décrit comme réel ou fictif dans la ressource."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasRelatedEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasLocation ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] .

ec:Person a owl:Class ;
    rdfs:label "Personne"@fr ;
    dcterms:description "Une personne.(physique)"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Affiliation ;
            owl:onProperty ec:hasAffiliation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Picture ;
            owl:onProperty ec:hasIdPicture ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:KeyCareerEvent ;
            owl:onProperty ec:hasKeyCareerEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:KeyPersonalEvent ;
            owl:onProperty ec:hasKeyPersonalEvent ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:CountryCode ;
            owl:onProperty ec:hasCountryOfBirth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:CountryCode ;
            owl:onProperty ec:hasCountryOfDeath ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfBirth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfDeath ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateOfRetirement ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasPlaceOfBirth ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasPlaceOfDeath ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:education ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:familyInformation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:familyName ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:givenName ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:hobbies ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:middleName ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:occupation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:officeEmailAddress ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:officeMobileTelephoneNumber ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:officeTelephoneNumber ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:personWeight ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:privateEmailAddress ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ec:privateHomepage ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:privateMobileTelephoneNumber ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ec:privateTelephoneNumber ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:salutationTitle ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:suffix ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:username ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:age ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:gender ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:maritalStatus ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:personHeight ],
        ec:Agent ;
    skos:definition "un agent individuel"@fr ;
    skos:example """- Alfred Hitchcock (réalisateur)
- James Bond (personnage)
- Sean Connery (acteur)
- John Ford (pseudonyme utilisé par le réalisateur John Martin Feeney)"""@fr .

ec:Picture a owl:Class ;
    rdfs:label "Photo"@fr ;
    dcterms:description "Une photographie, un logo, un pictogramme, etc."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:EncodingFormat ;
            owl:onProperty ec:hasEncodingFormat ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:ImageCodec ;
            owl:onProperty ec:hasImageCodec ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:ImageFormat ;
            owl:onProperty ec:hasImageFormat ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:aspectRatio ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:frameHeight ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:frameHeightUnit ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty ec:frameWidth ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty ec:frameWidthUnit ],
        ec:Resource ;
    skos:definition "une ressource sous la forme d'une image codée"@fr ;
    skos:example """- un fichier JPEG d'une photo, d'un logo, d'un graphique, ...
- un fichier PNG d'une photo, d'un logo, d'un graphique, ..."""@fr .

ec:Track a owl:Class ;
    rdfs:label "Piste"@fr ;
    dcterms:description "Cela peut être une piste audio ou video ou timecode ou data provenant de la ressource médiatique, MediaResource."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaResource ;
            owl:onProperty ec:hasTrackPart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TrackPurpose ;
            owl:onProperty ec:hasTrackPurpose ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TrackType ;
            owl:onProperty ec:hasTrackType ],
        ec:MediaResource ;
    skos:definition "une MediaResource sous forme d'éléments temporels pour l'audio, la vidéo ou les données (\"piste\") comprise dans une MediaResource \"agrégée\"."@fr ;
    skos:example "- l'audio dans un fichier vidéo MPEG4"@fr .

ec:Artefact a owl:Class ;
    rdfs:label "Artefact"@fr ;
    dcterms:description "Permet d'identifier tous les artefacts utilisés dans une production tels que les costumes, les objets, accessoires."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasArtefactBuyer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasArtefactOwner ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasArtefactRelatedLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PhysicalResource ;
            owl:onProperty ec:hasArtefactRelatedPhysicalResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasArtefactRetailer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasArtefactSupplier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Involvement ;
            owl:onProperty ec:hasCreator ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRelatedAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:hasRelatedEditorialObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasArtefactDateOfPurchase ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasArtefactDateOfSale ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:CurrencyCode ;
            owl:onProperty ec:hasArtefactPriceCurrency ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Location ;
            owl:onProperty ec:hasLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactAvailability ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactBrand ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactColour ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactComment ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactModel ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactPeriod ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactPriceAmount ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ec:artefactReference ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactStyle ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:artefactUsageHistory ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ec:artefactWebsite ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "une chose utilisée dans un travail de production, souvent visible et délibérément choisie pour sa valeur pour le sens du contenu."@fr ;
    skos:example """- les costumes et les accessoires dans un film
- la toile de fond non dynamique, les chaises, la table dans un talk-show"""@fr .

ec:Contract a owl:Class ;
    rdfs:label "Contrat"@fr ;
    dcterms:description "Un ensemble de conditions contractuelles impliquant différentes parties et droits, RIghts. Un contrat est utilisé pour commander et contracter la création de ressources. Un Contrat couvre l'ordre de production, ProductionOrder et la commande de vente, combinés. Le contrat relie les droits, Rights, à toutes les parties contractantes. Un contrat définit un ou plusieurs ensembles de droits."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasContractLink ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ContractCost ;
            owl:onProperty ec:hasContractRelatedCost ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:hasContractTemplate ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasContractualParty ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "un accord entre parties ou une loi concernant les droits et devoirs dans la création ou la publication de une ressource médiatique"@fr ;
    skos:example """- un contrat entre un PSM et une société de production pour la livraison d'une série
- une loi sur les droits d'auteur des articles de presse"""@fr .

ec:EditorialGroup a owl:Class ;
    rdfs:label "Groupe de rédaction"@fr ;
    dcterms:description "Pour définir une collection / un groupe de médias ressources, par exemple une série composée d'épisodes."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialGroup ;
            owl:onProperty ec:hasEditorialGroup ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:hasMember ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:totalNumberOfEpisodes ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:totalNumberOfGroupMembers ],
        ec:EditorialObject .

ec:EditorialWork a owl:Class ;
    rdfs:label "Œuvre"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialGroup ;
            owl:onProperty ec:hasEditorialGroup ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialWork ;
            owl:onProperty ec:hasEditorialWork ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialGroup ;
            owl:onProperty ec:promotes ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialWork ;
            owl:onProperty ec:promotes ],
        ec:EditorialObject ;
    skos:definition "un objet éditorial décrivant une \"œuvre de l'esprit\", une pièce."@fr ;
    skos:example """- un film basé sur un livret de jeu
- un feuilleton radiophonique basé sur un livret de jeu
- un journal télévisé avec plusieurs sujets
- un article dans un journal télévisé
- un épisode d'une série"""@fr .

ec:PublicationService a owl:Class ;
    rdfs:label "Service"@fr ;
    dcterms:description "Un service de publication est un canal ou une plate-forme de publication qui diffuse le contenu à une audience donnée."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Account ;
            owl:onProperty ec:accountingTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MarketingBrand ;
            owl:onProperty ec:hasBrand ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasConsumptionCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Logo ;
            owl:onProperty ec:hasLogo ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:hasRelatedPublicationService ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasServiceGenre ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:hasTargetAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:isOwnedBy ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "un service par lequel une organisation ou une personne publie son contenu et en offre l'accès aux consommateurs"@fr ;
    skos:example """- le service vidéo linéaire dénommé "BBC One
- le service de vidéo à la demande de Netflix"""@fr .

ec:references a owl:ObjectProperty ;
    rdfs:label "Références"@fr ;
    dcterms:description "Une ressource connexe qui est référencée, citée ou autrement pointée par la ressource décrite."@fr .

ec:Resource a owl:Class ;
    rdfs:label "Resource"@fr ;
    dcterms:description "une ressource utilisée ou à laquelle il est fait référence dans le workflow (par exemple, un document ou une image ou tout objet défini comme sous-classe de Resource). Elle possède un localisateur indiquant l'endroit où la ressource peut être récupérée."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:AncillaryData ;
            owl:onProperty ec:hasAncillaryData ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Format ;
            owl:onProperty ec:hasFormat ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Locator ;
            owl:onProperty ec:hasLocator ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:MediaFragment ;
            owl:onProperty ec:hasRelatedMediaFragment ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasStorageId ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasStorageType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:isCommissionedBy ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateDeleted ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateValidated ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:fileName ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:double ;
            owl:onProperty ec:fileSize ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty ec:resolution ] ;
    skos:definition "une Chose qui est créée, publiée, distribuée et consommée dans un flux de travail lié aux médias"@fr ;
    skos:example """- un document papier
- un document numérique
- une image numérique
- un disque vynil
- un CD audio
- une bande audio
- une cassette vidéo
- un dvd de film"""@fr .

ec:hasRights a owl:ObjectProperty ;
    rdfs:label "Est couvert par"@fr .

ec:Asset a owl:Class ;
    rdfs:label "Actif"@fr ;
    dcterms:description "Les actifs sont des EditorialObjects ou des ressources avec des droits associés. Un \"Asset\" est un objet auquel un identifiant sera associé lors de la mise en service. Il sert de point de référence central pour gérer les droits associés aux EditorialObjects, MediaResources ou Essences, et par déduction - les PublicationEvents (conditions de distribution et d'exploitation). Il est a noté que les MediaResources ou Essences seront dans ce modèle toujours représentées par un EditorialObject. Exemple : Le modèle CCDM permet l'association de droits à un EditorialObject connexe représenté par une ou plusieurs essences, Essences."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:derivedTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AccessConditions ;
            owl:onProperty ec:hasAccessConditions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AssetValue ;
            owl:onProperty ec:hasAssetValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:hasChild ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contact ;
            owl:onProperty ec:hasContact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Copyright ;
            owl:onProperty ec:hasCopyright ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CoverageRestrictions ;
            owl:onProperty ec:hasCoverageRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CreativeCommons ;
            owl:onProperty ec:hasCreativeCommons ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Disclaimer ;
            owl:onProperty ec:hasDisclaimer ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:ExploitationIssues ;
            owl:onProperty ec:hasExploitationIssues ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:IPRRestrictions ;
            owl:onProperty ec:hasIPRRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Licensing ;
            owl:onProperty ec:hasLicensing ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasParticipatingAgent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:hasRelatedAsset ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:AuditReport ;
            owl:onProperty ec:hasRelatedAuditReport ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:EditorialObject ;
            owl:onProperty ec:hasRelatedEditorialObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Picture ;
            owl:onProperty ec:hasRelatedPicture ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Record ;
            owl:onProperty ec:hasRelatedRecord ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Rights ;
            owl:onProperty ec:hasRights ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:RightsClearance ;
            owl:onProperty ec:hasRightsClearance ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:UsageRestrictions ;
            owl:onProperty ec:hasUsageRestrictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:UsageRights ;
            owl:onProperty ec:hasUsageRights ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:isDerivedFrom ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:isReplacedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:replaces ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateArchived ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateCreated ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateDeleted ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateDistributed ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateLicenseEnd ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateLicensedStart ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateModified ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateProduced ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasDateReleased ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Asset ;
            owl:onProperty ec:isChildOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty ec:orderedFlag ] ;
    owl:disjointWith ec:Rating ;
    skos:definition "un objet médiatique destiné à être publié et consommé, auquel sont attribués des droits d'auteur et des droits de reproduction, et qui représente une valeur."@fr ;
    skos:example """- un film sur bande dans les archives
- un enregistrement audio numérique avec droits d'auteur et copyright associés
- un livre
- une collection de livres"""@fr .

ec:Rights a owl:Class ;
    rdfs:label "Droits"@fr ;
    dcterms:description "Les droits, Rights, de propriété intellectuelle ou autres droits contractuels (par exemple, de publication) associés à un actif, un contrat ou un PublicationEvent. Les droits proviennent d'un contrat, Contract. Les droits sont associés à des EditorialObjects, MediaResource ou Essences par la définition d'un actif, Asset. Les droits sont liés à des détenteurs de droits, RightsHolders."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Asset ;
            owl:onProperty ec:applyTo ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contact ;
            owl:onProperty ec:hasContact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasRightsHolder ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:PublicationService ;
            owl:onProperty ec:hasRightsTargetService ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasRightsTerritoryExcludes ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasRightsTerritoryIncludes ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Contract ;
            owl:onProperty ec:originatesFrom ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:TimelinePoint ;
            owl:onProperty ec:hasDuration ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasEndDateTime ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass time:Instant ;
            owl:onProperty ec:hasStartDateTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:publishingEventsLeft ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:rightsExpression ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ec:rightsLink ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:rightsUsageRestrictions ] .

ec:Audience a owl:Class ;
    rdfs:label "Audience"@fr ;
    dcterms:description "Un groupe de consommateurs ou une aggrégation de groupes de consommateurs. Par exemple, un groupe peut correspondre à un ensemble de consommateurs d'une même tranche d'âges ou d'une même catégorie socioprofessionnelle."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:excludesAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Audience ;
            owl:onProperty ec:includesAudience ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:audienceAgeHigh ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ec:audienceAgeLow ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:audienceCount ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:audienceInterest ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ] ;
    skos:definition "un segment de consommateurs potentiels de services de médias qui se distingue par des critères qui déterminent son comportement de consommation, comme l'âge, l'éducation, le sexe, le statut social, le lieu de résidence, les attitudes, etc."@fr ;
    skos:example """- de 14 à 29 ans
- les jeunes ruraux
- les hommes de plus de 70 ans
- personnes orientées vers la culture
- personnes orientées vers le divertissement
- parents d'écoliers
- hommes peu instruits de moins de 25 ans
- jeunes progressistes"""@fr .

ec:Location a owl:Class ;
    rdfs:label "Localisation"@fr ;
    dcterms:description "Une localisation est liée à la ressource média, elle peut être décrite dans la ressource et donc être éventuellement fictive. Elle peut aussi représenter le lieu où la ressource a été créée (lieu de tournage). Une localisation est utilisée pour définir la couverture spatiale du reportage ou des lieux d'enregistrement comme par exemple : studios ou sur le terrain, associés aux EditorialObjects (ou à une partie des EditorialObjects). Note: le type de localisation doit être décrit comme une sous-classe de localisation."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Identifier ;
            owl:onProperty ec:hasIdentifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:LocationCode ;
            owl:onProperty ec:hasLocationCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Picture ;
            owl:onProperty ec:hasLocationPicture ],
        [ a owl:Restriction ;
            owl:allValuesFrom skos:Concept ;
            owl:onProperty ec:hasObjectType ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasRelatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Event ;
            owl:onProperty ec:hasRelatedEvent ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Resource ;
            owl:onProperty ec:hasRelatedResource ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:RegionCode ;
            owl:onProperty ec:hasRegionCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:locationAddressMunicipality ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:locationAddressPostalCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:locationAddressStreetName ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdfs:Literal ;
            owl:onProperty ec:name ],

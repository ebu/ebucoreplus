    skos:definition "un actif sous forme d'informations liées au contenu d'une MediaResource qui peut ou non exister."@fr ;
    skos:example """- un groupe d'EditorialObjects
- une "œuvre de l'esprit" unique, un morceau
- un segment d'une "œuvre de l'esprit"."""@fr .

ec:Agent a owl:Class ;
    rdfs:label "Un acteur"@fr ;
    dcterms:description "Un acteur est un terme général, soit un contact ou une personne ou une organisation à laquelle est associé un rôle correspondant à la contribution que l'acteur apporte à la réalisation d'une MediaResource ou d'un EditorialObject."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ec:Biography ;
            owl:onProperty ec:hasAgentBiography ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasAgentCountryOfResidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Language ;
            owl:onProperty ec:hasAgentLanguage ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Agent ;
            owl:onProperty ec:hasAgentMember ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:CountryCode ;
            owl:onProperty ec:hasAgentNationality ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Location ;
            owl:onProperty ec:hasAgentPlaceOfResidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Artefact ;
            owl:onProperty ec:hasAssociatedArtefact ],
        [ a owl:Restriction ;
            owl:allValuesFrom ec:Character ;
            owl:onProperty ec:hasCharacter ],
        [ a owl:Restriction ;

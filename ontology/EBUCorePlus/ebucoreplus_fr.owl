ec:synopsis a owl:DatatypeProperty ;
    rdfs:label "Synopsis"@fr ;
    dcterms:description "Pour fournir un résumé."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:contentDescription .

ec:tableOfContent a owl:DatatypeProperty ;
    rdfs:label "Table des matières"@fr ;

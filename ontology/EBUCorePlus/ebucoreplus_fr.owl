                                  owl:allValuesFrom rdfs:Literal
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty ec:name ;
                                  owl:allValuesFrom rdfs:Literal
                                ] ;
                dcterms:description "Permet d'identifier les coûts associés à un contrat."@fr ;
                rdfs:label "Coût d'un contrat"@fr .



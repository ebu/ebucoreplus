ec:hasShot a owl:ObjectProperty ;
    rdfs:label "a un plan"@fr ;
    rdfs:subPropertyOf ec:hasPart .

ec:hasSigning a owl:ObjectProperty ;
    rdfs:label "Accessibilité - signature"@fr ;
    dcterms:description "Pour identifier la présence d'une signature associée à l'EditorialObject."@fr .

ec:hasSigningFormat a owl:ObjectProperty ;
    rdfs:label "Format de signature"@fr ;
    dcterms:description "Pour spécifier le format utilisé pour la signature."@fr .

ec:hasSigningSource a owl:ObjectProperty ;
    rdfs:label "Source de signature"@fr ;
    dcterms:description "Pour spécifier la source de la signature."@fr .

ec:hasSource a owl:ObjectProperty ;
    rdfs:label "Source :"@fr ;
    dcterms:description "Pour identifier la source d'une MediaResource."@fr .

ec:hasStaffMember a owl:ObjectProperty ;
    rdfs:label "membre du personnel"@fr ;
    dcterms:description "Pour identifier les membres du personnel d'une organisation."@fr .

ec:hasStageLocation a owl:ObjectProperty ;
    rdfs:label "Lieu de la scène"@fr ;
    dcterms:description "Pour associer un emplacement à une scène."@fr .

ec:hasStakeholder a owl:ObjectProperty ;
    rdfs:label "Intervenant du plan de publication"@fr,
        "Parties prenantes"@fr ;
    dcterms:description "Pour identifier les agents associés à un PublicationPlan."@fr,
        "Un agent lié au PublicationPlan."@fr .

ec:hasStandard a owl:ObjectProperty ;
    rdfs:label "Standard"@fr ;
    dcterms:description "Identifie la norme vidéo technique d'une MediaResource, c'est-à-dire NTSC ou PAL."@fr ;
    rdfs:subPropertyOf ec:hasFormat .

ec:hasSticker a owl:ObjectProperty ;
    rdfs:label "Lien vers l'autocollant"@fr ;
    dcterms:description "Pour fournir un lien vers un autocollant"@fr .

ec:hasStorageId a owl:ObjectProperty ;
    rdfs:label "Identifiant de stockage"@fr ;
    dcterms:description "Identifier le stockage associé à un localisateur à partir duquel une ressource peut être accédée ou peut être récupérée."@fr .

ec:hasSubJob a owl:ObjectProperty ;
    rdfs:label "Poste de production"@fr ;
    dcterms:description "Pour identifier un ProductionJob / processus comme faisant partie d'un complexe ProductionJob."@fr .

ec:hasSubject a owl:ObjectProperty ;
    rdfs:label "Sujet"@fr ;
    dcterms:description "Cette propriété permet d'associer un actif à un sujet qui peut être une chaîne ou une URI pointant vers un terme d'un vocabulaire contrôlé."@fr .

ec:hasSubtitling a owl:ObjectProperty ;
    rdfs:label "Sous-titrage"@fr ;
    dcterms:description "Pour identifier le sous-titrage existant."@fr .

ec:hasSubtitlingFormat a owl:ObjectProperty ;
    rdfs:label "Format de sous-titrage"@fr ;
    dcterms:description "Le format du sous-titrage."@fr ;
    rdfs:subPropertyOf ec:hasFormat .

ec:hasSubtitlingSource a owl:ObjectProperty ;
    rdfs:label "Source de sous-titrage"@fr ;
    dcterms:description "Pour identifier la source du sous-titrage de la ressource."@fr .

ec:hasTargetChannel a owl:ObjectProperty ;
    rdfs:label "Canal de publication cible"@fr ;
    dcterms:description "Pour spécifier un canal de publication cible."@fr .

ec:hasTargetPlatform a owl:ObjectProperty ;
    rdfs:label "Plate-forme cible"@fr ;
    dcterms:description "Pour spécifier une plate-forme cible."@fr .

ec:hasTargetService a owl:ObjectProperty ;
    rdfs:label "Service de publication cible"@fr ;
    dcterms:description "Pour spécifier un service de publication cible."@fr .

ec:hasTeamMember a owl:ObjectProperty ;
    rdfs:label "Membre de l'équipe"@fr ;
    dcterms:description "Pour identifier les membres d'une équipe"@fr .

ec:hasTerritoryExcludes a owl:ObjectProperty ;
    rdfs:label "Zone d'exclusion"@fr ;
    dcterms:description "Pour définir l'emplacement (par exemple, le pays, la région) auquel le classement et le public cible ne s'appliquent PAS."@fr .

ec:hasTerritoryIncludes a owl:ObjectProperty ;
    rdfs:label "s'applique à"@fr ;
    dcterms:description "Identifier l'actif auquel le Rating s'applique."@fr .

ec:hasTextLineSource a owl:ObjectProperty ;
    rdfs:label "Source de la ligne de texte"@fr ;
    dcterms:description "Pour identifier la source d'un TextLine."@fr .

ec:hasTheme a owl:ObjectProperty ;
    rdfs:label "Thème"@fr ;
    dcterms:description "Cette propriété permet d'associer un actif à un thème qui peut être une chaîne ou un URI pointant vers un terme d'un vocabulaire contrôlé. Un exemple typique est la classification NACE d'Eurostats."@fr .

ec:hasTimecodeTrack a owl:ObjectProperty ;
    rdfs:label "Piste de timecode"@fr ;
    dcterms:description "Pour identifier une piste de timecode avec une MediaResource."@fr .

ec:hasTimelineTrack a owl:ObjectProperty ;
    rdfs:label "Piste chronologique"@fr ;
    dcterms:description "Pour associer un TimelineTrack à un EditorialObject"@fr .

ec:hasTimelineTrackPart a owl:ObjectProperty ;
    rdfs:label "Partie de la piste de la ligne de temps"@fr ;
    dcterms:description "Pour associer un EditorialObject à une TimelineTrack en tant que TimelineTrackpart"@fr ;
    owl:inverseOf ec:isTimelineTrackPartOf .

ec:hasTopic a owl:ObjectProperty ;
    rdfs:label "Sujet"@fr ;
    dcterms:description "Cette propriété permet d'associer un actif à un sujet qui peut être une chaîne ou une URI pointant vers un terme d'un vocabulaire contrôlé. Un exemple typique est l'utilisation des sujets IPTC Media Topics définis sur http://cv.iptc.org/newscodes/mediatopic/."@fr .

ec:hasTrack a owl:ObjectProperty ;
    rdfs:label "Piste"@fr ;
    dcterms:description "Pour associer des pistes audio/données/vidéo à une MediaResource."@fr .

ec:hasTrackPart a owl:ObjectProperty ;
    rdfs:label "Source de la partie de la voie"@fr ;
    dcterms:description "Un élément pour identifier une partie d'une piste par un titre, une heure de début et une heure de fin dans la source du média et la destination du médian."@fr ;
    owl:inverseOf ec:isTrackPartOf .

ec:hasTrackPurpose a owl:ObjectProperty ;
    rdfs:label "Objectif de la voie"@fr ;
    dcterms:description "Le but pour lequel la piste est fournie."@fr .

ec:hasTrackType a owl:ObjectProperty ;
    rdfs:label "Nom de la piste"@fr ;
    dcterms:description "Le type attribué à une piste."@fr .

ec:hasUnit a owl:ObjectProperty ;
    rdfs:label "Unité de mesure"@fr ;
    dcterms:description "Pour définir l'unité dans laquelle la valeur d'une mesure est exprimée, le cas échéant."@fr .

ec:hasUsageContract a owl:ObjectProperty ;
    rdfs:label "Contrat d'utilisation"@fr ;
    dcterms:description "Les conditions contractuelles selon lesquelles un ProductionDevice sera utilisé."@fr .

ec:hasUsageRights a owl:ObjectProperty ;
    rdfs:label "Droits d'utilisation"@fr ;
    dcterms:description "Pour exprimer les droits d'utilisation."@fr ;
    rdfs:subPropertyOf ec:hasRights .

ec:hasVersion a owl:ObjectProperty ;
    rdfs:label "Version"@fr ;
    dcterms:description "Pour identifier une autre version d'un actif, d'un objet éditorial ou d'une ressource."@fr ;
    owl:inverseOf ec:isVersionOf .

ec:hasVersionType a owl:ObjectProperty ;
    rdfs:label "Type de version"@fr ;
    dcterms:description "Pour spécifier un type de version pour un EditorialObject."@fr .

ec:hasVideoCodec a owl:ObjectProperty ;
    rdfs:label "Codec vidéo"@fr ;
    dcterms:description "Pour identifier un codec vidéo"@fr ;
    rdfs:subPropertyOf ec:hasCodec .

ec:hasVideoEncodingFormat a owl:ObjectProperty ;
    rdfs:label "Format d'encodage audio"@fr ;
    dcterms:description "Pour spécifier le format d'encodage vidéo."@fr ;
    rdfs:subPropertyOf ec:hasFormat .

ec:hasVideoTrack a owl:ObjectProperty ;
    rdfs:label "Piste vidéo"@fr ;
    dcterms:description "Pour identifier les VideoTracks dans la ressource."@fr .

ec:hasWrappingType a owl:ObjectProperty ;
    rdfs:label "Type d'emballage"@fr ;
    dcterms:description "Pour spécifier le type d'emballage."@fr .

ec:hashValue a owl:DatatypeProperty ;
    rdfs:label "Code de hachage"@fr ;
    dcterms:description "La valeur de hachage associée à une ressource. Il existe différentes méthodes / algorithmes pour calculer les valeurs de hachage, qui peuvent être définies en tant que sous-propriétés."@fr ;
    rdfs:range xsd:string .

ec:height a owl:DatatypeProperty ;
    rdfs:label "Hauteur"@fr ;
    dcterms:description "La hauteur d'une image vidéo, par exemple, généralement exprimée en nombre de lignes ou la hauteur d'une photo/image exprimée en millimètres ou autre unité."@fr ;
    rdfs:range xsd:integer .

ec:heightUnit a owl:DatatypeProperty ;
    rdfs:label "Unité de hauteur"@fr ;
    dcterms:description "Pour spécifier une unité pour exprimer la hauteur."@fr ;
    rdfs:range rdfs:Literal .

ec:highlights a owl:DatatypeProperty ;
    rdfs:label "Points forts"@fr ;
    dcterms:description "Pour fournir des points forts."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:contentDescription .

ec:hobbies a owl:DatatypeProperty ;
    rdfs:label "Passe-temps"@fr ;
    dcterms:description "Les loisirs d'une personne."@fr ;
    rdfs:range rdfs:Literal .

ec:holdsAward a owl:ObjectProperty ;
    rdfs:label "reçoit"@fr ;
    owl:inverseOf ec:isAwardedTo .

ec:holdsLicence a owl:ObjectProperty ;
    rdfs:label "Licence de consommation"@fr ;
    dcterms:description "Les termes d'une ConsumptionLicence associée à un contrat."@fr .

ec:iFrameSize a owl:DatatypeProperty ;
    rdfs:label "Taille I-frame/Gap"@fr ;
    dcterms:description "La distance entre 2 I-frames également connue comme la taille du gap."@fr ;
    rdfs:range xsd:int .

ec:identifierValue a owl:DatatypeProperty ;
    rdfs:label "Valeur d'identification"@fr ;
    dcterms:description "Plage : chaîne de caractères ou anyURI."@fr ;
    rdfs:range rdfs:Literal .

ec:inchesPerSecond a owl:DatatypeProperty ;
    rdfs:label "Pouces par seconde"@fr ;
    dcterms:description "Identifie les pouces par seconde auxquels une bande audio analogique doit être lue pour la consommation humaine."@fr ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf ec:playbackSpeed .

ec:includesAudience a owl:ObjectProperty ;
    rdfs:label "Comprend le public"@fr ;
    dcterms:description "Un groupe d'audience défini qui est inclus dans l'audience"@fr .

ec:instantiates a owl:ObjectProperty ;
    rdfs:label "Objet de la rédaction"@fr ;
    dcterms:description "Pour lier une manifestation particulière d'un objet éditorial à la ressource correspondante."@fr ;
    owl:inverseOf ec:isInstantiatedBy .

ec:internetConnectivity a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Connectivité Internet"@fr ;
    dcterms:description "Pour indiquer si le service nécessite une connection Internet."@fr .

ec:isAbout a owl:ObjectProperty ;
    rdfs:label "est à propos"@fr ;
    dcterms:description "Cette propriété est utilisée lorsqu'un autre objet éditorial, par exemple un livre, un film ou un programme, fait l'objet de l'objet éditorial."@fr ;
    rdfs:range ec:Asset .

ec:isAffiliatedTo a owl:ObjectProperty ;
    rdfs:label "est affilié à"@fr ;
    dcterms:description "Relation avec l'organisation que l'affiliation représente"@fr .

ec:isAffiliationFor a owl:ObjectProperty .

ec:isAnimalGroomFor a owl:ObjectProperty .

ec:isAnnotatedMediaResource a owl:ObjectProperty ;
    rdfs:label "Resource médiatique"@fr ;
    dcterms:description "Pour lier une Annotation à une MediaResource."@fr .

ec:isAttributedTo a owl:ObjectProperty ;
    rdfs:label "Cible de provenance"@fr ;
    dcterms:description "Pour associer un agent à une instance de Provenance."@fr .

ec:isAuthorOf a owl:ObjectProperty .

ec:isCommissionedBy a owl:ObjectProperty ;
    rdfs:label "Contrat"@fr ;
    dcterms:description "Le contrat par lequel une ressource est commandée."@fr .

ec:isComposedOf a owl:ObjectProperty ;
    rdfs:label "Resource médiatique"@fr ;
    dcterms:description "Identifier les mediaResources utilisées pour composer une Essence."@fr .

ec:isDistributedOn a owl:ObjectProperty ;
    rdfs:label "Plate-forme/Service/Canal de publication"@fr ;
    dcterms:description "Pour identifier la plateforme sur laquelle le contenu est distribué."@fr .

ec:isEmbodiedBy a owl:ObjectProperty .

ec:isEpisodeOfSeason a owl:ObjectProperty ;
    rdfs:label "Saison des parents"@fr ;
    dcterms:description "L'épisode d'une saison."@fr .

ec:isEpisodeOfSerial a owl:ObjectProperty ;
    rdfs:label "est un épisode de la série"@fr .

ec:isEpisodeOfSeries a owl:ObjectProperty ;
    rdfs:label "Série sur les parents"@fr ;
    dcterms:description "L'épisode d'une série."@fr .

ec:isExtractOf a owl:ObjectProperty ;
    rdfs:label "est un extrait de"@fr ;
    dcterms:description "Utilisé pour représenter un extrait, c'est-à-dire la diffusion d'une partie ou de la totalité d'un matériel archivé sur le playout. Pour les attributs tels que la durée et le début, les données sont placées dans l'instance représentant l'extrait. Les autres métadonnées sont lues à partir de l'instance originale qui est extraite."@fr .

ec:isNextInSequence a owl:ObjectProperty ;
    rdfs:label "Suivant"@fr ;
    dcterms:description "Un lien vers un objet éditorial suivant l'objet éditorial actuel dans une séquence ordonnée."@fr ;
    owl:inverseOf ec:isPreviousInSequence .

ec:isOfferedBy a owl:ObjectProperty ;
    rdfs:label "Service"@fr ;
    dcterms:description "Pour identifier un service associé à un PublicationEvent."@fr ;
    owl:inverseOf ec:offers .

ec:isOperatedBy a owl:ObjectProperty ;
    rdfs:label "Opérateur, propriétaire"@fr ;
    dcterms:description "Pour identifier le service qui exploite le canal de publication."@fr .

ec:isPlayedBy a owl:ObjectProperty ;
    rdfs:label "est joué par"@fr ;
    dcterms:description "Relation entre un personnage fictif et l'acteur qui joue le rôle."@fr ;
    owl:inverseOf ec:playsCharacter ;
    owl:propertyDisjointWith ec:isPortrayedBy .

ec:isRelatedAgent a owl:ObjectProperty .

ec:isReplacedBy a owl:ObjectProperty ;
    rdfs:label "Remplacement"@fr ;
    dcterms:description "Pour identifier les substitutions."@fr ;
    owl:inverseOf ec:replaces .

ec:isSeasonOf a owl:ObjectProperty ;
    rdfs:label "Série"@fr ;
    dcterms:description "Pour associer une Saison à une Série."@fr .

ec:isoDuration a owl:DatatypeProperty ;
    rdfs:label "Durée ISO"@fr ;
    dcterms:description "une durée exprimée sous la forme d'une chaîne de caractères au format ISO8601 : PT3M23S"@fr ;
    rdfs:range xsd:string .

ec:lineNumber a owl:DatatypeProperty ;
    rdfs:label "Numéro de ligne"@fr ;
    dcterms:description "Ppur fournir le numéro de la ligne sur laquelle les données auxiliaires sont transportées et l'équivalent dans le domaine numérique."@fr ;
    rdfs:range xsd:integer .

ec:live a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "En direct"@fr ;
    dcterms:description "Un drapeau pour signaler que le contenu est en direct"@fr ;
    rdfs:range xsd:boolean .

ec:locationAddressApartmentNumber a owl:DatatypeProperty ;
    rdfs:label "numéro de l'appartement"@fr ;
    dcterms:description "Le numéro identifiant un appartement dans une maison."@fr ;
    rdfs:range xsd:string .

ec:locationAddressArea a owl:DatatypeProperty ;
    rdfs:label "Zone"@fr ;
    dcterms:description "Pour fournir la partie Zone d'une adresse."@fr ;
    rdfs:range rdfs:Literal .

ec:locationAddressCountry a owl:DatatypeProperty ;
    rdfs:label "Pays"@fr ;
    dcterms:description "Pour fournir le nom du pays et ou le code du pays."@fr ;
    rdfs:range rdfs:Literal .

ec:locationAddressHouseNumber a owl:DatatypeProperty ;
    rdfs:label "numéro de maison"@fr ;
    dcterms:description "Le numéro donné à la maison ou à une entrée dans une rue"@fr ;
    rdfs:range xsd:string .

ec:locationAddressMunicipality a owl:DatatypeProperty ;
    rdfs:label "municipalité"@fr ;
    dcterms:description "Pour fournir le nom d'une ville, d'un village, etc."@fr ;
    rdfs:range rdfs:Literal .

ec:locationAddressPostalCode a owl:DatatypeProperty ;
    rdfs:label "Code postal"@fr ;
    dcterms:description "Pour fournir le code de l' adresse postale ."@fr ;
    rdfs:range rdfs:Literal .

ec:locationAddressStreetName a owl:DatatypeProperty ;
    rdfs:label "nom de la rue"@fr ;
    dcterms:description "Le nom de la rue, de la place ou du bloc dans une adresse"@fr ;
    rdfs:range rdfs:Literal .

ec:locationAltitude a owl:DatatypeProperty ;
    rdfs:label "Altitude"@fr ;
    dcterms:description "Pour définir l'altitude d'un emplacement en mètres."@fr ;
    rdfs:range xsd:float .

ec:locationCoordinateSystemName a owl:DatatypeProperty ;
    rdfs:label "Système de coordonnées"@fr ;
    dcterms:description "Pour spécifier le nom du système de coordonnées gps utilisé pour l'emplacement."@fr ;
    rdfs:range rdfs:Literal .

ec:locationLatitude a owl:DatatypeProperty ;
    rdfs:label "Latitude"@fr ;
    dcterms:description "La latitude de l'emplacement."@fr ;
    rdfs:range xsd:float .

ec:locationLongitude a owl:DatatypeProperty ;
    rdfs:label "Longitude"@fr ;
    dcterms:description "Pour définir la longitude de la emplacement."@fr ;
    rdfs:range xsd:float .

ec:locatorTargetInformation a owl:DatatypeProperty ;
    rdfs:label "Informations sur la cible du localisateur"@fr ;
    dcterms:description "Informations sur la cible du localisateur."@fr ;
    rdfs:range rdfs:Literal .

ec:log a owl:DatatypeProperty ;
    rdfs:label "Journal de bord"@fr ;
    dcterms:description "Pour enregistrer tout le contenu selon des règles et des critères prédéfinis, sous la forme d'une séquence neutre de descriptions textuelles (éventuellement minutées)."@fr ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf ec:contentDescription .

ec:logs a owl:ObjectProperty .

ec:maritalStatus a owl:DatatypeProperty ;
    rdfs:label "État civil"@fr ;
    dcterms:description "Pour identifier l'état civil d'une personne."@fr ;
    rdfs:range rdfs:Literal .

ec:measureValue a owl:DatatypeProperty ;
    rdfs:label "Valeur de mesure"@fr ;
    dcterms:description "Pour fournir la valeur d'une mesure."@fr .

ec:measureValueMax a owl:DatatypeProperty ;
    rdfs:label "Mesure de la valeur maximale"@fr ;
    dcterms:description "Pour définir la valeur maximale d'une mesure lorsque applicable."@fr .

ec:measureValueMin a owl:DatatypeProperty ;
    rdfs:label "Mesure de la valeur minimale"@fr ;
    dcterms:description "Pour définir la valeur minimale d'une mesure lorsque applicable."@fr .

ec:measures a owl:ObjectProperty ;
    rdfs:label "Règle connexe"@fr ;
    dcterms:description "Pour associer une règle à une mesure."@fr .

ec:microphone a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Microphone"@fr ;
    dcterms:description "Pour indiquer si le service nécessite un microphone."@fr .

ec:midRollAdAllowed a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Publicité midroll autorisée"@fr ;
    dcterms:description "Un drapeau pour indiquer s'il est autorisé d'insérer des coupures publicitaires en mid-roll."@fr ;
    rdfs:range xsd:boolean .

ec:middleName a owl:DatatypeProperty ;
    rdfs:label "Second prénom"@fr ;
    dcterms:description "Pour fournir un ou plusieurs seconds prénoms à une personne."@fr ;
    rdfs:range rdfs:Literal .

ec:nickName a owl:DatatypeProperty ;
    rdfs:label "Surnom"@fr ;
    dcterms:description "Le surnom d'une personne."@fr ;
    rdfs:range rdfs:Literal .

ec:noiseFilter a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Filtre anti-bruit"@fr ;
    dcterms:description "Un drapeau pour signaler qu'un filtre de bruit a été utilisé."@fr ;
    rdfs:range xsd:boolean .

ec:notRated a owl:DatatypeProperty ;
    rdfs:label "Non évalué"@fr ;
    dcterms:description "Un drapeau pour indiquer que l'EditorialObject n'a pas été évalué."@fr ;
    rdfs:range xsd:boolean .

ec:occupation a owl:DatatypeProperty ;
    rdfs:label "Profession"@fr ;
    dcterms:description "Le nom de l'emploi / de la profession d'une personne."@fr ;
    rdfs:range rdfs:Literal .

ec:occursOn a owl:ObjectProperty .

ec:officeEmailAddress a owl:DatatypeProperty ;
    rdfs:label "Courriel du bureau"@fr ;
    dcterms:description "Pour fournir l'adresse électronique professionnelle/bureautique d'un agent (contact/personne ou organisation)."@fr ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ec:agentEmailAddress .

ec:officeMobileTelephoneNumber a owl:DatatypeProperty ;
    rdfs:label "Téléphone (bureau)"@fr ;
    dcterms:description "Pour fournir le numéro de téléphone mobile du bureau d'un agent (contact/personne)."@fr ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ec:agentTelephoneNumber .

ec:officeTelephoneNumber a owl:DatatypeProperty ;
    rdfs:label "Téléphone (bureau)"@fr ;
    dcterms:description "Pour fournir le numéro de téléphone du bureau d'un agent (contact/personne)."@fr ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ec:agentTelephoneNumber .

ec:onStagePositionCoordinateX a owl:DatatypeProperty ;
    rdfs:label "Coordonnée X"@fr ;
    dcterms:description "Les coordonnées x dans un espace à 3 axes"@fr .

ec:onStagePositionCoordinateY a owl:DatatypeProperty ;
    rdfs:label "Coordonnée Y"@fr ;
    dcterms:description "Les coordonnées y dans un espace à 3 axes."@fr .

ec:onStagePositionCoordinateZ a owl:DatatypeProperty ;
    rdfs:label "Coordonnée Z"@fr ;
    dcterms:description "Les coordonnées z dans un espace à 3 axes."@fr .

ec:onStagePositionCoordinatesReferencePoint a owl:DatatypeProperty ;
    rdfs:label "Point de référence des coordonnées de la position sur scène"@fr ;
    dcterms:description "Pour définir un point de référence pour un ensemble de coordonnées définissant une position sur la scène."@fr .

ec:orderedFlag a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Ordonné"@fr ;
    dcterms:description "Un indicateur pour indiquer qu'un ÉditorialObject est membre d'un groupe ordonné ou est un groupe ordonné (par ex. Série)"@fr ;
    rdfs:range xsd:boolean .

ec:orientation a owl:DatatypeProperty ;
    rdfs:label "Orientation"@fr ;
    dcterms:description "L'orientation d'un document ou d'une image, c'est-à-dire paysage ou portrait."@fr ;
    rdfs:range rdfs:Literal .

ec:originatesFrom a owl:ObjectProperty ;
    rdfs:label "Contrat"@fr ;
    dcterms:description "Le contrat dont découlent les droits."@fr .

ec:owns a owl:ObjectProperty ;
    rdfs:label "possède"@fr ;
    dcterms:description "Pour identifier la Marque, le Canal de publication, la Plateforme de publication ou le Service de publication possédé par un Agent (Contact, Personne ou Organisation)."@fr .

ec:packageByteSize a owl:DatatypeProperty ;
    rdfs:label "Taille du paquet (en octets)"@fr ;
    dcterms:description "La taille d'un paquet média en octets."@fr ;
    rdfs:range xsd:long .

ec:packageName a owl:DatatypeProperty ;
    rdfs:label "Nom du paquet"@fr ;
    dcterms:description "Le nom d'un paquet média en octets."@fr ;
    rdfs:range rdfs:Literal .

ec:partTotalNumber a owl:DatatypeProperty ;

ec:publicationPlanTitle a owl:DatatypeProperty .

ec:publishingEventsLeft a owl:DatatypeProperty .

ec:radioTuner a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Tuner radio"@fr ;

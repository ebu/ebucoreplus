ec:hasEndDateTime a owl:ObjectProperty ;
    rdfs:label "Instant de fin"@fr ;
    dcterms:description "Décrit la fin d'un intervalle"@fr ;
    rdfs:subPropertyOf ec:hasDate .

ec:hasFormat a owl:ObjectProperty ;
    rdfs:label "Format"@fr ;
    dcterms:description "Pour identifier un format"@fr .

ec:hasStartDateTime a owl:ObjectProperty ;
    rdfs:label "Date de début"@fr ;
    dcterms:description "Un instant ou l'nstant de départ d'un intervalle"@fr ;
    rdfs:subPropertyOf ec:hasDate .

ec:contentDescription a owl:DatatypeProperty ;
    rdfs:label "Description du contenu"@fr ;
    dcterms:description "Ceci peut être spécialisé en utilisant des sous-propriétés comme celles définies dans https://github.com/ebu/ebu_cs/blob/main/metadata/cs/ebu_DescriptionTypeCodeCS.xml mises en œuvre à titre d'exemple, comme par exemple \"summary\" ou \"script\"."@fr ;
    rdfs:isDefinedBy <dc:description> ;
    rdfs:range rdfs:Literal .

ec:Format a owl:Class ;
    rdfs:label "Format"@fr ;
    dcterms:description "Un format peut être défini comme une collection de formats audio/vidéo/données et de conteneurs. Un format peut être associé globalement à une ressource multimédia, mais des formats audio/vidéo/données et conteneurs spécifiques peuvent également être associés de manière distincte à une ressource multimédia. Le ContainerFormat définit la structure du fichier / paquet de la MediaResource."@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Identifier ;
            owl:onProperty ec:hasFormatId ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ec:Identifier ;
            owl:onProperty ec:hasFormatVersionId ],
        skos:Concept .

ec:TimelinePoint a owl:Class ;
    rdfs:label "Point de repère chronologique"@fr ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:float ;
            owl:onProperty ec:equivalentTime ] .

ec:MediaResource a owl:Class ;
    rdfs:label "Resource médiatique"@fr ;
    dcterms:description "Une MediaResource audiovisuelle, qui peut être composée d'une ou plusieurs Pistes. une ressource multimédia, MediaResource est définie par un objet éditorial EditorialObject, (domaine éditorial), qui peut être réalisé dans des essences dans un ou plusieurs formats pour différents médias ou plateformes de diffusion."@fr ;

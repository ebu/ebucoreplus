ec:textLineOrder a owl:DatatypeProperty ;
    rdfs:label "Ordre des lignes de texte"@fr ;
    dcterms:description "L'ordre dans lequel une ligne de texte peut être trouvée, par exemple dans une scène."@fr ;
    rdfs:range rdfs:Literal .

ec:timeOfDay a owl:DatatypeProperty ;
    rdfs:label "heure de la journée"@fr ;
    dcterms:description "Une heure exprimée comme une heure normale de la journée"@fr ;
    rdfs:range xsd:time .

ec:timeshift a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Soutien aux horaires décalés"@fr ;
    dcterms:description "Un drapeau pour indiquer si le service a besoin d'une équipe de travail en horaires décalés. soutien."@fr .

ec:totalNumberOfAudioChannels a owl:DatatypeProperty ;
    rdfs:label "Nombre de canal audio"@fr ;
    dcterms:description "Le nombre total de canaux audio contenus dans la MediaResource."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:totalNumberOfAudioTracks a owl:DatatypeProperty ;
    rdfs:label "Nombre de pistes audio"@fr ;
    dcterms:description "Pour fournir le nombre total de pistes audio."@fr ;
    rdfs:range xsd:integer .

ec:totalNumberOfEpisodes a owl:DatatypeProperty ;
    rdfs:label "Nombre total d'épisodes"@fr ;
    dcterms:description "Pour fournir le nombre total d'épisodes d'une série ou d'une saison."@fr ;
    rdfs:range xsd:integer .

ec:totalNumberOfGroupMembers a owl:DatatypeProperty ;
    rdfs:label "Nombre total de membres du groupe"@fr ;

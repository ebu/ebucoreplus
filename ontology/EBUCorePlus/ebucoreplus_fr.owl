    rdfs:range xsd:nonNegativeInteger .

ec:textLineBoxTopLeftCornerPixelNumber a owl:DatatypeProperty ;
    rdfs:label "Boîte de ligne de texte en haut à gauche Position Corner X."@fr ;
    dcterms:description "Les coordonnées sur un axe horizontal de la position du coin supérieur gauche de la zone de texte contenant la TextLine."@fr ;

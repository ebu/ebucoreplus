ec:textLineBoxWidth a owl:DatatypeProperty ;
    rdfs:label "Largeur de la boîte de la ligne de texte."@fr ;
    dcterms:description "La largeur de la zone de texte contenant la TextLine."@fr ;
    rdfs:range xsd:nonNegativeInteger .

ec:textLineContent a owl:DatatypeProperty ;

                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty ec:hasProductionJobEvent ;
                                   owl:allValuesFrom ec:Event
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty ec:hasProductionJobLocation ;

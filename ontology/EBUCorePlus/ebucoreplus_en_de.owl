                                      "Ein Eintrag aus der Klassifikation von Annotationen."@de ;
                  rdfs:label "Anmerkungstyp"@de ,
                             "Annotation type"@en ;
                  skos:definition "a skos:Concept classifying an ec:Annotation"@en ,
                                  "ein skos:Concept, der ein ec:Annotation klassifiziert"@de .



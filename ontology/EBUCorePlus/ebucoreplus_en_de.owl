                           "Lizenzierung"@de ;
                skos:definition "an owl:ObjectProperty relating an ec:Asset to an ec:Licensing"@en ,
                                "eine owl:ObjectProperty, die ein ec:Asset mit einem ec:Licensing verknüpft"@de .


